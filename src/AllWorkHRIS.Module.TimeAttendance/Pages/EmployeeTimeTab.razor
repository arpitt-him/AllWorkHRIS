@inject TimeAttendanceQueryService QueryService
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.DropDowns

@if (_loading)
{
    <p class="loading-text">Loading…</p>
}
else if (_periods.Count == 0)
{
    <p class="placeholder-text">No time entries on record for this employee.</p>
}
else
{
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;">
        <label class="detail-label" style="margin:0;">Period</label>
        <SfDropDownList TValue="Guid" TItem="TaPeriodOption" DataSource="@_periods"
                        Value="@_selectedPeriodId" Width="280px">
            <DropDownListFieldSettings Value="PeriodId" Text="Label" />
            <DropDownListEvents TValue="Guid" TItem="TaPeriodOption"
                                ValueChange="OnPeriodChangedSf" />
        </SfDropDownList>
    </div>

    @if (_entriesLoading)
    {
        <p class="loading-text">Loading entries…</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="placeholder-text">No entries for this period.</p>
    }
    else
    {
        <SfGrid DataSource="@_entries" AllowSorting="true" CssClass="e-gridhover">
            <GridColumns>
                <GridColumn HeaderText="Date" Width="120">
                    <Template>@{ var e = (TimeEntryRow)context; }@e.WorkDate.ToString("ddd MMM d")</Template>
                </GridColumn>
                <GridColumn HeaderText="Category" Width="130">
                    <Template>@{ var e = (TimeEntryRow)context; }<span class="category-chip">@e.TimeCategoryCode</span></Template>
                </GridColumn>
                <GridColumn Field="Duration" HeaderText="Hours" Width="90">
                    <Template>@{ var e = (TimeEntryRow)context; }@e.Duration.ToString("F2")</Template>
                </GridColumn>
                <GridColumn HeaderText="Time" Width="130">
                    <Template>
                        @{ var e = (TimeEntryRow)context; }
                        @(e.StartTime.HasValue && e.EndTime.HasValue
                            ? $"{e.StartTime.Value:HH:mm}–{e.EndTime.Value:HH:mm}"
                            : "—")
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="Status" Width="110">
                    <Template>@{ var e = (TimeEntryRow)context; }<span class="status-badge status-@e.StatusCode.ToLower()">@e.StatusCode</span></Template>
                </GridColumn>
                <GridColumn HeaderText="Notes">
                    <Template>
                        @{ var e = (TimeEntryRow)context; }
                        <span class="note-cell">
                            @(e.RejectionReason is not null
                                ? $"Rejected: {e.RejectionReason}"
                                : e.Notes ?? "")
                        </span>
                    </Template>
                </GridColumn>
            </GridColumns>
            <GridAggregates>
                <GridAggregate>
                    <GridAggregateColumns>
                        <GridAggregateColumn Field="Duration" Type="AggregateType.Sum">
                            <FooterTemplate>
                                @{ var agg = (AggregateTemplateContext)context; }
                                <strong style="color:var(--aw-navy);">@(Convert.ToDecimal(agg.Sum).ToString("F2")) hrs total</strong>
                            </FooterTemplate>
                        </GridAggregateColumn>
                    </GridAggregateColumns>
                </GridAggregate>
            </GridAggregates>
        </SfGrid>
    }
}

@code {
    [Parameter] public Guid EmploymentId { get; set; }

    private bool _loading        = true;
    private bool _entriesLoading = false;
    private Guid _selectedPeriodId;
    private List<TaPeriodOption>  _periods = [];
    private List<TimeEntryRow>    _entries = [];

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try
        {
            _periods = (await QueryService.GetPeriodsWithEntriesForEmploymentAsync(EmploymentId)).ToList();
            if (_periods.Count > 0)
            {
                _selectedPeriodId = _periods[0].PeriodId;
                await LoadEntriesAsync();
            }
        }
        finally { _loading = false; }
    }

    private async Task OnPeriodChangedSf(ChangeEventArgs<Guid, TaPeriodOption> args)
    {
        _selectedPeriodId = args.Value;
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        _entriesLoading = true;
        try
        {
            _entries = (await QueryService.GetEntriesForEmploymentAsync(EmploymentId, _selectedPeriodId)).ToList();
        }
        finally { _entriesLoading = false; }
    }
}

<style>
    .category-chip {
        font-size: .7rem;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 999px;
        background: #e0f2fe;
        color: #0369a1;
        white-space: nowrap;
    }

    .note-cell {
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: var(--font-size-sm);
        color: #6b7280;
    }

    .status-submitted { background: #dbeafe; color: #1e3a8a; }
    .status-approved  { background: #dcfce7; color: #14532d; }
    .status-rejected  { background: #fee2e2; color: #7f1d1d; }
    .status-locked    { background: #e0e7ff; color: #3730a3; }
    .status-draft     { background: #f3f4f6; color: #6b7280; }
    .status-corrected { background: #fef9c3; color: #713f12; }
</style>
