@page "/ta/timecards"
@layout TimeAttendanceShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "TimeViewer,TimeAdmin,Manager")]
@using Microsoft.AspNetCore.Authorization
@using AllWorkHRIS.Module.TimeAttendance.Commands
@inject IHrisSessionState           SessionState
@inject TimeAttendanceQueryService  QueryService
@inject ITimeEntryService           TimeEntryService

<PageTitle>Timecards — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Timecards</h2>
    </div>

    @* ── Period selector ──────────────────────────────────────────────── *@
    <div class="filter-row" style="margin-bottom:var(--space-5,1.25rem);">
        <label class="filter-label">Period</label>
        <select class="form-input" style="width:320px;" value="@_selectedPeriodId"
                @onchange="OnPeriodChanged">
            <option value="">— select period —</option>
            @foreach (var p in _periods)
            {
                <option value="@p.PeriodId">@p.Label</option>
            }
        </select>
    </div>

    @if (_selectedPeriodId == Guid.Empty)
    {
        <div class="empty-state">Select a period to view timecards.</div>
    }
    else if (_loading)
    {
        <div class="empty-state">Loading…</div>
    }
    else
    {
        @* ── Stat cards ───────────────────────────────────────────────── *@
        <div class="stat-cards" style="margin-bottom:var(--space-5,1.25rem);">
            <div class="stat-card">
                <span class="stat-label">Pending Approval</span>
                <span class="stat-value">@_pendingApproval</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Overtime Alerts</span>
                <span class="stat-value @(_overtimeAlerts > 0 ? "stat-value--warn" : "")">@_overtimeAlerts</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Unapproved at Cutoff Risk</span>
                <span class="stat-value @(_cutoffRisk > 0 ? "stat-value--warn" : "")">@_cutoffRisk</span>
            </div>
        </div>

        @* ── Grid ─────────────────────────────────────────────────────── *@
        @if (_rows.Count == 0)
        {
            <div class="empty-state">No time entries found for this period.</div>
        }
        else
        {
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th class="text-right">Total Hrs</th>
                            <th class="text-right">Regular</th>
                            <th class="text-right" style="color:var(--module-ta,#7c3aed)">Overtime</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr class="@(_detailEmploymentId == row.EmploymentId ? "row-selected" : "")">
                                <td>
                                    <div style="font-weight:500;">@row.EmployeeName</div>
                                    <div style="font-size:.8rem;color:#9ca3af;">@row.EmployeeNumber</div>
                                </td>
                                <td class="text-right">@row.TotalHours.ToString("F2")</td>
                                <td class="text-right">@row.RegularHours.ToString("F2")</td>
                                <td class="text-right @(row.OvertimeHours > 0 ? "text-warn" : "")">
                                    @row.OvertimeHours.ToString("F2")
                                </td>
                                <td><span class="status-badge status-@TimecardStatus(row).ToLower()">@TimecardStatus(row)</span></td>
                                <td>
                                    <div style="display:flex;gap:.5rem;align-items:center;">
                                        <button class="btn-link" @onclick="() => ToggleDetail(row.EmploymentId)">
                                            @(_detailEmploymentId == row.EmploymentId ? "Close" : "View")
                                        </button>
                                        @if (row.SubmittedCount > 0)
                                        {
                                            <button class="btn-sm btn-primary" @onclick="() => ApproveAllAsync(row)">
                                                Approve All
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>

                            @* ── Inline detail panel ──────────────────────────────── *@
                            @if (_detailEmploymentId == row.EmploymentId)
                            {
                                <tr>
                                    <td colspan="6" style="padding:0;background:#f9fafb;">
                                        <div class="detail-panel">
                                            @if (_detailLoading)
                                            {
                                                <div class="empty-state">Loading entries…</div>
                                            }
                                            else if (_detailEntries.Count == 0)
                                            {
                                                <div class="empty-state" style="padding:1rem;">No entries.</div>
                                            }
                                            else
                                            {
                                                <table class="data-table data-table--inner">
                                                    <thead>
                                                        <tr>
                                                            <th>Date</th>
                                                            <th>Category</th>
                                                            <th class="text-right">Hours</th>
                                                            <th>Time</th>
                                                            <th>Status</th>
                                                            <th>Notes</th>
                                                            <th>Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var entry in _detailEntries)
                                                        {
                                                            <tr>
                                                                <td>@entry.WorkDate.ToString("ddd MMM d")</td>
                                                                <td><span class="cat-badge cat-@entry.TimeCategoryCode.ToLower()">@entry.TimeCategoryCode</span></td>
                                                                <td class="text-right">@entry.Duration.ToString("F2")</td>
                                                                <td style="font-size:.8rem;color:#6b7280;">
                                                                    @(entry.StartTime.HasValue ? $"{entry.StartTime:HH:mm}–{entry.EndTime:HH:mm}" : "—")
                                                                </td>
                                                                <td><span class="status-badge status-@entry.StatusCode.ToLower()">@entry.StatusCode</span></td>
                                                                <td style="font-size:.8rem;color:#6b7280;max-width:200px;overflow:hidden;text-overflow:ellipsis;">
                                                                    @(entry.RejectionReason ?? entry.Notes ?? "")
                                                                </td>
                                                                <td>
                                                                    @if (entry.StatusCode is "SUBMITTED" or "CORRECTED")
                                                                    {
                                                                        <div style="display:flex;gap:.35rem;">
                                                                            <button class="btn-sm btn-primary"
                                                                                    @onclick="() => ApproveEntryAsync(row.EmploymentId, entry.TimeEntryId)">✓</button>
                                                                            <button class="btn-sm btn-danger"
                                                                                    @onclick="() => StartReject(entry.TimeEntryId)">✗</button>
                                                                        </div>
                                                                    }
                                                                </td>
                                                            </tr>
                                                            @if (_rejectEntryId == entry.TimeEntryId)
                                                            {
                                                                <tr style="background:#fff7ed;">
                                                                    <td colspan="7" style="padding:.75rem 1rem;">
                                                                        <div style="display:flex;gap:.5rem;align-items:center;">
                                                                            <input class="form-input" style="flex:1;" placeholder="Rejection reason (required)"
                                                                                   @bind="_rejectReason" @bind:event="oninput" />
                                                                            <button class="btn-sm btn-danger" @onclick="ConfirmRejectAsync"
                                                                                    disabled="@string.IsNullOrWhiteSpace(_rejectReason)">Reject</button>
                                                                            <button class="btn-sm btn-ghost" @onclick="CancelReject">Cancel</button>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>

                                                @* Overtime summary *@
                                                @if (_detailEntries.Any(e => e.TimeCategoryCode == "OVERTIME"))
                                                {
                                                    <div class="ot-summary">
                                                        <span>OT this period:</span>
                                                        <strong>@_detailEntries.Where(e => e.TimeCategoryCode == "OVERTIME").Sum(e => e.Duration).ToString("F2") hrs</strong>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="alert-error" style="margin-top:.75rem;">@_errorMsg</div>
        }
    }
</div>

@code {
    private Guid                       _selectedPeriodId = Guid.Empty;
    private List<TaPeriodOption>       _periods          = [];
    private List<TimecardSummaryRow>   _rows             = [];
    private bool                       _loading;
    private int                        _pendingApproval, _overtimeAlerts, _cutoffRisk;

    private Guid?                      _detailEmploymentId;
    private List<TimeEntryRow>         _detailEntries    = [];
    private bool                       _detailLoading;

    private Guid?                      _rejectEntryId;
    private string                     _rejectReason     = string.Empty;
    private string                     _errorMsg         = string.Empty;

    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var entityId = SessionState.SelectedLegalEntityId;
        if (entityId is null) return;

        _periods = (await QueryService.GetOpenPeriodsForEntityAsync(entityId.Value)).ToList();
        if (_periods.Count > 0)
        {
            _selectedPeriodId = _periods[0].PeriodId;
            await LoadPeriodAsync();
        }
    }

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var id)) return;
        _selectedPeriodId   = id;
        _detailEmploymentId = null;
        _detailEntries      = [];
        await LoadPeriodAsync();
    }

    private async Task LoadPeriodAsync()
    {
        var entityId = SessionState.SelectedLegalEntityId;
        if (entityId is null || _selectedPeriodId == Guid.Empty) return;

        _loading = true;
        _errorMsg = string.Empty;
        StateHasChanged();

        try
        {
            _rows = (await QueryService.GetTimecardSummariesAsync(entityId.Value, _selectedPeriodId)).ToList();
            (_pendingApproval, _overtimeAlerts, _cutoffRisk) =
                await QueryService.GetStatCardsAsync(entityId.Value, _selectedPeriodId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleDetail(Guid employmentId)
    {
        if (_detailEmploymentId == employmentId)
        {
            _detailEmploymentId = null;
            _detailEntries      = [];
            return;
        }

        _detailEmploymentId = employmentId;
        _detailLoading      = true;
        _rejectEntryId      = null;
        StateHasChanged();

        try
        {
            _detailEntries = (await QueryService.GetEntriesForEmploymentAsync(
                employmentId, _selectedPeriodId)).ToList();
        }
        finally { _detailLoading = false; }
    }

    private async Task ApproveEntryAsync(Guid employmentId, Guid timeEntryId)
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var actorId   = GetActorId(authState);

        try
        {
            await TimeEntryService.ApproveTimeEntryAsync(
                new ApproveTimeEntryCommand { TimeEntryId = timeEntryId, ApprovedBy = actorId });
            await RefreshDetailAsync(employmentId);
            await LoadPeriodAsync();
        }
        catch (Exception ex) { _errorMsg = ex.Message; }
    }

    private async Task ApproveAllAsync(TimecardSummaryRow row)
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var actorId   = GetActorId(authState);

        var entries = await QueryService.GetEntriesForEmploymentAsync(row.EmploymentId, _selectedPeriodId);
        foreach (var entry in entries.Where(e => e.StatusCode is "SUBMITTED" or "CORRECTED"))
        {
            try
            {
                await TimeEntryService.ApproveTimeEntryAsync(
                    new ApproveTimeEntryCommand { TimeEntryId = entry.TimeEntryId, ApprovedBy = actorId });
            }
            catch (Exception ex) { _errorMsg = ex.Message; }
        }

        await RefreshDetailAsync(row.EmploymentId);
        await LoadPeriodAsync();
    }

    private void StartReject(Guid entryId)
    {
        _rejectEntryId = entryId;
        _rejectReason  = string.Empty;
    }

    private void CancelReject() { _rejectEntryId = null; _rejectReason = string.Empty; }

    private async Task ConfirmRejectAsync()
    {
        if (_rejectEntryId is null || string.IsNullOrWhiteSpace(_rejectReason)) return;

        var authState = await AuthState.GetAuthenticationStateAsync();
        var actorId   = GetActorId(authState);

        try
        {
            await TimeEntryService.RejectTimeEntryAsync(new RejectTimeEntryCommand
            {
                TimeEntryId = _rejectEntryId.Value,
                RejectedBy  = actorId,
                Reason      = _rejectReason
            });
            _rejectEntryId = null;
            _rejectReason  = string.Empty;
            if (_detailEmploymentId.HasValue)
                await RefreshDetailAsync(_detailEmploymentId.Value);
            await LoadPeriodAsync();
        }
        catch (Exception ex) { _errorMsg = ex.Message; }
    }

    private async Task RefreshDetailAsync(Guid employmentId)
    {
        _detailEntries = (await QueryService.GetEntriesForEmploymentAsync(
            employmentId, _selectedPeriodId)).ToList();
    }

    private static string TimecardStatus(TimecardSummaryRow row)
    {
        if (row.SubmittedCount > 0) return "PENDING";
        if (row.ApprovedCount > 0 && row.RejectedCount == 0) return "APPROVED";
        if (row.RejectedCount > 0) return "REJECTED";
        return "DRAFT";
    }

    private static Guid GetActorId(Microsoft.AspNetCore.Components.Authorization.AuthenticationState state)
    {
        var sub = state.User.FindFirst("sub")?.Value
               ?? state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(sub, out var g) ? g : Guid.Empty;
    }
}

<style>
    .detail-panel { padding: .75rem 1rem; border-top: 1px solid #e5e7eb; }
    .row-selected > td { background: #f5f3ff; }
    .text-right  { text-align: right; }
    .text-warn   { color: #d97706; font-weight: 600; }
    .stat-value--warn { color: #d97706; }

    .status-badge { padding:2px 8px;border-radius:999px;font-size:.75rem;font-weight:600; }
    .status-pending  { background:#fef9c3;color:#713f12; }
    .status-approved { background:#dcfce7;color:#14532d; }
    .status-rejected { background:#fee2e2;color:#7f1d1d; }
    .status-draft    { background:#f3f4f6;color:#6b7280; }
    .status-submitted { background:#dbeafe;color:#1e3a8a; }
    .status-locked   { background:#e0e7ff;color:#3730a3; }

    .cat-badge { padding:1px 6px;border-radius:4px;font-size:.75rem;font-weight:500;background:#f3f4f6;color:#374151; }
    .cat-overtime { background:#fef3c7;color:#92400e; }

    .ot-summary { display:flex;gap:.5rem;align-items:center;padding:.5rem 1rem;font-size:.85rem;color:#92400e;background:#fef3c7;border-radius:6px;margin-top:.5rem; }

    .data-table--inner { font-size:.85rem; }
    .data-table--inner th { padding:.4rem .75rem; }
    .data-table--inner td { padding:.4rem .75rem; }

    .btn-sm { padding:2px 10px;font-size:.8rem;border-radius:4px;cursor:pointer;border:1px solid transparent; }
    .btn-primary { background:var(--aw-blue,#2563eb);color:#fff;border-color:var(--aw-blue,#2563eb); }
    .btn-danger  { background:#ef4444;color:#fff;border-color:#ef4444; }
    .btn-ghost   { background:#f3f4f6;color:#374151;border-color:#e5e7eb; }
    .btn-link    { background:none;border:none;color:var(--aw-blue,#2563eb);cursor:pointer;font-size:.85rem;padding:0; }

    .alert-error { background:#fee2e2;color:#7f1d1d;padding:.75rem 1rem;border-radius:6px;font-size:.875rem; }
</style>
