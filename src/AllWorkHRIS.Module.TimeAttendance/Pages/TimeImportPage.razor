@page "/ta/import"
@layout TimeAttendanceShell
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "TimeAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Text
@using AllWorkHRIS.Module.TimeAttendance.Domain
@inject ITimeImportService        ImportService
@inject IHrisSessionState         SessionState
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime                JS

<PageTitle>Import Time Entries — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Import Time Entries</h2>
    </div>

    @* ── Format guide ────────────────────────────────────────────────── *@
    <div class="import-instructions" style="margin-bottom:1.5rem;">
        <h4 style="margin-bottom:.5rem;">CSV Format</h4>
        <p style="margin-bottom:.5rem;">One entry per row. Header row required. Columns may appear in any order:</p>
        <pre class="code-block" style="font-size:.8rem;overflow-x:auto;">employee_number, work_date, time_category, duration, start_time, end_time, payroll_period_id, project_code, task_code, notes</pre>

        <table class="data-table" style="margin-top:.875rem;font-size:.82rem;">
            <thead>
                <tr>
                    <th style="width:22%">Column</th>
                    <th style="width:15%">Required</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>employee_number</code></td>
                    <td>Yes</td>
                    <td>Must match an active employment record.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>work_date</code></td>
                    <td>Yes</td>
                    <td>Format: YYYY-MM-DD.</td>
                </tr>
                <tr>
                    <td><code>time_category</code></td>
                    <td>Yes</td>
                    <td><code>REGULAR</code>, <code>OVERTIME</code>, <code>PTO</code>, <code>SICK</code>, <code>HOLIDAY</code>, <code>BEREAVEMENT</code>, <code>JURY_DUTY</code>, <code>UNPAID</code>.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>duration</code></td>
                    <td>Yes</td>
                    <td>Positive decimal hours (e.g. <strong>8.00</strong> or <strong>7.5</strong>).</td>
                </tr>
                <tr>
                    <td><code>start_time</code></td>
                    <td>No</td>
                    <td>Format: HH:mm (24-hour). Omit for leave/absence entries.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>end_time</code></td>
                    <td>No</td>
                    <td>Format: HH:mm (24-hour). Must be after <code>start_time</code> when both supplied.</td>
                </tr>
                <tr>
                    <td><code>payroll_period_id</code></td>
                    <td>Yes</td>
                    <td>UUID of the target payroll period. Period must not be CLOSED.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>project_code</code></td>
                    <td>No</td>
                    <td>Free-form billing code; passed through as-is.</td>
                </tr>
                <tr>
                    <td><code>task_code</code></td>
                    <td>No</td>
                    <td>Free-form task code; passed through as-is.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>notes</code></td>
                    <td>No</td>
                    <td>Free-form notes attached to the entry.</td>
                </tr>
            </tbody>
        </table>
    </div>

    @* ── Upload ──────────────────────────────────────────────────────── *@
    @if (_step == Step.Upload)
    {
        <div class="form-panel">
            <h3 class="form-panel__title">Upload CSV</h3>

            <div class="form-group">
                <label class="form-label">CSV File <span class="required">*</span></label>
                <input type="file" id="ta-import-file" accept=".csv" class="form-input"
                       @key="_fileInputKey" @onchange="OnFileInputChange" />
            </div>

            @if (_fileError is not null)
            {
                <p class="form-error">@_fileError</p>
            }

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="RunImportAsync"
                        disabled="@(!_fileSelected || _importing)">
                    @(_importing ? "Importing…" : "Import")
                </button>
            </div>
        </div>
    }

    @* ── Results ─────────────────────────────────────────────────────── *@
    @if (_step == Step.Done && _result is not null)
    {
        <div class="import-provenance">
            <span class="import-provenance__file">@_fileName</span>
            @if (_importedAt.HasValue)
            {
                <span class="import-provenance__sep">—</span>
                <span class="import-provenance__time">Imported @_importedAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
            }
        </div>

        <div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
            <div class="stat-card stat-card--success">
                <div class="stat-value">@_result.Imported</div>
                <div class="stat-label">Imported</div>
            </div>
            <div class="stat-card @(_result.Failed > 0 ? "stat-card--danger" : "stat-card--success")">
                <div class="stat-value">@_result.Failed</div>
                <div class="stat-label">Failed</div>
            </div>
        </div>

        @if (_result.Errors.Count > 0)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
                <h4>Exception Queue — @_result.Errors.Count row@(_result.Errors.Count == 1 ? "" : "s") failed</h4>
                <button class="btn btn-ghost btn-sm" @onclick="DownloadErrorsAsync">
                    Download Errors as CSV
                </button>
            </div>
            <div style="max-height:420px;overflow-y:auto;border:1px solid var(--border-color, #e5e7eb);border-radius:6px;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:6rem;">Row #</th>
                            <th style="width:14rem;">Employee Number</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var err in _result.Errors)
                        {
                            <tr>
                                <td>@err.RowNumber</td>
                                <td><code>@err.EmployeeNumber</code></td>
                                <td>@err.Reason</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="form-actions" style="margin-top:1.25rem;">
            <button class="btn btn-ghost" @onclick="Reset">Import More</button>
        </div>
    }

</div>

@code {

    private enum Step { Upload, Done }

    private Step              _step         = Step.Upload;
    private int               _fileInputKey;
    private bool              _fileSelected;
    private string?           _fileError;
    private bool              _importing;
    private TimeImportResult? _result;
    private string?           _fileName;
    private DateTimeOffset?   _importedAt;

    private void OnFileInputChange(ChangeEventArgs e)
    {
        var raw       = e.Value?.ToString();
        _fileSelected = !string.IsNullOrEmpty(raw);
        _fileName     = _fileSelected ? Path.GetFileName(raw) : null;
        _fileError    = null;
        _result       = null;
        _step         = Step.Upload;
    }

    private async Task RunImportAsync()
    {
        _importing = true; _fileError = null;
        try
        {
            var base64 = await JS.InvokeAsync<string?>("allworkFiles.readBase64", "ta-import-file");
            if (string.IsNullOrEmpty(base64))
            { _fileError = "Could not read file. Please re-select and try again."; return; }

            var bytes = Convert.FromBase64String(base64);

            var auth = await AuthState.GetAuthenticationStateAsync();
            var empIdStr = auth.User.FindFirstValue("employment_id")
                        ?? auth.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            Guid.TryParse(empIdStr, out var importedBy);

            using var ms = new MemoryStream(bytes);
            _result     = await ImportService.ImportAsync(ms, importedBy, SessionState.SelectedLegalEntityId);
            _importedAt = DateTimeOffset.Now;
            _step       = Step.Done;
        }
        catch (Exception ex) { _fileError = ex.Message; }
        finally { _importing = false; }
    }

    private async Task DownloadErrorsAsync()
    {
        if (_result is null || _result.Errors.Count == 0) return;

        var sb = new StringBuilder();
        sb.AppendLine("row_number,employee_number,reason");
        foreach (var e in _result.Errors)
        {
            var escapedReason = e.Reason.Replace("\"", "\"\"");
            sb.AppendLine($"{e.RowNumber},{e.EmployeeNumber},\"{escapedReason}\"");
        }

        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("allworkFiles.downloadBase64", "ta-import-errors.csv", "text/csv", base64);
    }

    private void Reset()
    {
        _step         = Step.Upload;
        _fileInputKey++;
        _fileSelected = false;
        _result       = null;
        _fileError    = null;
        _fileName     = null;
        _importedAt   = null;
    }
}

<style>
    .import-provenance {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1.25rem;
        padding: .5rem .875rem;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: .8125rem;
        color: #4b5563;
    }

    .import-provenance__file {
        font-weight: 600;
        color: #111827;
        font-family: monospace;
    }

    .import-provenance__sep {
        color: #9ca3af;
    }

    .import-provenance__time {
        color: #6b7280;
    }
</style>
