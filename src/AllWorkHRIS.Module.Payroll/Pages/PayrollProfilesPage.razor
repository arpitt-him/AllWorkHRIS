@page "/payroll/profiles"
@layout PayrollShell
@rendermode InteractiveServer
@implements IDisposable
@attribute [Authorize(Roles = "PayrollAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayrollContextRepository   ContextRepo
@inject IPayrollProfileRepository   ProfileRepo
@inject IPersonNameLookup           PersonService
@inject IEmploymentLookup           EmploymentService
@inject IOrgUnitLookup              OrgService
@inject IHrisSessionState           SessionState
@inject ILookupCache                LookupCache
@inject ITemporalContext            TemporalContext
@inject AuthenticationStateProvider AuthState

<PageTitle>Payroll Profiles — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Payroll Profiles</h2>
        <button class="btn-primary" @onclick="ToggleEnrollFormAsync">+ Enroll Employee</button>
    </div>

    @* Stat cards *@
    <div class="stat-cards">
        <div class="stat-card">
            <span class="stat-label">Enrolled</span>
            <span class="stat-value">@_profiles.Count(p => p.EnrollmentStatus == "ACTIVE")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Final Pay Pending</span>
            <span class="stat-value">@_profiles.Count(p => p.EnrollmentStatus == "FINAL_PAY_PENDING")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Suspended</span>
            <span class="stat-value">@_profiles.Count(p => p.EnrollmentStatus == "SUSPENDED")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Terminated</span>
            <span class="stat-value">@_profiles.Count(p => p.EnrollmentStatus == "TERMINATED")</span>
        </div>
    </div>

    @* ── Bulk Enroll Form ─────────────────────────────────────── *@
    @if (_showEnrollForm)
    {
        <div class="panel-card" style="margin-bottom:1.5rem;">
            <h3 class="panel-title">Enroll Employees in Payroll</h3>

            @* Enrollment parameters *@
            <p class="form-section-label">Enrollment Settings</p>
            <div class="form-grid form-grid-3" style="margin-bottom:var(--space-5)">
                <div class="form-field">
                    <label class="form-label">Payroll Context <span style="color:var(--color-danger)">*</span></label>
                    <select class="form-control" value="@_enrollContextId"
                            @onchange="OnEnrollContextChangedAsync">
                        <option value="">— select —</option>
                        @foreach (var ctx in _contexts)
                        {
                            <option value="@ctx.PayrollContextId">@ctx.PayrollContextName</option>
                        }
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">Effective Start Date <span style="color:var(--color-danger)">*</span></label>
                    <input type="date" class="form-control" @bind="_enrollStartDate" />
                </div>
            </div>

            @* Employee filter + selection *@
            <p class="form-section-label">Filter Employees</p>
            <div class="form-grid form-grid-3" style="margin-bottom:var(--space-3)">
                <div class="form-field">
                    <label class="form-label">Division</label>
                    <select class="form-control" value="@_filterDivId"
                            @onchange="OnDivFilterChanged">
                        <option value="">All Divisions</option>
                        @foreach (var dv in _divisions)
                        {
                            <option value="@dv.OrgUnitId">@dv.OrgUnitName</option>
                        }
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">Department</label>
                    <select class="form-control" value="@_filterDeptId"
                            @onchange="OnDeptFilterChanged">
                        <option value="">All Departments</option>
                        @foreach (var d in _departments)
                        {
                            <option value="@d.OrgUnitId">@d.OrgUnitName</option>
                        }
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">Location</label>
                    <select class="form-control" value="@_filterLocId"
                            @onchange="OnLocFilterChanged">
                        <option value="">All Locations</option>
                        @foreach (var l in _locations)
                        {
                            <option value="@l.OrgUnitId">@l.OrgUnitName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="form-grid form-grid-2" style="margin-bottom:24px">
                <div class="form-field">
                    <label class="form-label">Rate Type</label>
                    <select class="form-control" value="@_filterRateTypeCode"
                            @onchange="OnRateTypeFilterChanged">
                        <option value="">All Rate Types</option>
                        @foreach (var rt in _rateTypes)
                        {
                            <option value="@rt.Code">@rt.Label</option>
                        }
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">Pay Frequency</label>
                    <select class="form-control" value="@_filterPayFreqCode"
                            @onchange="OnPayFreqFilterChanged">
                        <option value="">All Frequencies</option>
                        @foreach (var pf in _payFreqs)
                        {
                            <option value="@pf.Code">@pf.Label</option>
                        }
                    </select>
                </div>
            </div>

            @* Employee selection table *@
            @if (_enrollContextId == Guid.Empty)
            {
                <p class="empty-state">Select a payroll context to see unenrolled employees.</p>
            }
            else if (_filteredEmployees.Count == 0)
            {
                <p class="empty-state">No unenrolled employees match the selected filters.</p>
            }
            else
            {
                <div style="margin-bottom:12px;margin-top:32px;display:flex;align-items:center;gap:12px">
                    <label style="font-size:var(--font-size-sm);font-weight:var(--font-weight-medium);color:#374151">
                        @_selectedIds.Count of @_filteredEmployees.Count selected
                    </label>
                    <button class="btn-link" @onclick="SelectAll">Select All</button>
                    <button class="btn-link" @onclick="DeselectAll">Deselect All</button>
                </div>
                <div style="max-height:280px;overflow-y:auto;border:1px solid #E5E7EB;border-radius:var(--radius-md);margin-bottom:var(--space-4)">
                    <table class="data-table" style="margin:0">
                        <thead>
                            <tr>
                                <th style="width:2.5rem"></th>
                                <th>Name</th>
                                <th>Employee #</th>
                                <th>Division</th>
                                <th>Department</th>
                                <th>Location</th>
                                <th>Rate Type</th>
                                <th>Pay Frequency</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in _filteredEmployees)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox"
                                               checked="@_selectedIds.Contains(emp.EmploymentId)"
                                               @onchange="e => ToggleSelection(emp.EmploymentId, (bool)e.Value!)" />
                                    </td>
                                    <td>@emp.LegalLastName, @emp.LegalFirstName</td>
                                    <td style="font-family:monospace">@emp.EmployeeNumber</td>
                                    <td>@(emp.DivisionName ?? "—")</td>
                                    <td>@(emp.DepartmentName ?? "—")</td>
                                    <td>@(emp.LocationName ?? "—")</td>
                                    <td>@(emp.RateTypeCode ?? "—")</td>
                                    <td>@(emp.PayFrequencyCode ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (_enrollError is not null)
            {
                <div class="alert-error" style="margin-bottom:var(--space-3)">@_enrollError</div>
            }
            @if (_enrollSuccess is not null)
            {
                <div class="alert-info" style="margin-bottom:var(--space-3)">@_enrollSuccess</div>
            }
            <div class="form-actions">
                <button class="btn-primary" @onclick="EnrollSelectedAsync"
                        disabled="@(_submitting || _selectedIds.Count == 0)">
                    @(_submitting ? "Enrolling…" : $"Enroll Selected ({_selectedIds.Count})")
                </button>
                <button class="btn-secondary" @onclick="ToggleEnrollFormAsync">Cancel</button>
            </div>
        </div>
    }

    @if (_contexts.Count > 1)
    {
        <div class="filter-row">
            <label class="filter-label">Payroll Context</label>
            <select class="filter-select" value="@_selectedContextId" @onchange="OnContextChangedAsync">
                @foreach (var ctx in _contexts)
                {
                    <option value="@ctx.PayrollContextId">@ctx.PayrollContextName</option>
                }
            </select>
        </div>
    }

    @if (_loading)
    {
        <p class="loading-state">Loading…</p>
    }
    else if (_profiles.Count == 0)
    {
        <p class="empty-state">No payroll profiles found for this context.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Payroll Context</th>
                    <th>Enrollment Status</th>
                    <th>Source</th>
                    <th>Effective From</th>
                    <th>Effective To</th>
                    <th>Final Pay</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _profiles.OrderBy(p => GetName(p.EmploymentId)))
                {
                    <tr>
                        <td>
                            <a href="/hris/employees/@p.EmploymentId" class="table-link">@GetName(p.EmploymentId)</a>
                        </td>
                        <td>@GetContextName(p.PayrollContextId)</td>
                        <td><span class="badge @GetStatusClass(p.EnrollmentStatus)">@p.EnrollmentStatus</span></td>
                        <td>@p.EnrollmentSource</td>
                        <td>@p.EffectiveStartDate.ToString("yyyy-MM-dd")</td>
                        <td>@(p.EffectiveEndDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>@(p.FinalPayFlag ? "Yes" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@code {
    // ── Profile list state ────────────────────────────────────────
    private List<PayrollContext>      _contexts          = [];
    private List<PayrollProfile>      _profiles          = [];
    private Dictionary<Guid, string>  _names             = new();
    private Guid                      _selectedContextId;
    private bool                      _loading           = true;
    private Guid                      _currentUserId;

    // ── Enroll form state ─────────────────────────────────────────
    private bool                      _showEnrollForm;
    private bool                      _submitting;
    private Guid                      _enrollContextId;
    private DateOnly                  _enrollStartDate;
    private string?                   _enrollError;
    private string?                   _enrollSuccess;

    private List<EmploymentListItem>  _unenrolledEmployees = [];
    private List<EmploymentListItem>  _filteredEmployees   = [];
    private HashSet<Guid>             _selectedIds         = [];

    private List<OrgUnitOption>       _divisions           = [];
    private List<OrgUnitOption>       _departments         = [];
    private List<OrgUnitOption>       _locations           = [];
    private Guid                      _filterDivId;
    private Guid                      _filterDeptId;
    private Guid                      _filterLocId;
    private string                    _filterRateTypeCode  = "";
    private string                    _filterPayFreqCode   = "";
    private List<LookupEntry>         _rateTypes           = [];
    private List<LookupEntry>         _payFreqs            = [];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = Guid.TryParse(auth.User.FindFirst("sub")?.Value, out var g) ? g : Guid.Empty;

        SessionState.OnChanged += HandleEntityChanged;

        _enrollStartDate = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
        _rateTypes       = LookupCache.GetAll(LookupTables.CompensationRateType).OrderBy(e => e.Label).ToList();
        _payFreqs        = LookupCache.GetAll(LookupTables.PayFrequency).OrderBy(e => e.Label).ToList();

        await LoadForEntityAsync();
    }

    private void HandleEntityChanged()
        => InvokeAsync(async () => { await LoadForEntityAsync(); StateHasChanged(); });

    private async Task LoadForEntityAsync()
    {
        if (!SessionState.HasEntity) return;
        _contexts          = (await ContextRepo.GetByLegalEntityAsync(SessionState.SelectedLegalEntityId!.Value))
                                 .Where(c => c.ContextStatus == "ACTIVE").ToList();
        _selectedContextId = _contexts.FirstOrDefault()?.PayrollContextId ?? Guid.Empty;

        if (_showEnrollForm)
        {
            _enrollContextId    = _selectedContextId;
            _filterDivId        = Guid.Empty;
            _filterDeptId       = Guid.Empty;
            _filterLocId        = Guid.Empty;
            _filterRateTypeCode = "";
            _filterPayFreqCode  = "";
            _selectedIds        = [];
            await LoadUnenrolledAsync(_enrollContextId);
        }

        await LoadProfilesAsync();
    }

    public void Dispose()
        => SessionState.OnChanged -= HandleEntityChanged;

    // ── Enroll form open/close ────────────────────────────────────

    private async Task ToggleEnrollFormAsync()
    {
        _showEnrollForm = !_showEnrollForm;
        _enrollError    = null;
        _enrollSuccess  = null;

        if (_showEnrollForm)
        {
            _enrollContextId     = _selectedContextId;
            _enrollStartDate     = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
            _filterDivId         = Guid.Empty;
            _filterDeptId        = Guid.Empty;
            _filterLocId         = Guid.Empty;
            _filterRateTypeCode  = "";
            _filterPayFreqCode   = "";
            _selectedIds         = [];

            var entityId = SessionState.SelectedLegalEntityId;
            var divs  = await OrgService.GetDivisionsAsync(entityId);
            var depts = await OrgService.GetDepartmentsAsync(entityId);
            var locs  = await OrgService.GetLocationsAsync(entityId);
            _divisions   = divs.OrderBy(d => d.OrgUnitName).ToList();
            _departments = depts.OrderBy(d => d.OrgUnitName).ToList();
            _locations   = locs.OrderBy(l => l.OrgUnitName).ToList();

            await LoadUnenrolledAsync(_enrollContextId);
        }
        else
        {
            _unenrolledEmployees = [];
            _filteredEmployees   = [];
            _divisions           = [];
            _departments         = [];
            _locations           = [];
        }
    }

    private async Task LoadUnenrolledAsync(Guid contextId)
    {
        if (contextId == Guid.Empty) { _unenrolledEmployees = []; _filteredEmployees = []; return; }

        var all      = await EmploymentService.GetAllActiveListAsync(SessionState.SelectedLegalEntityId);
        var enrolled = (await ProfileRepo.GetActiveEmploymentIdsByContextAsync(contextId)).ToHashSet();
        _unenrolledEmployees = all.Where(e => !enrolled.Contains(e.EmploymentId))
                                  .OrderBy(e => e.LegalLastName).ThenBy(e => e.LegalFirstName)
                                  .ToList();
        ApplyFilters();
    }

    private void OnDivFilterChanged(ChangeEventArgs e)
    {
        _filterDivId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        ApplyFilters();
    }

    private void OnDeptFilterChanged(ChangeEventArgs e)
    {
        _filterDeptId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        ApplyFilters();
    }

    private void OnLocFilterChanged(ChangeEventArgs e)
    {
        _filterLocId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        ApplyFilters();
    }

    private void OnRateTypeFilterChanged(ChangeEventArgs e)
    {
        _filterRateTypeCode = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnPayFreqFilterChanged(ChangeEventArgs e)
    {
        _filterPayFreqCode = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filteredEmployees = _unenrolledEmployees
            .Where(e => _filterDivId         == Guid.Empty || e.DivisionId      == _filterDivId)
            .Where(e => _filterDeptId        == Guid.Empty || e.DepartmentId    == _filterDeptId)
            .Where(e => _filterLocId         == Guid.Empty || e.LocationId      == _filterLocId)
            .Where(e => _filterRateTypeCode  == ""         || e.RateTypeCode    == _filterRateTypeCode)
            .Where(e => _filterPayFreqCode   == ""         || e.PayFrequencyCode == _filterPayFreqCode)
            .ToList();

        // Drop any selections no longer in view
        var visibleIds = _filteredEmployees.Select(e => e.EmploymentId).ToHashSet();
        _selectedIds.IntersectWith(visibleIds);
    }

    private async Task OnEnrollContextChangedAsync(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _enrollContextId = id;
            _selectedIds     = [];
            await LoadUnenrolledAsync(id);
        }
    }

    // ── Selection helpers ─────────────────────────────────────────

    private void SelectAll()   => _selectedIds = _filteredEmployees.Select(e => e.EmploymentId).ToHashSet();
    private void DeselectAll() => _selectedIds = [];

    private void ToggleSelection(Guid employmentId, bool selected)
    {
        if (selected) _selectedIds.Add(employmentId);
        else          _selectedIds.Remove(employmentId);
    }

    // ── Bulk enroll ───────────────────────────────────────────────

    private async Task EnrollSelectedAsync()
    {
        _enrollError   = null;
        _enrollSuccess = null;

        if (_enrollContextId == Guid.Empty) { _enrollError = "Select a payroll context."; return; }
        if (_selectedIds.Count == 0)        { _enrollError = "Select at least one employee."; return; }

        _submitting = true;
        int enrolled = 0;
        try
        {
            var toEnroll = _filteredEmployees.Where(e => _selectedIds.Contains(e.EmploymentId)).ToList();
            var now      = DateTimeOffset.UtcNow;

            foreach (var emp in toEnroll)
            {
                var profile = new PayrollProfile
                {
                    PayrollProfileId    = Guid.NewGuid(),
                    EmploymentId        = emp.EmploymentId,
                    PersonId            = emp.PersonId,
                    PayrollContextId    = _enrollContextId,
                    EnrollmentStatus    = "ACTIVE",
                    EffectiveStartDate  = _enrollStartDate,
                    EffectiveEndDate    = null,
                    FinalPayFlag        = false,
                    BlockingTasksCleared = true,
                    EnrollmentSource    = "MANUAL",
                    CreatedBy           = _currentUserId,
                    CreationTimestamp   = now,
                    LastUpdatedBy       = _currentUserId,
                    LastUpdateTimestamp = now
                };
                await ProfileRepo.InsertAsync(profile);
                enrolled++;
            }

            _enrollSuccess = $"{enrolled} employee{(enrolled == 1 ? "" : "s")} enrolled successfully.";
            _selectedIds   = [];

            // Remove newly-enrolled from the unenrolled list and re-filter
            var enrolledIds = toEnroll.Select(e => e.EmploymentId).ToHashSet();
            _unenrolledEmployees.RemoveAll(e => enrolledIds.Contains(e.EmploymentId));
            ApplyFilters();

            await LoadProfilesAsync();
        }
        catch (Exception ex) { _enrollError = ex.Message; }
        finally { _submitting = false; }
    }

    // ── Profile list ──────────────────────────────────────────────

    private async Task LoadProfilesAsync()
    {
        if (_selectedContextId == Guid.Empty) { _profiles = []; _loading = false; return; }
        _loading  = true;
        _profiles = (await ProfileRepo.GetByContextAsync(_selectedContextId)).ToList();

        if (_profiles.Count > 0)
            _names = await PersonService.GetNamesByEmploymentIdsAsync(_profiles.Select(p => p.EmploymentId));

        _loading = false;
    }

    private async Task OnContextChangedAsync(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedContextId = id;
            await LoadProfilesAsync();
        }
    }

    private string GetName(Guid employmentId)
        => _names.TryGetValue(employmentId, out var n) ? n : employmentId.ToString()[..8];

    private string GetContextName(Guid contextId)
        => _contexts.FirstOrDefault(c => c.PayrollContextId == contextId)?.PayrollContextName ?? contextId.ToString()[..8];

    private static string GetStatusClass(string status) => status switch
    {
        "ACTIVE"             => "badge-success",
        "FINAL_PAY_PENDING"  => "badge-warning",
        "SUSPENDED"          => "badge-info",
        "TERMINATED"         => "badge-neutral",
        _                    => "badge-neutral"
    };
}
