@page "/payroll/runs"
@layout PayrollShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "PayrollOperator,PayrollAdmin")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@inject IPayrollRunService          RunService
@inject IPayrollContextRepository   ContextRepo
@inject IHrisSessionState           SessionState
@inject ITemporalContext            TemporalContext
@inject IRunProgressNotifier        ProgressNotifier
@inject NavigationManager           Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Payroll Runs — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Payroll Runs</h2>
        <AuthorizeView Roles="PayrollAdmin">
            <Authorized>
                <button class="btn-primary" @onclick="ToggleNewRunForm">+ New Run</button>
            </Authorized>
        </AuthorizeView>
    </div>

    @* Stat Cards *@
    <div class="stat-cards">
        <div class="stat-card stat-card--open-runs">
            <span class="stat-label">Open Runs</span>
            <span class="stat-value">@_openRunCount</span>
        </div>
        <div class="stat-card stat-card--pending">
            <span class="stat-label">Pending Approval</span>
            <span class="stat-value">@_pendingApprovalCount</span>
        </div>
        <div class="stat-card stat-card--last-pay">
            <span class="stat-label">Last Pay Date</span>
            <span class="stat-value">@(_lastReleasedDate?.ToString("yyyy-MM-dd") ?? "—")</span>
        </div>
        <div class="stat-card stat-card--next-pay">
            <span class="stat-label">Next Open Pay Date</span>
            <span class="stat-value">@(_nextPayDate?.ToString("yyyy-MM-dd") ?? "—")</span>
        </div>
    </div>

    <div class="filter-row">
        @if (_contexts.Count > 1)
        {
            <label class="filter-label">Payroll Context</label>
            <SfDropDownList TValue="Guid" TItem="PayrollContext"
                            DataSource="@_contexts"
                            @bind-Value="_selectedContextId"
                            Width="200px">
                <DropDownListFieldSettings Value="PayrollContextId" Text="PayrollContextName" />
                <DropDownListEvents TValue="Guid" TItem="PayrollContext"
                                    ValueChange="OnContextChangedAsync" />
            </SfDropDownList>
        }
        <label class="filter-label">Status</label>
        <SfDropDownList TValue="string" TItem="FilterOption"
                        DataSource="@_statusOptions"
                        @bind-Value="_statusFilter"
                        Width="160px">
            <DropDownListFieldSettings Value="Value" Text="Label" />
        </SfDropDownList>
    </div>

    @* New Run Form *@
    @if (_showNewRunForm)
    {
        <div class="panel-card" style="margin-bottom:1.5rem;">
            <h3 class="panel-title">Initiate Payroll Run</h3>
            <div class="form-grid form-grid-4">
                <div class="form-field">
                    <label class="form-label">Payroll Context</label>
                    <SfDropDownList TValue="Guid" TItem="PayrollContext"
                                    DataSource="@_contexts"
                                    @bind-Value="_newRun.ContextId"
                                    Width="100%">
                        <DropDownListFieldSettings Value="PayrollContextId" Text="PayrollContextName" />
                        <DropDownListEvents TValue="Guid" TItem="PayrollContext"
                                            ValueChange="OnNewRunContextChangedAsync" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Pay Period</label>
                    <SfDropDownList TValue="Guid" TItem="PeriodOption"
                                    DataSource="@PeriodOptions"
                                    @bind-Value="_newRun.PeriodId"
                                    Width="100%"
                                    Placeholder="— select —">
                        <DropDownListFieldSettings Value="PeriodId" Text="PeriodLabel" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Run Type</label>
                    <SfDropDownList TValue="int" TItem="IntOption"
                                    DataSource="@_runTypeOptions"
                                    @bind-Value="_newRun.RunTypeId"
                                    Width="100%">
                        <DropDownListFieldSettings Value="Value" Text="Label" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Description (optional)</label>
                    <SfTextBox @bind-Value="_newRun.Description"
                               Placeholder="e.g. April Biweekly" />
                </div>
            </div>
            @if (_newRunError is not null)
            {
                <div class="alert-error">@_newRunError</div>
            }
            @if (_confirmEarlyRun)
            {
                <div class="early-run-confirm">
                    <p class="early-run-confirm__msg">
                        The pay date for this period is <strong>@_selectedPeriod!.PayDate.ToString("yyyy-MM-dd")</strong>,
                        which has not yet been reached. Payroll runs are sometimes initiated early to allow
                        time for ACH processing, but please confirm this is intentional before proceeding.
                    </p>
                    <div class="early-run-confirm__actions">
                        <button class="btn-primary" @onclick="ConfirmEarlyRunAsync" disabled="@_submitting">
                            @(_submitting ? "Initiating…" : "Yes, initiate early")
                        </button>
                        <button class="btn-secondary" @onclick="CancelEarlyRun">Go back</button>
                    </div>
                </div>
            }
            else
            {
                <div class="form-actions">
                    <button class="btn-primary" @onclick="InitiateRunAsync" disabled="@_submitting">
                        @(_submitting ? "Initiating…" : "Initiate Run")
                    </button>
                    <button class="btn-secondary" @onclick="ToggleNewRunForm">Cancel</button>
                </div>
            }
        </div>
    }

    @if (_errorMessage is not null)
    {
        <div class="alert-error" style="margin-bottom:1rem;">@_errorMessage</div>
    }

    @* Run list *@
    @if (_loading)
    {
        <p class="loading-state">Loading…</p>
    }
    else if (_filteredRuns.Count == 0)
    {
        <p class="empty-state">No payroll runs match the selected filter.</p>
    }
    else
    {
        <SfGrid DataSource="@_filteredRuns.OrderByDescending(r => r.CreationTimestamp).ToList()"
                AllowSorting="true" AllowPaging="true" CssClass="e-gridhover">
            <GridPageSettings PageSize="25" />
            <GridColumns>
                <GridColumn Field="RunDescription" HeaderText="Description" Width="220">
                    <Template>
                        @{ var run = (PayrollRun)context; }
                        <a href="/payroll/runs/@run.RunId" class="table-link">
                            @(run.RunDescription ?? $"Run {run.RunId.ToString()[..8].ToUpper()}")
                        </a>
                    </Template>
                </GridColumn>
                <GridColumn Field="PeriodId" HeaderText="Period" Width="180">
                    <Template>
                        @{ var run = (PayrollRun)context; }
                        @GetPeriodLabel(run.PeriodId)
                    </Template>
                </GridColumn>
                <GridColumn Field="PayDate" HeaderText="Pay Date" Width="120" Format="MM/dd/yyyy" />
                <GridColumn Field="RunTypeId" HeaderText="Type" Width="130">
                    <Template>
                        @{ var run = (PayrollRun)context; }
                        <span class="badge badge-neutral">@GetRunTypeLabel(run.RunTypeId)</span>
                    </Template>
                </GridColumn>
                <GridColumn Field="RunStatusId" HeaderText="Status" Width="180">
                    <Template>
                        @{
                            var run = (PayrollRun)context;
                            var progress = ProgressNotifier.GetProgress(run.RunId);
                        }
                        <span class="badge @GetStatusBadgeClass(run.RunStatusId)">
                            @GetStatusLabel(run.RunStatusId)
                        </span>
                        @if (run.RunStatusId == 3 && progress is not null)
                        {
                            <div class="progress-mini">
                                <div class="progress-bar-track">
                                    <div class="progress-bar-fill" style="width:@progress.PercentComplete%"></div>
                                </div>
                                <span class="progress-text">@progress.Processed/@progress.Total</span>
                            </div>
                        }
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="Actions" Width="160" TextAlign="TextAlign.Right">
                    <Template>
                        @{ var run = (PayrollRun)context; }
                        <div class="action-cell">
                            <a href="/payroll/runs/@run.RunId" class="btn-link">View</a>
                            @if (run.RunStatusId == 4)
                            {
                                <AuthorizeView Roles="PayrollAdmin" Context="auth">
                                    <Authorized>
                                        <button class="btn-link" @onclick="() => ApproveRunAsync(run.RunId)">Approve</button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            @if (run.RunStatusId is 1 or 4)
                            {
                                <AuthorizeView Roles="PayrollAdmin" Context="auth">
                                    <Authorized>
                                        <button class="btn-link btn-danger" @onclick="() => CancelRunAsync(run.RunId)">Cancel</button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                        </div>
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>
    }

</div>

<style>
    .stat-card--open-runs { border-top: 4px solid var(--module-payroll); }
    .stat-card--pending   { border-top: 4px solid var(--color-warning); }
    .stat-card--last-pay  { border-top: 4px solid var(--color-success); }
    .stat-card--next-pay  { border-top: 4px solid var(--aw-teal); }
</style>

@code {
    private List<PayrollContext>             _allContexts   = [];
    private List<PayrollContext>             _contexts      = [];
    private Guid                             _selectedContextId;
    private List<PayrollRun>                 _runs          = [];
    private Dictionary<Guid, PayrollPeriod>  _periods       = new();
    private List<PayrollPeriod>              _openPeriods   = [];
    private bool                             _loading       = true;
    private bool                             _showNewRunForm;
    private bool                             _confirmEarlyRun;
    private PayrollPeriod?                   _selectedPeriod;
    private bool                             _submitting;
    private string?                          _newRunError;
    private string?                          _errorMessage;
    private NewRunFormModel                  _newRun        = new();
    private PeriodicTimer?                   _pollTimer;
    private CancellationTokenSource?         _pollCts;
    private Guid                             _currentUserId;
    private string                           _statusFilter  = "ACTIVE";

    private record FilterOption(string Value, string Label);
    private static readonly List<FilterOption> _statusOptions =
    [
        new("ACTIVE",    "Active"),
        new("ALL",       "All"),
        new("RELEASED",  "Released"),
        new("CANCELLED", "Cancelled"),
        new("FAILED",    "Failed"),
    ];

    private record IntOption(int Value, string Label);
    private static readonly List<IntOption> _runTypeOptions =
    [
        new(1, "Regular"),
        new(2, "Supplemental"),
        new(3, "Adjustment"),
        new(4, "Correction"),
    ];

    private record PeriodOption(Guid PeriodId, string PeriodLabel);
    private List<PeriodOption> PeriodOptions => _openPeriods
        .Select(p => new PeriodOption(p.PeriodId,
            $"{p.PeriodYear} P{p.PeriodNumber} ({p.PeriodStartDate:MM/dd}–{p.PeriodEndDate:MM/dd}, pay {p.PayDate:MM/dd/yyyy})"))
        .ToList();

    // Terminal statuses excluded from the "Active" filter view
    private static readonly HashSet<int> TerminalStatuses = [8, 9, 10, 11]; // Released, Closed, Failed, Cancelled

    private List<PayrollRun> _filteredRuns => _statusFilter switch
    {
        "ACTIVE"    => _runs.Where(r => !TerminalStatuses.Contains(r.RunStatusId)).ToList(),
        "RELEASED"  => _runs.Where(r => r.RunStatusId == 8).ToList(),
        "CANCELLED" => _runs.Where(r => r.RunStatusId == 11).ToList(),
        "FAILED"    => _runs.Where(r => r.RunStatusId == 10).ToList(),
        _           => _runs
    };

    private int       _openRunCount         => _runs.Count(r => r.RunStatusId is >= 1 and <= 7);
    private int       _pendingApprovalCount => _runs.Count(r => r.RunStatusId == 4);
    private DateOnly? _lastReleasedDate     => _runs.Where(r => r.RunStatusId == 8)
                                                    .Select(r => (DateOnly?)r.PayDate)
                                                    .DefaultIfEmpty(null).Max();
    private DateOnly? _nextPayDate          => _openPeriods.Select(p => (DateOnly?)p.PayDate)
                                                           .Where(d => d >= DateOnly.FromDateTime(TemporalContext.GetOperativeDate()))
                                                           .DefaultIfEmpty(null).Min();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = Guid.TryParse(auth.User.FindFirst("sub")?.Value, out var g) ? g : Guid.Empty;

        SessionState.OnChanged += HandleEntityChanged;
        _allContexts = (await ContextRepo.GetAllActiveAsync()).ToList();
        await LoadForEntityAsync();
    }

    private void HandleEntityChanged()
        => InvokeAsync(async () => { await LoadForEntityAsync(); StateHasChanged(); });

    private async Task LoadForEntityAsync()
    {
        if (!SessionState.HasEntity) return;

        _contexts          = _allContexts.Where(c => c.LegalEntityId == SessionState.SelectedLegalEntityId).ToList();
        _selectedContextId = _contexts.FirstOrDefault()?.PayrollContextId ?? Guid.Empty;

        await LoadRunsAsync();

        if (_selectedContextId != Guid.Empty)
            _openPeriods = (await ContextRepo.GetOpenPeriodsAsync(_selectedContextId)).ToList();

        if (_runs.Any(r => r.RunStatusId == 3))
            StartPolling();

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadRunsAsync()
    {
        if (_selectedContextId == Guid.Empty) { _loading = false; return; }
        _loading = true;

        var runs = await RunService.GetRunsByContextAsync(_selectedContextId);
        _runs = [.. runs];

        var operativeYear    = TemporalContext.GetOperativeDate().Year;
        var yearPeriods      = await ContextRepo.GetPeriodsByContextAsync(_selectedContextId, operativeYear);
        var prevYearPeriods  = await ContextRepo.GetPeriodsByContextAsync(_selectedContextId, operativeYear - 1);
        _periods = yearPeriods.Concat(prevYearPeriods).ToDictionary(p => p.PeriodId);

        _loading = false;
    }

    private async Task OnContextChangedAsync(ChangeEventArgs<Guid, PayrollContext> args)
    {
        _selectedContextId = args.Value;
        await LoadRunsAsync();
        _openPeriods = (await ContextRepo.GetOpenPeriodsAsync(_selectedContextId)).ToList();
    }

    private async Task OnNewRunContextChangedAsync(ChangeEventArgs<Guid, PayrollContext> args)
    {
        _newRun.ContextId = args.Value;
        _newRun.PeriodId  = Guid.Empty;
        _openPeriods = (await ContextRepo.GetOpenPeriodsAsync(args.Value)).ToList();
    }

    private void ToggleNewRunForm()
    {
        _showNewRunForm  = !_showNewRunForm;
        _newRunError     = null;
        _confirmEarlyRun = false;
        _selectedPeriod  = null;
        if (_showNewRunForm)
            _newRun = new NewRunFormModel { ContextId = _selectedContextId, RunTypeId = 1 };
    }

    private async Task InitiateRunAsync()
    {
        if (_newRun.ContextId == Guid.Empty || _newRun.PeriodId == Guid.Empty)
        {
            _newRunError = "Payroll context and period are required.";
            return;
        }

        _selectedPeriod = _openPeriods.FirstOrDefault(p => p.PeriodId == _newRun.PeriodId);
        if (_selectedPeriod is not null)
        {
            var today         = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
            var runThreshold  = _selectedPeriod.CalculationDate ?? _selectedPeriod.PayDate;
            if (today < runThreshold)
            {
                _confirmEarlyRun = true;
                _newRunError     = null;
                return;
            }
        }

        await SubmitRunAsync();
    }

    private async Task ConfirmEarlyRunAsync()
    {
        _confirmEarlyRun = false;
        await SubmitRunAsync();
    }

    private void CancelEarlyRun()
    {
        _confirmEarlyRun = false;
        _selectedPeriod  = null;
    }

    private async Task SubmitRunAsync()
    {
        _submitting  = true;
        _newRunError = null;
        try
        {
            await RunService.InitiateRunAsync(new InitiatePayrollRunCommand
            {
                PayrollContextId = _newRun.ContextId,
                PeriodId         = _newRun.PeriodId,
                RunTypeId        = _newRun.RunTypeId,
                RunDescription   = string.IsNullOrWhiteSpace(_newRun.Description) ? null : _newRun.Description,
                InitiatedBy      = _currentUserId,
                ParentRunId      = null
            });
            _showNewRunForm = false;
            await LoadRunsAsync();
            StartPolling();
        }
        catch (InvalidOperationException ex) { _newRunError = ex.Message; }
        finally { _submitting = false; }
    }

    private async Task ApproveRunAsync(Guid runId)
    {
        _errorMessage = null;
        try
        {
            await RunService.ApproveRunAsync(new ApprovePayrollRunCommand
                { RunId = runId, ApprovedBy = _currentUserId });
            await LoadRunsAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task CancelRunAsync(Guid runId)
    {
        _errorMessage = null;
        try
        {
            await RunService.CancelRunAsync(new CancelPayrollRunCommand
                { RunId = runId, CancelledBy = _currentUserId, Reason = "Cancelled by operator" });
            await LoadRunsAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private void StartPolling()
    {
        if (_pollCts is not null) return;
        _pollCts = new CancellationTokenSource();
        _ = PollAsync(_pollCts.Token);
    }

    private async Task PollAsync(CancellationToken ct)
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(ct))
            {
                await LoadRunsAsync();
                await InvokeAsync(StateHasChanged);
                if (!_runs.Any(r => r.RunStatusId == 3))
                {
                    _pollCts?.Cancel();
                    break;
                }
            }
        }
        catch (OperationCanceledException) { }
        finally { _pollTimer?.Dispose(); _pollTimer = null; }
    }

    public void Dispose()
    {
        SessionState.OnChanged -= HandleEntityChanged;
        _pollCts?.Cancel();
        _pollTimer?.Dispose();
    }

    private string GetPeriodLabel(Guid periodId) =>
        _periods.TryGetValue(periodId, out var p)
            ? $"{p.PeriodYear} P{p.PeriodNumber} ({p.PeriodStartDate:MM/dd}–{p.PeriodEndDate:MM/dd})"
            : periodId.ToString()[..8];

    private static string GetRunTypeLabel(int id) => id switch
    {
        1 => "Regular",   2 => "Supplemental", 3 => "Adjustment",
        4 => "Correction", 5 => "Reprocessing", 6 => "Simulation",
        _ => id.ToString()
    };

    private static string GetStatusLabel(int id) => id switch
    {
        1 => "Draft",       2 => "Open",         3 => "Calculating",
        4 => "Calculated",  5 => "Under Review",  6 => "Approved",
        7 => "Releasing",   8 => "Released",      9 => "Closed",
        10 => "Failed",     11 => "Cancelled",
        _  => id.ToString()
    };

    private static string GetStatusBadgeClass(int id) => id switch
    {
        3 or 7  => "badge-info",
        4 or 6  => "badge-teal",
        8       => "badge-success",
        5       => "badge-warning",
        10      => "badge-error",
        _       => "badge-neutral"
    };

    private sealed class NewRunFormModel
    {
        public Guid   ContextId   { get; set; }
        public Guid   PeriodId    { get; set; }
        public int    RunTypeId   { get; set; } = 1;
        public string Description { get; set; } = "";
    }
}
