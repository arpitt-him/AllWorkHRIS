@page "/payroll/calendar"
@layout PayrollShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "PayrollAdmin")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Calendars
@inject IPayrollContextRepository   ContextRepo
@inject IHrisSessionState           SessionState
@inject ILookupCache                LookupCache
@inject AuthenticationStateProvider AuthState
@inject NavigationManager           Nav
@inject ITemporalContext            TemporalContext

<PageTitle>Pay Calendars — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Pay Calendars</h2>
        <button class="btn-primary" @onclick="ToggleNewContextForm">+ New Context</button>
    </div>

    <div class="stat-cards">
        <div class="stat-card stat-card--total">
            <span class="stat-label">Total Contexts</span>
            <span class="stat-value">@_filtered.Count</span>
        </div>
        <div class="stat-card stat-card--active">
            <span class="stat-label">Active</span>
            <span class="stat-value">@_filtered.Count(c => c.ContextStatus == "ACTIVE")</span>
        </div>
        <div class="stat-card stat-card--inactive">
            <span class="stat-label">Inactive</span>
            <span class="stat-value">@_filtered.Count(c => c.ContextStatus == "INACTIVE")</span>
        </div>
        <div class="stat-card stat-card--closed">
            <span class="stat-label">Closed</span>
            <span class="stat-value">@_filtered.Count(c => c.ContextStatus == "CLOSED")</span>
        </div>
    </div>

    @* ── New Context Form ──────────────────────────────────────── *@
    @if (_showNewContextForm)
    {
        <div class="panel-card" style="margin-bottom:1.5rem;">
            <h3 class="panel-title">Create Payroll Context</h3>
            <div class="form-grid form-grid-3">
                <div class="form-field">
                    <label class="form-label">Context Code <span style="color:var(--color-danger)">*</span></label>
                    <SfTextBox @bind-Value="_newCtx.Code" Placeholder="e.g. CORP-BW" />
                </div>
                <div class="form-field" style="grid-column:span 2">
                    <label class="form-label">Context Name <span style="color:var(--color-danger)">*</span></label>
                    <SfTextBox @bind-Value="_newCtx.Name" Placeholder="e.g. Corporate Biweekly" />
                </div>
                <div class="form-field">
                    <label class="form-label">Rate Type <span style="color:var(--color-danger)">*</span></label>
                    <SfDropDownList TValue="int" TItem="LookupEntry"
                                    DataSource="@_rateTypes"
                                    @bind-Value="_newCtx.RateTypeId"
                                    Placeholder="— select —" Width="100%">
                        <DropDownListFieldSettings Value="Id" Text="Label" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Pay Frequency <span style="color:var(--color-danger)">*</span></label>
                    <SfDropDownList TValue="int" TItem="LookupEntry"
                                    DataSource="@_frequencies"
                                    @bind-Value="_newCtx.PayFrequencyId"
                                    Placeholder="— select —" Width="100%">
                        <DropDownListFieldSettings Value="Id" Text="Label" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Effective Start Date <span style="color:var(--color-danger)">*</span></label>
                    <SfDatePicker TValue="DateOnly" @bind-Value="_newCtx.EffectiveStartDate"
                                  Placeholder="MM/DD/YYYY" Width="100%" />
                </div>
            </div>

            @* ── Convention / Offset (driven by selected frequency) ── *@
            @{
                var newFreqCode = _frequencies.FirstOrDefault(f => f.Id == _newCtx.PayFrequencyId)?.Code ?? "";
            }
            @if (newFreqCode == "MONTHLY")
            {
                <p class="form-section-label">Pay Date Convention</p>
                <div style="display:flex;flex-direction:column;gap:var(--space-2);margin-bottom:var(--space-4)">
                    @foreach (var (convCode, label, hint) in _monthlyConventions)
                    {
                        var cc = convCode;
                        <label style="display:flex;align-items:baseline;gap:var(--space-2);cursor:pointer;font-size:var(--font-size-sm)">
                            <input type="radio" name="new-monthly-convention" value="@cc"
                                   checked="@(_newCtx.PayDateConvention == cc)"
                                   @onchange="() => _newCtx.PayDateConvention = cc" />
                            <span><strong>@label</strong></span>
                            <span style="color:#6B7280">— @hint</span>
                        </label>
                    }
                </div>
            }
            @if (newFreqCode == "SEMI_MONTHLY")
            {
                <p class="form-section-label">Pay Date Convention</p>
                <div style="display:flex;flex-direction:column;gap:var(--space-2);margin-bottom:var(--space-4)">
                    @foreach (var (convCode, label, hint) in _semiMonthlyConventions)
                    {
                        var cc = convCode;
                        <label style="display:flex;align-items:baseline;gap:var(--space-2);cursor:pointer;font-size:var(--font-size-sm)">
                            <input type="radio" name="new-sm-convention" value="@cc"
                                   checked="@(_newCtx.PayDateConvention == cc)"
                                   @onchange="() => _newCtx.PayDateConvention = cc" />
                            <span><strong>@label</strong></span>
                            <span style="color:#6B7280">— @hint</span>
                        </label>
                    }
                </div>
            }
            @if (_newCtx.PayFrequencyId > 0)
            {
                <div class="form-grid form-grid-3" style="margin-bottom:var(--space-4)">
                    @if (newFreqCode is "WEEKLY" or "BIWEEKLY" or "QUARTERLY" or "ANNUAL")
                    {
                        <div class="form-field">
                            <label class="form-label">Pay Date Offset (days after period end)</label>
                            <SfNumericTextBox TValue="int" @bind-Value="_newCtx.PayDateOffsetDays" Min="1" Max="30" Width="100%" />
                        </div>
                    }
                    <div class="form-field">
                        <label class="form-label">Input Cutoff (days before pay date)</label>
                        <SfNumericTextBox TValue="int" @bind-Value="_newCtx.CutoffOffsetDays" Min="1" Max="30" Width="100%" />
                    </div>
                    @if (newFreqCode is "WEEKLY" or "BIWEEKLY")
                    {
                        <div class="form-field">
                            <label class="form-label">53rd/27th Period Policy</label>
                            <SfDropDownList TValue="string" TItem="FilterOption"
                                            DataSource="@_extraPeriodOptions"
                                            @bind-Value="_newCtx.ExtraPeriodPolicy"
                                            Width="100%">
                                <DropDownListFieldSettings Value="Value" Text="Label" />
                            </SfDropDownList>
                        </div>
                    }
                    <div class="form-field">
                        <label class="form-label">OT Weekly Threshold (hrs)</label>
                        <SfNumericTextBox TValue="decimal" @bind-Value="_newCtx.OtWeeklyThresholdHours"
                                         Min="1" Max="168" Step="0.5m" Width="100%" />
                        <span style="font-size:var(--font-size-sm);color:#6B7280">
                            FLSA standard is 40.00. Override only if this payroll group has a lower company-configured threshold than the legal entity default.
                        </span>
                    </div>
                    <div class="form-field">
                        <label class="form-label">Workweek Start Day</label>
                        <SfDropDownList TValue="int" TItem="IntOption"
                                        DataSource="@_weekdayOptions"
                                        @bind-Value="_newCtx.WorkweekStartDay"
                                        Width="100%">
                            <DropDownListFieldSettings Value="Value" Text="Label" />
                        </SfDropDownList>
                        <span style="font-size:var(--font-size-sm);color:#6B7280">
                            Pre-populated from the legal entity default. FLSA workweek anchor — every non-exempt employee in this group uses this day.
                        </span>
                    </div>
                </div>
            }

            @if (_contextError is not null)
            {
                <div class="alert-error" style="margin-bottom:var(--space-3)">@_contextError</div>
            }
            <div class="form-actions">
                <button class="btn-primary" @onclick="CreateContextAsync" disabled="@_submitting">
                    @(_submitting ? "Creating…" : "Create Context")
                </button>
                <button class="btn-secondary" @onclick="ToggleNewContextForm">Cancel</button>
            </div>
        </div>
    }

    @* ── Status filter ─────────────────────────────────────────── *@
    @if (_filtered.Count > 0)
    {
        <div class="filter-row" style="margin-bottom:var(--space-4)">
            <label class="filter-label">Status</label>
            <SfDropDownList TValue="string" TItem="FilterOption"
                            DataSource="@_statusOptions"
                            @bind-Value="_statusFilter"
                            Width="160px">
                <DropDownListFieldSettings Value="Value" Text="Label" />
            </SfDropDownList>
        </div>
    }

    @* ── Context list ──────────────────────────────────────────── *@
    @if (_loading)
    {
        <p class="loading-state">Loading…</p>
    }
    else if (_filtered.Count == 0)
    {
        <div class="panel-card">
            <p style="color:#6B7280;font-size:var(--font-size-sm);margin:0">
                No payroll contexts for this legal entity. Use <strong>+ New Context</strong> to create one.
            </p>
        </div>
    }
    else
    {
        var visible = string.IsNullOrEmpty(_statusFilter)
            ? _filtered
            : _filtered.Where(c => c.ContextStatus == _statusFilter).ToList();

        @if (visible.Count == 0)
        {
            <p class="empty-state">No contexts match the selected filter.</p>
        }
        else
        {
            <SfGrid DataSource="@visible" AllowSorting="true" AllowPaging="true" CssClass="e-gridhover">
                <GridPageSettings PageSize="25" />
                <GridColumns>
                    <GridColumn Field="PayrollContextCode" HeaderText="Code" Width="120">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            <span style="font-family:monospace;font-weight:var(--font-weight-medium)">@ctx.PayrollContextCode</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="PayrollContextName" HeaderText="Name" Width="200">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            <a href="/payroll/calendar/@ctx.PayrollContextId" class="table-link">@ctx.PayrollContextName</a>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="PayFrequencyId" HeaderText="Pay Frequency" Width="150">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            @FrequencyLabel(ctx.PayFrequencyId)
                        </Template>
                    </GridColumn>
                    <GridColumn Field="EffectiveStartDate" HeaderText="Effective From" Width="140" Format="yyyy-MM-dd" />
                    <GridColumn Field="EffectiveEndDate" HeaderText="Effective To" Width="130">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            @(ctx.EffectiveEndDate?.ToString("yyyy-MM-dd") ?? "—")
                        </Template>
                    </GridColumn>
                    <GridColumn Field="ContextStatus" HeaderText="Status" Width="120">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            <span class="badge @StatusClass(ctx.ContextStatus)">@ctx.ContextStatus</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="90" TextAlign="TextAlign.Right">
                        <Template>
                            @{ var ctx = (PayrollContext)context; }
                            <a href="/payroll/calendar/@ctx.PayrollContextId" class="btn-link">View</a>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    }

</div>

<style>
    .stat-card--total    { border-top: 4px solid var(--module-payroll); }
    .stat-card--active   { border-top: 4px solid var(--color-success); }
    .stat-card--inactive { border-top: 4px solid var(--color-warning); }
    .stat-card--closed   { border-top: 4px solid #9CA3AF; }
</style>

@code {
    private List<PayrollContext> _all         = [];
    private List<PayrollContext> _filtered    = [];
    private List<LookupEntry>    _frequencies = [];
    private List<LookupEntry>    _rateTypes   = [];

    private bool    _loading           = true;
    private bool    _submitting;
    private bool    _showNewContextForm;
    private string  _statusFilter      = "";
    private string? _contextError;
    private Guid    _currentUserId;

    private NewContextForm _newCtx = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = Guid.TryParse(auth.User.FindFirst("sub")?.Value, out var g) ? g : Guid.Empty;

        SessionState.OnChanged += HandleEntityChanged;

        try { _frequencies = LookupCache.GetAll(LookupTables.PayFrequency).OrderBy(f => f.Id).ToList(); }
        catch { _frequencies = DefaultFrequencies(); }

        try { _rateTypes = LookupCache.GetAll(LookupTables.CompensationRateType).OrderBy(r => r.Id).ToList(); }
        catch { _rateTypes = []; }

        _all     = (await ContextRepo.GetAllAsync()).ToList();
        _loading = false;

        FilterForEntity();
    }

    private void HandleEntityChanged()
    {
        FilterForEntity();
        InvokeAsync(StateHasChanged);
    }

    private void FilterForEntity()
    {
        if (SessionState.HasEntity)
            _filtered = _all.Where(c => c.LegalEntityId == SessionState.SelectedLegalEntityId).ToList();
    }

    public void Dispose()
        => SessionState.OnChanged -= HandleEntityChanged;

    private async Task ToggleNewContextForm()
    {
        _showNewContextForm = !_showNewContextForm;
        _contextError       = null;
        if (_showNewContextForm)
        {
            var entityId = SessionState.SelectedLegalEntityId ?? Guid.Empty;
            var (otThreshold, wwStartDay) = entityId != Guid.Empty
                ? await ContextRepo.GetLegalEntityDefaultsAsync(entityId)
                : (null, null);

            _newCtx = new NewContextForm
            {
                EffectiveStartDate     = DateOnly.FromDateTime(TemporalContext.GetOperativeDate()),
                LegalEntityId          = entityId,
                OtWeeklyThresholdHours = otThreshold ?? 40.00m,
                WorkweekStartDay       = wwStartDay  ?? 1
            };
        }
    }

    private async Task CreateContextAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCtx.Code) ||
            string.IsNullOrWhiteSpace(_newCtx.Name) ||
            _newCtx.LegalEntityId == Guid.Empty ||
            _newCtx.PayFrequencyId == 0 ||
            _newCtx.RateTypeId == 0)
        {
            _contextError = "Code, name, rate type, and pay frequency are required.";
            return;
        }

        var normalizedCode = _newCtx.Code.Trim().ToUpper();
        if (_all.Any(c => c.PayrollContextCode.Equals(normalizedCode, StringComparison.OrdinalIgnoreCase)))
        {
            _contextError = $"A payroll context with code '{normalizedCode}' already exists.";
            return;
        }

        _submitting   = true;
        _contextError = null;
        try
        {
            var now = DateTimeOffset.UtcNow;
            var ctx = new PayrollContext
            {
                PayrollContextId        = Guid.NewGuid(),
                PayrollContextCode      = _newCtx.Code.Trim().ToUpper(),
                PayrollContextName      = _newCtx.Name.Trim(),
                LegalEntityId           = _newCtx.LegalEntityId,
                PayFrequencyId          = _newCtx.PayFrequencyId,
                CompensationRateTypeId  = _newCtx.RateTypeId == 0 ? null : (int?)_newCtx.RateTypeId,
                ContextStatus           = "ACTIVE",
                ParentPayrollContextId  = null,
                RootPayrollContextId    = null,
                ContextVersionNumber    = 1,
                ContextChangeReasonCode = null,
                EffectiveStartDate      = _newCtx.EffectiveStartDate,
                EffectiveEndDate        = null,
                PayDateConvention       = string.IsNullOrEmpty(_newCtx.PayDateConvention) ? null : _newCtx.PayDateConvention,
                PayDateOffsetDays       = _newCtx.PayDateOffsetDays,
                CutoffOffsetDays        = _newCtx.CutoffOffsetDays,
                ExtraPeriodPolicy       = _newCtx.ExtraPeriodPolicy,
                OtWeeklyThresholdHours  = _newCtx.OtWeeklyThresholdHours,
                WorkweekStartDay        = _newCtx.WorkweekStartDay,
                CreatedBy               = _currentUserId,
                CreationTimestamp       = now,
                LastUpdatedBy           = _currentUserId,
                LastUpdateTimestamp     = now
            };
            await ContextRepo.InsertContextAsync(ctx);
            _all                = (await ContextRepo.GetAllAsync()).ToList();
            FilterForEntity();
            _showNewContextForm = false;
            Nav.NavigateTo($"/payroll/calendar/{ctx.PayrollContextId}");
        }
        catch (Exception ex) { _contextError = ex.Message; }
        finally { _submitting = false; }
    }

    private record FilterOption(string Value, string Label);
    private static readonly List<FilterOption> _statusOptions =
    [
        new("",         "All"),
        new("ACTIVE",   "Active"),
        new("INACTIVE", "Inactive"),
        new("CLOSED",   "Closed"),
    ];
    private static readonly List<FilterOption> _extraPeriodOptions =
    [
        new("EXTRA_SPECIAL", "Treat as special case (recommended)"),
        new("ADJUST_ALL",    "Adjust all checks (÷ 27)"),
        new("PER_EMPLOYEE",  "HR decides per employee"),
    ];

    private record IntOption(int Value, string Label);
    private static readonly List<IntOption> _weekdayOptions =
    [
        new(0, "Sunday"), new(1, "Monday"), new(2, "Tuesday"),
        new(3, "Wednesday"), new(4, "Thursday"), new(5, "Friday"), new(6, "Saturday"),
    ];

    private string FrequencyLabel(int id)
        => _frequencies.FirstOrDefault(f => f.Id == id)?.Label ?? id.ToString();

    private static string StatusClass(string status) => status switch
    {
        "ACTIVE"   => "badge-success",
        "INACTIVE" => "badge-warning",
        "CLOSED"   => "badge-neutral",
        _          => "badge-neutral"
    };

    private static List<LookupEntry> DefaultFrequencies() =>
    [
        new LookupEntry { Id = 1, Code = "WEEKLY",       Label = "Weekly"       },
        new LookupEntry { Id = 2, Code = "BIWEEKLY",     Label = "Biweekly"     },
        new LookupEntry { Id = 3, Code = "SEMI_MONTHLY", Label = "Semi-Monthly" },
        new LookupEntry { Id = 4, Code = "MONTHLY",      Label = "Monthly"      },
        new LookupEntry { Id = 5, Code = "QUARTERLY",    Label = "Quarterly"    },
        new LookupEntry { Id = 6, Code = "ANNUAL",       Label = "Annual"       },
    ];

    private static readonly (string Code, string Label, string Hint)[] _monthlyConventions =
    [
        ("MONTH_END",       "Last day of the month",       "Most common — aligns with accounting close, employees paid for full month"),
        ("FIRST_FOLLOWING", "1st of the following month",  "Gives payroll team the full month to process; pay is slightly delayed"),
        ("MID_MONTH",       "15th of the month",           "Mid-month — simple and predictable"),
        ("FIXED_25",        "25th of the month",           "Gives employees money before month-end bills; payroll has most of month to process"),
    ];

    private static readonly (string Code, string Label, string Hint)[] _semiMonthlyConventions =
    [
        ("SM_15_AND_END", "15th and last day of month", "Most common semi-monthly"),
        ("SM_1_AND_15",   "1st and 15th of month",      "Government, education"),
        ("SM_10_AND_25",  "10th and 25th of month",     "Less common"),
    ];

    private sealed class NewContextForm
    {
        public string   Code                   { get; set; } = "";
        public string   Name                   { get; set; } = "";
        public Guid     LegalEntityId          { get; set; }
        public int      RateTypeId             { get; set; }
        public int      PayFrequencyId         { get; set; }
        public DateOnly EffectiveStartDate     { get; set; } = DateOnly.MinValue;
        public string?  PayDateConvention      { get; set; }
        public int      PayDateOffsetDays      { get; set; } = 5;
        public int      CutoffOffsetDays       { get; set; } = 3;
        public string   ExtraPeriodPolicy      { get; set; } = "EXTRA_SPECIAL";
        public decimal  OtWeeklyThresholdHours { get; set; } = 40.00m;
        public int      WorkweekStartDay        { get; set; } = 1;
    }
}
