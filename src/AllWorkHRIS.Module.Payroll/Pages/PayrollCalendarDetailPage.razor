    private void BeginEditRunDate(PayrollPeriod p)
    {
        _editRunDatePeriodId = p.PeriodId;
        _editRunDateValue    = p.CalculationDate;
        _editRunDateError    = null;
    }

    private void CancelEditRunDate()
    {
        _editRunDatePeriodId = null;
        _editRunDateValue    = null;
        _editRunDateError    = null;
    }

    private async Task SaveRunDateAsync(Guid periodId)
    {
        _editRunDateSaving = true;
        _editRunDateError  = null;
        try
        {
            await ContextRepo.UpdatePeriodRunDateAsync(periodId, _editRunDateValue, _currentUserId);
            await LoadPeriodsAsync();
            CancelEditRunDate();
        }
        catch (Exception ex) { _editRunDateError = ex.Message; }
        finally { _editRunDateSaving = false; }
    }

