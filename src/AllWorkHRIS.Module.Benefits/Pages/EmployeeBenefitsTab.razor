@using AllWorkHRIS.Module.Benefits.Repositories
@inject IBenefitElectionRepository BenefitElectionRepo

@if (_loading)
{
    <p class="loading-text">Loading…</p>
}
else if (_elections.Count == 0)
{
    <p class="placeholder-text">No active elections for this employee.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Treatment</th>
                <th>Emp Amount</th>
                <th>ER Amount</th>
                <th>Effective Start</th>
                <th>Effective End</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in _elections)
            {
                <tr>
                    <td><samp>@e.DeductionCode</samp></td>
                    <td><span class="badge @(e.TaxTreatment == "PRE_TAX" ? "badge-blue" : "badge-orange")">@e.TaxTreatment</span></td>
                    <td>@e.EmployeeAmount.ToString("N2")</td>
                    <td>@(e.EmployerContributionAmount?.ToString("N2") ?? "—")</td>
                    <td>@e.EffectiveStartDate.ToString("yyyy-MM-dd")</td>
                    <td>@(e.EffectiveEndDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td><span class="badge badge-green">@e.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public Guid EmploymentId { get; set; }

    private bool _loading = true;
    private List<BenefitDeductionElection> _elections = [];

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try
        {
            var asOf = DateOnly.FromDateTime(DateTime.Today);
            _elections = (await BenefitElectionRepo.GetActiveByEmploymentIdAsync(EmploymentId, asOf)).ToList();
        }
        catch { }
        finally { _loading = false; }
    }
}
