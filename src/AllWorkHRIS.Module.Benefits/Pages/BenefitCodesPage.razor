    // ── Helpers ──────────────────────────────────────────────────────

    private static decimal? ParseRoundedDecimal(string? s) =>
        decimal.TryParse(s, out var v) ? Math.Round(v, 2) : (decimal?)null;

    private static string TreatmentBadgeClass(string t) =>
        t == "PRE_TAX" ? "badge-blue" : "badge-orange";

    private static string StatusBadgeClass(string s) =>
        s == "ACTIVE" ? "badge-green" : "badge-gray";
