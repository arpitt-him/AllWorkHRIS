@page "/benefits/import"
@layout BenefitsShell
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "HrisAdmin,BenefitsAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IBenefitElectionImportService ImportService
@inject AuthenticationStateProvider   AuthState
@inject IJSRuntime                    JS
@using Syncfusion.Blazor.Grids

<PageTitle>Import Elections — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Import Benefit Elections</h2>
    </div>

    @* ── Format guide ────────────────────────────────────────────────── *@
    <div class="import-instructions" style="margin-bottom:1.5rem;">
        <h4 style="margin-bottom:.5rem;">CSV Format</h4>
        <p style="margin-bottom:.5rem;">One election per row. Header row required. 8 or 9 columns in this order:</p>
        <pre class="code-block" style="font-size:.8rem;overflow-x:auto;">employee_number, deduction_code, employee_amount, contribution_pct, coverage_tier, employer_contribution_amount, annual_coverage_amount, effective_start_date, effective_end_date</pre>

        <table class="data-table" style="margin-top:.875rem;font-size:.82rem;">
            <thead>
                <tr>
                    <th style="width:22%">Column</th>
                    <th style="width:30%">Required for mode</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>employee_number</code></td>
                    <td>All</td>
                    <td>Must match an active employment record.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>deduction_code</code></td>
                    <td>All</td>
                    <td>Must be an active deduction code.</td>
                </tr>
                <tr>
                    <td><code>employee_amount</code></td>
                    <td>FIXED_PER_PERIOD, FIXED_ANNUAL, FIXED_MONTHLY</td>
                    <td>Dollar amount ≥ 0. Leave blank for PCT / COVERAGE_BASED modes.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>contribution_pct</code></td>
                    <td>PCT_PRE_TAX, PCT_POST_TAX</td>
                    <td>Percentage value — e.g. <strong>6</strong> means 6% of gross. Leave blank for other modes.</td>
                </tr>
                <tr>
                    <td><code>coverage_tier</code></td>
                    <td>COVERAGE_BASED</td>
                    <td><code>EE_ONLY</code>, <code>EE_SPOUSE</code>, <code>EE_CHILD</code>, or <code>FAMILY</code>. Leave blank for other modes.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>employer_contribution_amount</code></td>
                    <td>Optional</td>
                    <td>Fixed employer dollar contribution per period. Omit or leave blank if none.</td>
                </tr>
                <tr>
                    <td><code>annual_coverage_amount</code></td>
                    <td>Optional</td>
                    <td>Annual face value for life/disability plans. Omit or leave blank if not applicable.</td>
                </tr>
                <tr style="background:#f9fafb;">
                    <td><code>effective_start_date</code></td>
                    <td>All</td>
                    <td>Required. Format: YYYY-MM-DD.</td>
                </tr>
                <tr>
                    <td><code>effective_end_date</code></td>
                    <td>Optional</td>
                    <td>Format: YYYY-MM-DD. Leave blank for open-ended elections.</td>
                </tr>
            </tbody>
        </table>
    </div>

    @* ── Step 1: Upload ──────────────────────────────────────────────── *@
    @if (_step == ImportStep.Upload)
    {
        <div class="form-panel">
            <h3 class="form-panel__title">Step 1 — Upload and Validate</h3>

            <div class="form-group">
                <label class="form-label">CSV File <span class="required">*</span></label>
                <input type="file" id="benefit-import-file" accept=".csv" class="form-input"
                       @key="_fileInputKey" @onchange="OnFileInputChange" />
            </div>

            @if (_fileError is not null)
            {
                <p class="form-error">@_fileError</p>
            }

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="ValidateAsync"
                        disabled="@(!_fileSelected || _validating)">
                    @(_validating ? "Validating…" : "Validate")
                </button>
                @if (_fileSelected)
                {
                    <button class="btn btn-ghost" @onclick="Reset">Cancel</button>
                }
            </div>
        </div>
    }

    @* ── Step 2: Review & import ─────────────────────────────────────── *@
    @if (_step == ImportStep.Validated && _validationResult is not null)
    {
        <div class="form-panel">
            <h3 class="form-panel__title">Step 2 — Review and Import</h3>

            <div class="import-summary">
                <div class="stat-card stat-card--neutral">
                    <div class="stat-value">@_validationResult.TotalRecords</div>
                    <div class="stat-label">Total Records</div>
                </div>
                <div class="stat-card stat-card--valid">
                    <div class="stat-value">@_validationResult.ValidCount</div>
                    <div class="stat-label">Valid</div>
                </div>
                <div class="stat-card @(_validationResult.InvalidCount > 0 ? "stat-card--invalid" : "stat-card--valid")">
                    <div class="stat-value">@_validationResult.InvalidCount</div>
                    <div class="stat-label">Invalid</div>
                </div>
            </div>

            @if (_validationResult.Errors.Count > 0)
            {
                <h4 style="margin-top:1.25rem;">Validation Errors</h4>
                <SfGrid DataSource="@_validationResult.Errors" AllowSorting="true" CssClass="e-gridhover"
                        style="margin-top:.5rem;">
                    <GridColumns>
                        <GridColumn HeaderText="Row" Width="80">
                            <Template>@{ var err = (RecordError)context; }@err.RowNumber</Template>
                        </GridColumn>
                        <GridColumn HeaderText="Field" Width="200">
                            <Template>@{ var err = (RecordError)context; }<code>@err.Field</code></Template>
                        </GridColumn>
                        <GridColumn HeaderText="Error">
                            <Template>@{ var err = (RecordError)context; }@err.ErrorMessage</Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            }

            @if (_importError is not null)
            {
                <p class="form-error" style="margin-top:1rem;">@_importError</p>
            }
            @if (_importSuccess is not null)
            {
                <p class="form-success" style="margin-top:1rem;">@_importSuccess</p>
            }

            <div class="form-actions" style="margin-top:1.25rem;">
                @if (_importSuccess is null)
                {
                    <button class="btn btn-primary" @onclick="ImportAsync"
                            disabled="@(_validationResult.ValidCount == 0 || _importing)"
                            title="@(_validationResult.ValidCount == 0 ? "No valid records to import" : "")">
                        @(_importing ? "Importing…" : $"Import {_validationResult.ValidCount} Valid Record{(_validationResult.ValidCount == 1 ? "" : "s")}")
                    </button>
                }
                <button class="btn btn-ghost" @onclick="Reset">Start Over</button>
            </div>
        </div>
    }

</div>

<style>
    .stat-card--neutral { border-top: 3px solid #6b7280; }
    .stat-card--valid   { border-top: 3px solid #16a34a; }
    .stat-card--invalid { border-top: 3px solid #dc2626; }
</style>

@code {

    private enum ImportStep { Upload, Validated }

    private ImportStep             _step             = ImportStep.Upload;
    private int                    _fileInputKey;
    private bool                   _fileSelected;
    private byte[]?                _fileBytes;
    private string?                _fileError;
    private bool                   _validating;
    private bool                   _importing;
    private BatchValidationResult? _validationResult;
    private string?                _importError;
    private string?                _importSuccess;

    private void OnFileInputChange(ChangeEventArgs e)
    {
        _fileSelected     = !string.IsNullOrEmpty(e.Value?.ToString());
        _fileBytes        = null;
        _fileError        = null;
        _validationResult = null;
        _importSuccess    = null;
        _step             = ImportStep.Upload;
    }

    private async Task ValidateAsync()
    {
        _validating = true; _fileError = null;
        try
        {
            var base64 = await JS.InvokeAsync<string?>("allworkFiles.readBase64", "benefit-import-file");
            if (string.IsNullOrEmpty(base64))
            { _fileError = "Could not read file. Please re-select and try again."; return; }

            _fileBytes = Convert.FromBase64String(base64);

            using var ms = new MemoryStream(_fileBytes);
            _validationResult = await ImportService.ValidateBatchAsync(ms, "text/csv");
            _step = ImportStep.Validated;
        }
        catch (Exception ex) { _fileError = ex.Message; }
        finally { _validating = false; }
    }

    private async Task ImportAsync()
    {
        if (_fileBytes is null || _validationResult is null) return;
        _importing = true; _importError = null; _importSuccess = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            Guid.TryParse(auth.User.FindFirstValue(ClaimTypes.NameIdentifier), out var submittedBy);

            using var ms  = new MemoryStream(_fileBytes);
            var jobId     = await ImportService.SubmitBatchAsync(ms, "text/csv", submittedBy);
            _importSuccess = $"Import complete (Job {jobId}). {_validationResult.ValidCount} election(s) created.";
        }
        catch (Exception ex) { _importError = ex.Message; }
        finally { _importing = false; }
    }

    private void Reset()
    {
        _step             = ImportStep.Upload;
        _fileInputKey++;
        _fileSelected     = false;
        _fileBytes        = null;
        _validationResult = null;
        _importError      = null;
        _importSuccess    = null;
    }
}
