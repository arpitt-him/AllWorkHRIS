@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IReadOnlyList<IPlatformModule> PlatformModules

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="@PlatformModules.Select(m => m.GetType().Assembly).Distinct().ToArray()">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(AllWorkHRIS.Host.SharedUI.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
