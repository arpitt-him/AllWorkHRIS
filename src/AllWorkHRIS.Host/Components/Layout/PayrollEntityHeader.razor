@implements IDisposable
@using AllWorkHRIS.Host.Hris.Domain
@using AllWorkHRIS.Host.Hris.Services
@using AllWorkHRIS.Host.Payroll.Services
@inject IOrgStructureService OrgService
@inject IPayrollSessionState SessionState

@if (_entities.Count > 1)
{
    <div class="payroll-shell__header">
        <span class="payroll-shell__entity-label">Legal Entity</span>
        @if (SessionState.IsLocked)
        {
            <span class="payroll-shell__entity-locked">@SessionState.SelectedLegalEntityName</span>
        }
        else
        {
            @foreach (var e in _entities)
            {
                var entity = e;
                <button @key="entity.OrgUnitId"
                        class="payroll-shell__entity-pill @(SessionState.SelectedLegalEntityId == entity.OrgUnitId ? "payroll-shell__entity-pill--active" : "")"
                        @onclick="() => SelectEntity(entity)">
                    @entity.OrgUnitName
                </button>
            }
        }
    </div>
}

@code {
    private List<OrgUnit> _entities = [];

    protected override async Task OnInitializedAsync()
    {
        SessionState.OnChanged += OnSessionChanged;

        var all = await OrgService.GetLegalEntitiesAsync();
        _entities = all.OrderBy(e => e.OrgUnitName).ToList();

        if (_entities.Count > 0 && !SessionState.HasEntity)
            SelectEntity(_entities[0]);
    }

    private void SelectEntity(OrgUnit entity)
        => SessionState.SetEntity(entity.OrgUnitId, entity.OrgUnitName);

    private void OnSessionChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => SessionState.OnChanged -= OnSessionChanged;
}
