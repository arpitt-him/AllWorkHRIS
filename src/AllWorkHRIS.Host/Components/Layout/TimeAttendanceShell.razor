@rendermode InteractiveServer
@inherits LayoutComponentBase
@layout MainLayout
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization
@using AllWorkHRIS.Core.Security

<div class="ta-shell">

    <div class="ta-shell__tabs">
        <AuthorizeView Roles="TimeViewer,TimeAdmin,Manager">
            <a class="ta-tab @ActiveClass("/ta/timecards")" href="/ta/timecards">Timecards</a>
        </AuthorizeView>
        <AuthorizeView Roles="TimeAdmin">
            <a class="ta-tab @ActiveClass("/ta/import")"   href="/ta/import">Import Entries</a>
        </AuthorizeView>
        <AuthorizeView Roles="TimeAdmin">
            <a class="ta-tab @ActiveClass("/ta/handoff")"  href="/ta/handoff">Payroll Handoff</a>
        </AuthorizeView>
    </div>

    <div class="ta-shell__body">
        @Body
    </div>

</div>

@code {
    private string ActiveClass(string path)
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        return uri.StartsWith(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase)
            ? "ta-tab--active"
            : "";
    }
}

<style>
    .ta-shell { display: flex; flex-direction: column; height: 100%; }

    .ta-shell__tabs {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #e5e7eb;
        background: white;
        padding: 0 var(--space-6, 1.5rem);
        flex-shrink: 0;
    }

    .ta-tab {
        padding: var(--space-3, .75rem) var(--space-4, 1rem);
        font-size: var(--font-size-sm, .875rem);
        font-weight: var(--font-weight-medium, 500);
        color: #6b7280;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        white-space: nowrap;
        transition: color .15s, border-color .15s;
    }

    .ta-tab:hover                { color: var(--module-ta, #7c3aed); }
    .ta-tab--active {
        color: var(--module-ta, #7c3aed);
        border-bottom-color: var(--module-ta, #7c3aed);
        font-weight: var(--font-weight-semibold, 600);
    }

    .ta-shell__body { flex: 1; overflow: auto; padding: var(--space-6, 1.5rem); }
</style>
