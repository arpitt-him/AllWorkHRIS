@using AllWorkHRIS.Host.Hris.Domain
@using AllWorkHRIS.Host.Hris.Services
@inject IOrgStructureService OrgService

@if (_entities.Count == 1)
{
    <span class="entity-badge">@_entities[0].OrgUnitName</span>
}
else if (_entities.Count > 1 && _entities.Count <= 8)
{
    <div class="entity-tabs">
        @foreach (var e in _entities)
        {
            <button class="entity-tab @(_selectedId == e.OrgUnitId ? "active" : "")"
                    @onclick="() => SelectAsync(e.OrgUnitId)">
                @e.OrgUnitName
            </button>
        }
    </div>
}
else if (_entities.Count > 8)
{
    <div class="entity-search-wrap">
        <input type="text" class="entity-search-input" placeholder="Search legal entities…"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty" />
        <div class="entity-search-list">
            @foreach (var e in Filtered)
            {
                <button class="entity-search-item @(_selectedId == e.OrgUnitId ? "active" : "")"
                        @onclick="() => SelectAsync(e.OrgUnitId)">
                    @e.OrgUnitName
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<Guid> OnChanged { get; set; }

    private List<OrgUnit> _entities  = [];
    private Guid          _selectedId;
    private string        _search    = "";

    private IEnumerable<OrgUnit> Filtered =>
        string.IsNullOrEmpty(_search)
            ? _entities
            : _entities.Where(e => e.OrgUnitName.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var all = await OrgService.GetLegalEntitiesAsync();
        _entities = all.OrderBy(e => e.OrgUnitName).ToList();
        if (_entities.Count > 0)
            await SelectAsync(_entities[0].OrgUnitId);
    }

    private async Task SelectAsync(Guid id)
    {
        _selectedId = id;
        await OnChanged.InvokeAsync(id);
    }
}
