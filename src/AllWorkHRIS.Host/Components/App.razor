<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["AllWorkHRIS.Host.styles.css"]" />
    <link href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    <div id="components-reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-spinner"></div>
            <div class="reconnect-text">
                <strong>Connection lost</strong>
                <span id="reconnect-status">Attempting to reconnect…</span>
                <span id="reconnect-countdown"></span>
            </div>
        </div>
    </div>

    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        (function () {
            var modal       = document.getElementById('components-reconnect-modal');
            var statusEl    = document.getElementById('reconnect-status');
            var countdownEl = document.getElementById('reconnect-countdown');
            if (!modal) return;

            // Seconds to wait before each retry attempt (index = previousAttempts)
            // Attempt 1 is immediate; subsequent waits ramp up to match Blazor's backoff
            var SCHEDULE    = [0, 7, 12, 17, 22, 27];
            var MAX_RETRIES = SCHEDULE.length;
            var countdownTimer = null;

            function clearTimer() {
                clearInterval(countdownTimer);
                countdownTimer = null;
            }

            function showConnecting(attemptNum) {
                clearTimer();
                statusEl.textContent    = 'Attempt ' + attemptNum + ' of ' + MAX_RETRIES;
                countdownEl.textContent = 'Connecting…';
            }

            function startCountdown(failedAttempt, waitSecs) {
                clearTimer();
                statusEl.textContent    = 'Attempt ' + failedAttempt + ' failed';
                countdownEl.textContent = 'Retrying in ' + waitSecs + 's…';
                var secs = waitSecs;
                countdownTimer = setInterval(function () {
                    secs--;
                    if (secs <= 0) {
                        clearTimer();
                        showConnecting(failedAttempt + 1);
                    } else {
                        countdownEl.textContent = 'Retrying in ' + secs + 's…';
                    }
                }, 1000);
            }

            // Handle failed / rejected states via MutationObserver
            new MutationObserver(function () {
                if (modal.classList.contains('components-reconnect-failed') ||
                    modal.classList.contains('components-reconnect-rejected')) {
                    clearTimer();
                    statusEl.textContent    = 'Could not reconnect.';
                    countdownEl.textContent = 'Please reload the page.';
                } else if (!modal.classList.contains('components-reconnect-show')) {
                    clearTimer();
                    statusEl.textContent    = 'Attempting to reconnect…';
                    countdownEl.textContent = '';
                }
            }).observe(modal, { attributes: true, attributeFilter: ['class'] });

            Blazor.start({
                circuit: {
                    reconnectionOptions: {
                        maxRetries: MAX_RETRIES,
                        retryIntervalMilliseconds: function (previousAttempts) {
                            if (previousAttempts >= MAX_RETRIES) return null;
                            var waitSecs = SCHEDULE[previousAttempts];
                            if (waitSecs === 0) {
                                showConnecting(1);
                            } else {
                                startCountdown(previousAttempts, waitSecs);
                            }
                            return waitSecs * 1000;
                        }
                    }
                },
                configureSignalR: function (builder) {
                    builder.withServerTimeout(300000);    // 5 minutes (default is 30s)
                    builder.withKeepAliveInterval(15000); // 15 seconds
                }
            });
        })();

        // Read a file input's content client-side and return it as a base64 string.
        // Used instead of IBrowserFile.OpenReadStream(), which times out in Blazor Web App.
        // Uint8Array cannot cross the JS interop JSON boundary; base64 string can.
        window.allworkFiles = {
            readBase64: function (inputId) {
                return new Promise(function (resolve, reject) {
                    var input = document.getElementById(inputId);
                    if (!input || !input.files || !input.files.length) { resolve(null); return; }
                    var reader = new FileReader();
                    reader.onload  = function () {
                        // result is "data:<mime>;base64,<data>" — strip the prefix
                        var b64 = reader.result.split(',')[1];
                        resolve(b64);
                    };
                    reader.onerror = function () { reject(reader.error); };
                    reader.readAsDataURL(input.files[0]);
                });
            },
            getFileSize: function (inputId) {
                var input = document.getElementById(inputId);
                if (!input || !input.files || !input.files.length) return 0;
                return input.files[0].size;
            },
            getFileMime: function (inputId) {
                var input = document.getElementById(inputId);
                if (!input || !input.files || !input.files.length) return '';
                return input.files[0].type;
            }
        };
    </script>
</body>

</html>
