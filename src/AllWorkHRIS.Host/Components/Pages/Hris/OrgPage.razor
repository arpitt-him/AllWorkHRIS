@page "/hris/org"
@layout HrisShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "HrisViewer,HrisAdmin")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using AllWorkHRIS.Core.Lookups
@using AllWorkHRIS.Host.Hris.Commands
@using AllWorkHRIS.Host.Hris.Services
@using AllWorkHRIS.Host.Hris.Domain
@using AllWorkHRIS.Host.Hris.Queries
@using AllWorkHRIS.Core.Temporal
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.Inputs
@inject IOrgStructureService OrgStructureService
@inject ILookupCache         LookupCache
@inject ITemporalContext     TemporalContext
@inject IHrisSessionState    SessionState

<PageTitle>Organization — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Organization</h2>
        <AuthorizeView Roles="HrisAdmin">
            <Authorized>
                <button class="btn-primary" @onclick="OpenAddOrgUnitPanel">+ Add Org Unit</button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_selectError is not null)
    {
        <p class="form-error" style="margin-bottom:var(--space-3)">Error loading org units: @_selectError</p>
    }

    @* View toggle *@
    <div class="view-toggle">
        <button class="toggle-btn @(_activeView == "hierarchy" ? "active" : "")"
                @onclick='() => _activeView = "hierarchy"'>
            Hierarchy
        </button>
        <button class="toggle-btn @(_activeView == "list" ? "active" : "")"
                @onclick='() => _activeView = "list"'>
            List
        </button>
    </div>

    @if (_loading)
    {
        <p class="loading-text">Loading organization...</p>
    }
    else if (_selectedLegalEntityId is null)
    {
        <div class="empty-state">
            <p>Select a legal entity to view its organization structure.</p>
        </div>
    }
    else if (_activeView == "hierarchy")
    {
        <div class="org-tree-container">
            @if (!_orgUnits.Any())
            {
                <div class="empty-state">
                    <p>No org units found for this legal entity.</p>
                    <AuthorizeView Roles="HrisAdmin">
                        <Authorized>
                            <p>Click <strong>+ Add Org Unit</strong> to create the first org unit.</p>
                        </Authorized>
                    </AuthorizeView>
                </div>
            }
            else
            {
                @foreach (var (unit, depth) in GetTreeOrder())
                {
                    var hasChildren = TreeUnits.Any(u => u.ParentOrgUnitId == unit.OrgUnitId);
                    var isSelected  = _selectedNodeId == unit.OrgUnitId;
                    <div class="org-tree-node">
                        <div class="org-node-header @(isSelected ? "selected" : "")"
                             style="padding-left: calc(var(--space-3) + @(depth * 24)px)"
                             @onclick="async () => await SelectNodeAsync(unit.OrgUnitId, unit.OrgUnitName)">
                            <span class="org-node-toggle"
                                  @onclick:stopPropagation
                                  @onclick="() => { if (hasChildren) ToggleNode(unit.OrgUnitId); }">
                                @if (hasChildren)
                                {
                                    @(IsExpanded(unit.OrgUnitId) ? "▾" : "▸")
                                }
                                else
                                {
                                    @("·")
                                }
                            </span>
                            <span class="org-type-badge">@LookupLabel(LookupTables.OrgUnitType, unit.OrgUnitTypeId)</span>
                            <span class="org-node-name">@unit.OrgUnitName</span>
                            <span class="org-node-code">@unit.OrgUnitCode</span>
                            @if (_isHrisAdmin)
                            {
                                <span class="org-node-actions" @onclick:stopPropagation>
                                    <button class="btn-icon-edit" title="Edit" @onclick="() => OpenEditOrgUnitPanel(unit)"><span class="e-icons e-edit"></span></button>
                                </span>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (LocationUnits.Any())
        {
            <div class="locations-section">
                <h4 class="locations-title">Locations</h4>
                <div class="locations-list">
                    @foreach (var loc in LocationUnits.OrderBy(l => l.OrgUnitName))
                    {
                        <div class="location-chip">
                            <span class="location-chip-name">@loc.OrgUnitName</span>
                            <span class="location-chip-code">@loc.OrgUnitCode</span>
                            @if (_isHrisAdmin)
                            {
                                <button class="btn-icon-edit" title="Edit" @onclick="() => OpenEditOrgUnitPanel(loc)"><span class="e-icons e-edit"></span></button>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="grid-container">
            @if (!_listOrgUnits.Any())
            {
                <div class="empty-state">
                    <p>No org units found for this legal entity.</p>
                </div>
            }
            else
            {
                <SfGrid DataSource="@_listOrgUnits" AllowSorting="true" CssClass="e-gridhover">
                    <GridEvents TValue="OrgUnit" RowSelected="OnListRowSelectedAsync" />
                    <GridColumns>
                        <GridColumn HeaderText="Name">
                            <Template>@{ var u = (OrgUnit)context; }@u.OrgUnitName</Template>
                        </GridColumn>
                        <GridColumn HeaderText="Code" Width="100">
                            <Template>@{ var u = (OrgUnit)context; }@u.OrgUnitCode</Template>
                        </GridColumn>
                        <GridColumn HeaderText="Type" Width="140">
                            <Template>@{ var u = (OrgUnit)context; }<span class="org-type-badge">@LookupLabel(LookupTables.OrgUnitType, u.OrgUnitTypeId)</span></Template>
                        </GridColumn>
                        <GridColumn HeaderText="Status" Width="110">
                            <Template>@{ var u = (OrgUnit)context; }<span class="status-badge status-@LookupCode(LookupTables.OrgStatus, u.OrgStatusId)">@LookupLabel(LookupTables.OrgStatus, u.OrgStatusId)</span></Template>
                        </GridColumn>
                        <GridColumn HeaderText="Effective Start" Width="145">
                            <Template>@{ var u = (OrgUnit)context; }@u.EffectiveStartDate.ToString("yyyy-MM-dd")</Template>
                        </GridColumn>
                        <GridColumn HeaderText="" Width="60" AllowSorting="false">
                            <Template>
                                @{ var u = (OrgUnit)context; }
                                @if (_isHrisAdmin)
                                {
                                    <button class="btn-icon-edit" title="Edit"
                                            @onclick:stopPropagation
                                            @onclick="() => OpenEditOrgUnitPanel(u)">
                                        <span class="e-icons e-edit"></span>
                                    </button>
                                }
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            }
        </div>
    }

    @* Workforce panel — shown when a hierarchy node is selected *@
    @if (_selectedNodeId.HasValue)
    {
        <div class="workforce-panel">
            <div class="workforce-panel-header">
                <div>
                    <span class="workforce-panel-title">@_selectedNodeName</span>
                    <span class="workforce-panel-subtitle">Workforce Composition</span>
                </div>
                <button class="workforce-close" @onclick="() => { _selectedNodeId = null; _workforce = []; }">✕</button>
            </div>

            @if (_workforceLoading)
            {
                <p class="loading-text">Loading workforce...</p>
            }
            else if (!_workforce.Any())
            {
                <p class="loading-text">No active employees in this unit or its sub-units.</p>
            }
            else
            {
                @* Summary cards *@
                var headcount  = _workforce.Count;
                var fullTime   = _workforce.Count(w => w.FullPartTime == "FULL_TIME");
                var partTime   = _workforce.Count(w => w.FullPartTime != "FULL_TIME");
                var exempt     = _workforce.Count(w => w.FlsaStatus.StartsWith("EXEMPT"));
                var nonExempt  = _workforce.Count(w => w.FlsaStatus   == "NON_EXEMPT");
                var totalCost  = _workforce.Sum(w => w.AnnualEquivalent);

                <div class="wf-summary">
                    <div class="wf-card">
                        <div class="wf-card-value">@headcount</div>
                        <div class="wf-card-label">Headcount</div>
                    </div>
                    <div class="wf-card">
                        <div class="wf-card-value">@fullTime <span class="wf-card-sub">FT</span> / @partTime <span class="wf-card-sub">PT</span></div>
                        <div class="wf-card-label">Full / Part Time</div>
                    </div>
                    <div class="wf-card">
                        <div class="wf-card-value">@exempt <span class="wf-card-sub">Ex</span> / @nonExempt <span class="wf-card-sub">NE</span></div>
                        <div class="wf-card-label">FLSA Exempt / Non-Exempt</div>
                    </div>
                    <div class="wf-card wf-card-cost">
                        <div class="wf-card-value">@totalCost.ToString("C0")</div>
                        <div class="wf-card-label">Total Annualized Cost</div>
                    </div>
                </div>

                <SfGrid DataSource="@_workforce" AllowSorting="true" CssClass="e-gridhover">
                    <GridColumns>
                        <GridColumn HeaderText="Name">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }@emp.LegalLastName, @(emp.PreferredName ?? emp.LegalFirstName)</Template>
                        </GridColumn>
                        <GridColumn HeaderText="#" Width="100">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }<code>@emp.EmployeeNumber</code></Template>
                        </GridColumn>
                        <GridColumn HeaderText="Job Title">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }@emp.JobTitle</Template>
                        </GridColumn>
                        <GridColumn HeaderText="Department">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }@emp.DepartmentName</Template>
                        </GridColumn>
                        <GridColumn HeaderText="FT/PT" Width="100">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }<span class="wf-badge wf-@emp.FullPartTime.ToLower()">@emp.FullPartTime.Replace("_", " ")</span></Template>
                        </GridColumn>
                        <GridColumn HeaderText="FLSA" Width="110">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }<span class="wf-badge wf-@emp.FlsaStatus.ToLower()">@emp.FlsaStatus.Replace("_", " ")</span></Template>
                        </GridColumn>
                        <GridColumn HeaderText="Annual Cost" Width="130">
                            <Template>@{ var emp = (OrgUnitEmployee)context; }<code>@emp.AnnualEquivalent.ToString("C0")</code></Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            }
        </div>
    }

</div>

@if (_showAddPanel)
{
    <div class="panel-overlay" @onclick="CloseAddOrgUnitPanel">
        <div class="panel-content" @onclick:stopPropagation>
            <h3 class="panel-title">Add Org Unit</h3>

            <div class="panel-form">
                <div class="form-field">
                    <label class="form-label">Type</label>
                    <SfDropDownList TValue="string" TItem="OrgTypeOption" DataSource="@_orgTypeOptions"
                                    @bind-Value="_newUnitType" Placeholder="Select type…">
                        <DropDownListFieldSettings Value="Code" Text="Label" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Name</label>
                    <SfTextBox @bind-Value="_newUnitName" Placeholder="e.g. Engineering" />
                </div>
                <div class="form-field">
                    <label class="form-label">Code</label>
                    <SfTextBox @bind-Value="_newUnitCode" Placeholder="e.g. ENG" />
                </div>
                <div class="form-field">
                    <label class="form-label">Legal Entity</label>
                    <div class="form-readonly">@(SessionState.SelectedLegalEntityName ?? "—")</div>
                </div>
                <div class="form-field">
                    <label class="form-label">Parent Org Unit (optional)</label>
                    <SfDropDownList TValue="string" TItem="ParentUnitOption" DataSource="@_parentOptions"
                                    @bind-Value="_newParentIdStr" Placeholder="— None (top level) —" ShowClearButton="true">
                        <DropDownListFieldSettings Value="IdStr" Text="Label" />
                    </SfDropDownList>
                </div>
                <div class="form-field">
                    <label class="form-label">Effective Start Date</label>
                    <SfDatePicker TValue="DateTime" @bind-Value="_newEffectiveDt" />
                </div>
            </div>

            @if (_addError is not null)
            {
                <p class="form-error">@_addError</p>
            }

            <div class="panel-actions">
                <button class="btn-primary" @onclick="SaveOrgUnitAsync" disabled="@_saving">
                    @(_saving ? "Saving…" : "Save")
                </button>
                <button class="btn-secondary" @onclick="CloseAddOrgUnitPanel">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_showEditPanel && _editingUnit is not null)
{
    <div class="panel-overlay" @onclick="CloseEditOrgUnitPanel">
        <div class="panel-content" @onclick:stopPropagation>
            <h3 class="panel-title">Edit Org Unit</h3>

            <div class="panel-form">
                <div class="form-field">
                    <label class="form-label">Type</label>
                    <div class="form-readonly">@LookupLabel(LookupTables.OrgUnitType, _editingUnit.OrgUnitTypeId)</div>
                </div>
                <div class="form-field">
                    <label class="form-label">Name</label>
                    <SfTextBox @bind-Value="_editName" />
                </div>
                <div class="form-field">
                    <label class="form-label">Code</label>
                    <SfTextBox @bind-Value="_editCode" />
                </div>
            </div>

            @if (_editError is not null)
            {
                <p class="form-error">@_editError</p>
            }

            <div class="panel-actions">
                <button class="btn-primary" @onclick="SaveEditOrgUnitAsync" disabled="@_editSaving">
                    @(_editSaving ? "Saving…" : "Save")
                </button>
                <button class="btn-secondary" @onclick="CloseEditOrgUnitPanel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private sealed record OrgTypeOption(string Code, string Label);
    private sealed record ParentUnitOption(string IdStr, string Label);

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool          _loading      = true;
    private string        _activeView   = "hierarchy";
    private bool          _showAddPanel = false;
    private List<OrgUnit> _orgUnits      = [];
    private List<OrgUnit> _listOrgUnits  = [];

    private int LocationTypeId => LookupCache.GetId(LookupTables.OrgUnitType, "LOCATION");
    private IEnumerable<OrgUnit> TreeUnits     => _orgUnits.Where(u => u.OrgUnitTypeId != LocationTypeId);
    private IEnumerable<OrgUnit> LocationUnits => _orgUnits.Where(u => u.OrgUnitTypeId == LocationTypeId);
    private Guid?         _selectedLegalEntityId;
    private HashSet<Guid> _expanded      = [];
    private string?       _selectError;
    private Guid?         _selectedNodeId;
    private string        _selectedNodeName  = "";
    private List<OrgUnitEmployee> _workforce = [];
    private bool          _workforceLoading  = false;

    // Add panel state
    private string   _newUnitType    = "";
    private string   _newUnitName    = "";
    private string   _newUnitCode    = "";
    private string   _newParentIdStr = "";
    private DateTime _newEffectiveDt;
    private string?  _addError;
    private bool     _saving         = false;

    // Edit panel state
    private bool     _showEditPanel = false;
    private OrgUnit? _editingUnit;
    private string   _editName      = "";
    private string   _editCode      = "";
    private string?  _editError;
    private bool     _editSaving    = false;
    private bool     _isHrisAdmin   = false;

    // Dropdown sources
    private List<OrgTypeOption>    _orgTypeOptions = [];
    private List<ParentUnitOption> _parentOptions  = [];

    protected override async Task OnInitializedAsync()
    {
        SessionState.OnChanged += HandleEntityChanged;

        var state    = await AuthStateTask;
        _isHrisAdmin = state.User.IsInRole("HrisAdmin");

        _orgTypeOptions = LookupCache.GetAll(LookupTables.OrgUnitType)
            .Where(t => t.Code != "LEGAL_ENTITY")
            .Select(t => new OrgTypeOption(t.Code, t.Label))
            .ToList();

        _loading = true;
        try
        {
            if (SessionState.HasEntity)
                await SelectLegalEntityAsync(SessionState.SelectedLegalEntityId!.Value);
        }
        finally { _loading = false; }
    }

    private void HandleEntityChanged()
        => InvokeAsync(async () =>
        {
            if (SessionState.HasEntity)
                await SelectLegalEntityAsync(SessionState.SelectedLegalEntityId!.Value);
            StateHasChanged();
        });

    public void Dispose()
        => SessionState.OnChanged -= HandleEntityChanged;

    private async Task OnListRowSelectedAsync(RowSelectEventArgs<OrgUnit> args)
    {
        if (args.Data is null) return;
        await SelectNodeAsync(args.Data.OrgUnitId, args.Data.OrgUnitName);
    }

    private async Task SelectNodeAsync(Guid nodeId, string nodeName)
    {
        _selectedNodeId   = nodeId;
        _selectedNodeName = nodeName;
        _expanded.Add(nodeId);
        _workforceLoading = true;
        _workforce        = [];
        try
        {
            var result = await OrgStructureService.GetOrgUnitWorkforceAsync(nodeId);
            _workforce = result.ToList();
        }
        catch (Exception ex)
        {
            _selectError = ex.Message;
        }
        finally
        {
            _workforceLoading = false;
            StateHasChanged();
        }
    }

    private async Task SelectLegalEntityAsync(Guid legalEntityId)
    {
        _selectError      = null;
        _selectedNodeId   = null;
        _workforce        = [];
        try
        {
            _selectedLegalEntityId = legalEntityId;
            _expanded.Clear();

            var units = await OrgStructureService.GetAllActiveAsync(legalEntityId);
            _orgUnits = units.ToList();

            foreach (var unit in _orgUnits)
                _expanded.Add(unit.OrgUnitId);

            _listOrgUnits = TreeUnits.OrderBy(u => u.OrgUnitTypeId).ThenBy(u => u.OrgUnitName).ToList();
            _parentOptions = _orgUnits
                .OrderBy(u => u.OrgUnitName)
                .Select(u => new ParentUnitOption(
                    u.OrgUnitId.ToString(),
                    $"{u.OrgUnitName} ({LookupCode(LookupTables.OrgUnitType, u.OrgUnitTypeId).ToUpper()})"))
                .ToList();
        }
        catch (Exception ex)
        {
            _selectError = ex.Message;
        }
        finally
        {
            StateHasChanged();
        }
    }

    private IEnumerable<OrgUnit> RootUnits =>
        _orgUnits.Where(u => u.ParentOrgUnitId is null);

    private bool IsExpanded(Guid id) => _expanded.Contains(id);

    private void ToggleNode(Guid id)
    {
        if (_expanded.Contains(id)) _expanded.Remove(id);
        else _expanded.Add(id);
    }

    private IEnumerable<(OrgUnit Unit, int Depth)> GetTreeOrder()
    {
        var result = new List<(OrgUnit, int)>();
        void Visit(Guid? parentId, int depth)
        {
            foreach (var unit in TreeUnits
                .Where(u => u.ParentOrgUnitId == parentId)
                .OrderBy(u => u.OrgUnitName))
            {
                result.Add((unit, depth));
                if (_expanded.Contains(unit.OrgUnitId))
                    Visit(unit.OrgUnitId, depth + 1);
            }
        }
        Visit(null, 0);
        return result;
    }

    private void OpenAddOrgUnitPanel()
    {
        _newUnitType = _newUnitName = _newUnitCode = _newParentIdStr = "";
        _newEffectiveDt = TemporalContext.GetOperativeDate();
        _addError = null;
        _showAddPanel = true;
    }

    private void CloseAddOrgUnitPanel() => _showAddPanel = false;

    private async Task SaveOrgUnitAsync()
    {
        _addError = null;
        if (string.IsNullOrWhiteSpace(_newUnitType)) { _addError = "Type is required."; return; }
        if (string.IsNullOrWhiteSpace(_newUnitName)) { _addError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_newUnitCode)) { _addError = "Code is required."; return; }
        if (!SessionState.HasEntity)                 { _addError = "No legal entity context."; return; }

        var parentId = Guid.TryParse(_newParentIdStr, out var pid) ? pid : (Guid?)null;

        _saving = true;
        try
        {
            var state   = await AuthStateTask;
            var sub     = state.User.FindFirst("sub")?.Value;
            var actorId = Guid.TryParse(sub, out var g) ? g : Guid.Empty;

            var command = new CreateOrgUnitCommand
            {
                OrgUnitTypeCode    = _newUnitType,
                OrgUnitCode        = _newUnitCode.Trim().ToUpper(),
                OrgUnitName        = _newUnitName.Trim(),
                ParentOrgUnitId    = parentId,
                LegalEntityId      = SessionState.SelectedLegalEntityId,
                EffectiveStartDate = DateOnly.FromDateTime(_newEffectiveDt),
                InitiatedBy        = actorId
            };

            await OrgStructureService.CreateOrgUnitAsync(command);
            _showAddPanel = false;
            await SelectLegalEntityAsync(SessionState.SelectedLegalEntityId!.Value);
        }
        catch (Exception ex) { _addError = ex.Message; }
        finally { _saving = false; }
    }

    private void OpenEditOrgUnitPanel(OrgUnit unit)
    {
        _editingUnit   = unit;
        _editName      = unit.OrgUnitName;
        _editCode      = unit.OrgUnitCode;
        _editError     = null;
        _showEditPanel = true;
    }

    private void CloseEditOrgUnitPanel()
    {
        _showEditPanel = false;
        _editingUnit   = null;
    }

    private async Task SaveEditOrgUnitAsync()
    {
        _editError = null;
        if (string.IsNullOrWhiteSpace(_editName)) { _editError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_editCode)) { _editError = "Code is required."; return; }
        if (_editingUnit is null) return;

        _editSaving = true;
        try
        {
            var state   = await AuthStateTask;
            var sub     = state.User.FindFirst("sub")?.Value;
            var actorId = Guid.TryParse(sub, out var g) ? g : Guid.Empty;

            var command = new UpdateOrgUnitCommand
            {
                OrgUnitId   = _editingUnit.OrgUnitId,
                OrgUnitCode = _editCode.Trim().ToUpper(),
                OrgUnitName = _editName.Trim(),
                UpdatedBy   = actorId
            };

            await OrgStructureService.UpdateOrgUnitAsync(command);
            _showEditPanel = false;
            _editingUnit   = null;
            await SelectLegalEntityAsync(SessionState.SelectedLegalEntityId!.Value);
        }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _editSaving = false; }
    }

    private string LookupLabel(string tableName, int id)
        => LookupCache.GetAll(tableName).FirstOrDefault(e => e.Id == id)?.Label ?? id.ToString();

    private string LookupCode(string tableName, int id)
        => LookupCache.GetCode(tableName, id).ToLower();
}

<style>
    .page-container { padding: var(--space-6); }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-4);
    }

    .page-title {
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-semibold);
        color: var(--aw-navy);
        margin: 0;
    }

    .view-toggle {
        display: flex;
        gap: 0;
        border: 1px solid #E5E7EB;
        border-radius: var(--radius-md);
        overflow: hidden;
        margin-bottom: var(--space-6);
        width: fit-content;
    }

    .toggle-btn {
        padding: var(--space-2) var(--space-4);
        background: white;
        border: none;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: #6B7280;
        cursor: pointer;
    }

    .toggle-btn.active {
        background: var(--aw-teal);
        color: white;
    }

    .locations-section {
        margin-top: var(--space-4);
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: var(--space-4) var(--space-5);
    }

    .locations-title {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
        color: #6B7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 var(--space-3) 0;
    }

    .locations-list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .location-chip {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        background: #F0F9FF;
        border: 1px solid #BAE6FD;
        border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-3);
    }

    .location-chip-name {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: var(--aw-navy);
    }

    .location-chip-code {
        font-size: var(--font-size-xs, 0.75rem);
        color: #6B7280;
        font-family: monospace;
    }

    .org-tree-container, .grid-container {
