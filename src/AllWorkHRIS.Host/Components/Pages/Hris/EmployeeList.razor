@page "/hris/employees"
@layout HrisShell
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "HrisViewer,HrisAdmin,HrisOperator")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using AllWorkHRIS.Core.Temporal
@using AllWorkHRIS.Host.Hris.Services
@using AllWorkHRIS.Host.Hris.Queries
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@inject IEmploymentService  EmploymentService
@inject ITemporalContext     TemporalContext
@inject IHrisSessionState   SessionState

<PageTitle>Employees — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Employees</h2>
        <AuthorizeView Roles="HrisAdmin">
            <Authorized>
                <button class="btn-primary" @onclick="OpenHirePanel">+ Add Employee</button>
            </Authorized>
        </AuthorizeView>
    </div>

    @* Stat cards *@
    <div class="stat-cards">
        <div class="stat-card stat-card--active">
            <span class="stat-label">Active</span>
            <span class="stat-value">@_stats.Active</span>
        </div>
        <div class="stat-card stat-card--leave">
            <span class="stat-label">On Leave</span>
            <span class="stat-value">@_stats.OnLeave</span>
        </div>
        <div class="stat-card stat-card--contractor">
            <span class="stat-label">Contractors</span>
            <span class="stat-value">@_stats.Contractors</span>
        </div>
        <div class="stat-card stat-card--dept">
            <span class="stat-label">Departments</span>
            <span class="stat-value">@_stats.Departments</span>
        </div>
    </div>

    @* Filter bar *@
    <div class="filter-bar">
        <SfDropDownList TValue="string" TItem="FilterOption"
                        Placeholder="All Statuses"
                        DataSource="@_statusOptions"
                        @bind-Value="_statusFilter"
                        Width="160px">
            <DropDownListFieldSettings Value="Value" Text="Label" />
            <DropDownListEvents TValue="string" TItem="FilterOption"
                                ValueChange="OnStatusChanged" />
        </SfDropDownList>

        <SfDropDownList TValue="string" TItem="FilterOption"
                        Placeholder="All Types"
                        DataSource="@_typeOptions"
                        @bind-Value="_typeFilter"
                        Width="160px">
            <DropDownListFieldSettings Value="Value" Text="Label" />
            <DropDownListEvents TValue="string" TItem="FilterOption"
                                ValueChange="OnTypeChanged" />
        </SfDropDownList>

        <SfTextBox Placeholder="Search name or Emp #…"
                   @bind-Value="_searchTerm"
                   Width="240px"
                   Input="OnSearchInput" />
    </div>

    @* Employee grid *@
    <div class="grid-container">
        @if (_loading)
        {
            <p class="loading-text">Loading employees…</p>
        }
        else if (_allEmployees.Count == 0)
        {
            <div class="empty-state">
                <p>No employees found.</p>
                <AuthorizeView Roles="HrisAdmin">
                    <Authorized>
                        <p>Click <strong>+ Add Employee</strong> to hire the first employee.</p>
                    </Authorized>
                </AuthorizeView>
            </div>
        }
        else
        {
            <SfGrid TValue="EmploymentListItem" DataSource="@_employees"
                    AllowSorting="true" AllowPaging="true"
                    CssClass="e-gridhover">
                <GridPageSettings PageSize="25" />
                <GridColumns>
                    <GridColumn Field="LegalLastName" HeaderText="Employee" AllowSorting="true">
                        <Template>
                            @{ var emp = (EmploymentListItem)context; }
                            <div class="employee-name-cell">
                                <span class="avatar @(emp.EmploymentType == "CONTRACTOR" ? "avatar--contractor" : "")">@GetInitials(emp)</span>
                                <div class="employee-name-info">
                                    <a class="employee-link" href="/hris/employees/@emp.EmploymentId">@emp.LegalFirstName @emp.LegalLastName</a>
                                    @if (emp.EmploymentType == "CONTRACTOR")
                                    {
                                        <span class="type-badge type-badge--contractor">Contractor</span>
                                    }
                                </div>
                            </div>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="EmployeeNumber" HeaderText="Emp #" Width="120" />
                    <GridColumn Field="JobTitle" HeaderText="Job Title" />
                    <GridColumn Field="DepartmentName" HeaderText="Department" />
                    <GridColumn Field="LocationName" HeaderText="Location" />
                    <GridColumn Field="EmploymentStatus" HeaderText="Status" Width="110">
                        <Template>
                            @{ var emp = (EmploymentListItem)context; }
                            <span class="status-badge status-@emp.EmploymentStatus.ToLower()">@emp.EmploymentStatus</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="EmploymentStartDate" HeaderText="Start Date" Width="120">
                        <Template>
                            @(((EmploymentListItem)context).EmploymentStartDate.ToString("yyyy-MM-dd"))
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>

</div>

@if (_showHirePanel)
{
    <HireEmployeePanel OnHireComplete="OnHireComplete" OnCancel="CloseHirePanel"
                       LegalEntityId="@(SessionState.SelectedLegalEntityId ?? Guid.Empty)" />
}

@code {
    private record FilterOption(string Value, string Label);

    private bool _loading       = true;
    private bool _showHirePanel = false;

    private List<EmploymentListItem> _allEmployees = [];
    private List<EmploymentListItem> _employees    = [];
    private EmployeeStatCards        _stats        = new();

    private string _statusFilter = "";
    private string _typeFilter   = "";
    private string _searchTerm   = "";

    private readonly List<FilterOption> _statusOptions =
    [
        new("", "All Statuses"),
        new("ACTIVE",     "Active"),
        new("ON_LEAVE",   "On Leave"),
        new("SUSPENDED",  "Suspended"),
        new("TERMINATED", "Terminated"),
    ];

    private readonly List<FilterOption> _typeOptions =
    [
        new("", "All Types"),
        new("EMPLOYEE",   "Employee"),
        new("CONTRACTOR", "Contractor"),
    ];

    protected override async Task OnInitializedAsync()
    {
        SessionState.OnChanged += HandleEntityChanged;
        await LoadDataAsync();
    }

    private void HandleEntityChanged()
        => InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            var entityId = SessionState.SelectedLegalEntityId;
            var result = await EmploymentService.GetPagedListAsync(new EmployeeListQuery
            {
                LegalEntityId = entityId,
                PageSize      = 2000,
                Page          = 1,
                SortColumn    = "legal_last_name",
                SortAscending = true
            });
            _allEmployees = result.Items.ToList();
            ApplyFilters();

            _stats = await EmploymentService.GetStatCardsAsync(
                DateOnly.FromDateTime(TemporalContext.GetOperativeDate()),
                entityId);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        var search = _searchTerm.Trim();
        _employees = _allEmployees
            .Where(e => string.IsNullOrEmpty(_statusFilter)
                     || e.EmploymentStatus.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase))
            .Where(e => string.IsNullOrEmpty(_typeFilter)
                     || e.EmploymentType.Equals(_typeFilter, StringComparison.OrdinalIgnoreCase))
            .Where(e => string.IsNullOrEmpty(search)
                     || e.LegalFirstName.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || e.LegalLastName.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || e.EmployeeNumber.Contains(search, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void OnStatusChanged(ChangeEventArgs<string, FilterOption> args)
    {
        _statusFilter = args.Value ?? "";
        ApplyFilters();
    }

    private void OnTypeChanged(ChangeEventArgs<string, FilterOption> args)
    {
        _typeFilter = args.Value ?? "";
        ApplyFilters();
    }

    private void OnSearchInput(InputEventArgs args)
    {
        _searchTerm = args.Value ?? "";
        ApplyFilters();
    }

    private void OpenHirePanel()
    {
        _showHirePanel = true;
        StateHasChanged();
    }
    private void CloseHirePanel() => _showHirePanel = false;

    private async Task OnHireComplete()
    {
        _showHirePanel = false;
        await LoadDataAsync();
    }

    private static string GetInitials(EmploymentListItem emp) =>
        $"{emp.LegalFirstName.FirstOrDefault()}{emp.LegalLastName.FirstOrDefault()}".ToUpper();

    public void Dispose()
        => SessionState.OnChanged -= HandleEntityChanged;
}

<style>
    .stat-card--active     { border-top: 4px solid #10B981; }
    .stat-card--leave      { border-top: 4px solid #F59E0B; }
    .stat-card--contractor { border-top: 4px solid #3B82F6; }
    .stat-card--dept       { border-top: 4px solid #8B5CF6; }

    .filter-bar {
        display: flex;
        gap: var(--space-3);
        margin-bottom: var(--space-4);
        align-items: center;
    }

    .grid-container {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .loading-text {
        padding: var(--space-6);
        color: #6B7280;
        text-align: center;
    }

    .employee-name-cell {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .employee-name-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .employee-link {
        font-weight: var(--font-weight-medium);
        color: var(--aw-navy);
    }

    .employee-link:hover {
        color: var(--aw-teal);
        text-decoration: none;
    }

    .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background-color: var(--aw-teal);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
        flex-shrink: 0;
    }

    .avatar--contractor { background-color: #3B82F6; }

    .type-badge {
        display: inline-block;
        padding: 1px 6px;
        border-radius: var(--radius-sm);
        font-size: 0.7rem;
        font-weight: var(--font-weight-medium);
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .type-badge--contractor { background: #DBEAFE; color: #1D4ED8; }

    .status-badge {
        padding: 2px var(--space-2);
        border-radius: var(--radius-sm);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
    }

    .status-active     { background: #D1FAE5; color: #065F46; }
    .status-on_leave   { background: #FEF3C7; color: #92400E; }
    .status-suspended  { background: #FEE2E2; color: #991B1B; }
    .status-terminated { background: #F3F4F6; color: #6B7280; }
</style>
