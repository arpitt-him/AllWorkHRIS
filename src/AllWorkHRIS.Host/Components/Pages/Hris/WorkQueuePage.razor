@page "/hris/workqueue"
@layout HrisShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "HrisAdmin,Manager")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using AllWorkHRIS.Host.Hris.Commands
@using AllWorkHRIS.Host.Hris.Domain
@using AllWorkHRIS.Host.Hris.Services
@using AllWorkHRIS.Core.Lookups
@using AllWorkHRIS.Core.Temporal
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Calendars
@implements IDisposable
@inject IWorkQueueService  WorkQueueService
@inject ILeaveService      LeaveService
@inject IPersonService     PersonService
@inject IHrisSessionState  SessionState
@inject ILookupCache       LookupCache
@inject ITemporalContext   TemporalContext

<PageTitle>Work Queue — AllWork HRIS</PageTitle>

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Work Queue</h2>
        <button class="btn-secondary btn-sm" @onclick="LoadAsync">Refresh</button>
    </div>

    @* ── STAT CARDS ── *@
    <div class="stat-cards">
        <div class="stat-card stat-card--open">
            <span class="stat-label">Open Items</span>
            <span class="stat-value">@_items.Count</span>
        </div>
        <div class="stat-card stat-card--urgent">
            <span class="stat-label">High / Hold Priority</span>
            <span class="stat-value">@_items.Count(i => i.Priority is WorkQueuePriority.High or WorkQueuePriority.Hold)</span>
        </div>
    </div>

    @if (!_loading && _items.Count > 0)
    {
        <div class="filter-row" style="margin-top: var(--space-2); margin-bottom: var(--space-6);">
            <SfTextBox Placeholder="Filter by employee name…"
                       @bind-Value="_nameFilter"
                       Width="220px" />
            <span class="filter-label">Due from</span>
            <SfDatePicker TValue="DateOnly?" @bind-Value="_dateFrom" Width="150px" Placeholder="MM/DD/YYYY" />
            <span class="filter-label">to</span>
            <SfDatePicker TValue="DateOnly?" @bind-Value="_dateTo" Width="150px" Placeholder="MM/DD/YYYY" />
            @if (!string.IsNullOrWhiteSpace(_nameFilter) || _dateFrom.HasValue || _dateTo.HasValue)
            {
                <button class="btn-secondary btn-sm" @onclick="ClearFilters">Clear</button>
            }
        </div>
    }

    @if (_loading)
    {
        <p class="loading-text">Loading work queue...</p>
    }
    else if (_items.Count == 0)
    {
        <div class="empty-state">
            <p>No open items — all caught up.</p>
        </div>
    }
    else
    {
        @* ── LEAVE APPROVALS ── *@
        @if (LeaveItems.Any())
        {
            <h3 class="section-heading" style="margin-top: var(--space-2);">Leave Approvals</h3>
            <div class="grid-container">
                <SfGrid TValue="WorkQueueItem"
                        DataSource="@LeaveItems.OrderByDescending(i => PriorityRank(i.Priority)).ToList()"
                        AllowSorting="true" CssClass="e-gridhover">
                    <GridColumns>
                        <GridColumn Field="Title" HeaderText="Title" />
                        <GridColumn Field="EmploymentId" HeaderText="Employee" Width="180">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                @if (item.EmploymentId.HasValue)
                                {
                                    <a href="/hris/employees/@item.EmploymentId">@EmployeeName(item.EmploymentId)</a>
                                }
                                else { <text>—</text> }
                            </Template>
                        </GridColumn>
                        <GridColumn Field="Priority" HeaderText="Priority" Width="100">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="priority-badge priority-@item.Priority.ToLower()">@item.Priority</span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="CreatedAt" HeaderText="Created" Width="120">
                            <Template>@(((WorkQueueItem)context).CreatedAt.ToString("yyyy-MM-dd"))</Template>
                        </GridColumn>
                        <GridColumn Field="DueDate" HeaderText="Due" Width="120">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="@DueClass(item.DueDate)">@(item.DueDate?.ToString("yyyy-MM-dd") ?? "—")</span>
                            </Template>
                        </GridColumn>
                        <GridColumn HeaderText="" Width="220" AllowSorting="false">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                @if (_approvingId == item.WorkQueueItemId)
                                {
                                    <div class="inline-confirm">
                                        <span class="confirm-text">Confirm approval?</span>
                                        <button class="btn-primary btn-xs" @onclick="() => ConfirmApproveAsync(item)" disabled="@_actioning">Yes</button>
                                        <button class="btn-secondary btn-xs" @onclick="CancelAction">No</button>
                                    </div>
                                    @if (_actionError is not null) { <p class="form-error" style="margin:0">@_actionError</p> }
                                }
                                else if (_denyingId == item.WorkQueueItemId)
                                {
                                    <div class="inline-confirm">
                                        <SfTextBox @bind-Value="_denyReason" Placeholder="Reason…" Width="180px" />
                                        <button class="btn-danger btn-xs" @onclick="() => ConfirmDenyAsync(item)" disabled="@_actioning">Deny</button>
                                        <button class="btn-secondary btn-xs" @onclick="CancelAction">Cancel</button>
                                    </div>
                                    @if (_actionError is not null) { <p class="form-error" style="margin:0">@_actionError</p> }
                                }
                                else
                                {
                                    <button class="btn-primary btn-xs" @onclick="() => StartApprove(item.WorkQueueItemId)">Approve</button>
                                    <button class="btn-danger btn-xs" @onclick="() => StartDeny(item.WorkQueueItemId)">Deny</button>
                                }
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            </div>
        }

        @* ── DOCUMENT ALERTS ── *@
        @if (DocItems.Any())
        {
            <h3 class="section-heading" style="margin-top: var(--space-8);">Document Alerts</h3>
            <div class="grid-container">
                <SfGrid TValue="WorkQueueItem"
                        DataSource="@DocItems.OrderByDescending(i => PriorityRank(i.Priority)).ToList()"
                        AllowSorting="true" CssClass="e-gridhover">
                    <GridColumns>
                        <GridColumn Field="Title" HeaderText="Alert" />
                        <GridColumn Field="EmploymentId" HeaderText="Employee" Width="180">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                @if (item.EmploymentId.HasValue)
                                {
                                    <a href="/hris/employees/@item.EmploymentId">@EmployeeName(item.EmploymentId)</a>
                                }
                                else { <text>—</text> }
                            </Template>
                        </GridColumn>
                        <GridColumn Field="Description" HeaderText="Description">
                            <Template>@(((WorkQueueItem)context).Description ?? "—")</Template>
                        </GridColumn>
                        <GridColumn Field="Priority" HeaderText="Priority" Width="100">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="priority-badge priority-@item.Priority.ToLower()">@item.Priority</span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="DueDate" HeaderText="Due / Expires" Width="130">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="@DueClass(item.DueDate)">@(item.DueDate?.ToString("yyyy-MM-dd") ?? "—")</span>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            </div>
        }

        @* ── ONBOARDING TASKS ── *@
        @if (OnboardingItems.Any())
        {
            <h3 class="section-heading" style="margin-top: var(--space-8);">Onboarding Tasks</h3>
            <div class="grid-container">
                <SfGrid TValue="WorkQueueItem"
                        DataSource="@OnboardingItems.OrderBy(i => i.DueDate).ToList()"
                        AllowSorting="true" CssClass="e-gridhover">
                    <GridColumns>
                        <GridColumn Field="Title" HeaderText="Task">
                            <Template>@OnboardingTaskLabel(((WorkQueueItem)context).Title)</Template>
                        </GridColumn>
                        <GridColumn Field="EmploymentId" HeaderText="Employee" Width="180">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                @if (item.EmploymentId.HasValue)
                                {
                                    <a href="/hris/employees/@item.EmploymentId">@EmployeeName(item.EmploymentId)</a>
                                }
                                else { <text>—</text> }
                            </Template>
                        </GridColumn>
                        <GridColumn Field="Priority" HeaderText="Priority" Width="100">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="priority-badge priority-@item.Priority.ToLower()">@item.Priority</span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="DueDate" HeaderText="Due" Width="120">
                            <Template>
                                @{ var item = (WorkQueueItem)context; }
                                <span class="@DueClass(item.DueDate)">@(item.DueDate?.ToString("yyyy-MM-dd") ?? "—")</span>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            </div>
        }
    }

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool                       _loading      = true;
    private List<WorkQueueItem>        _items        = [];
    private Dictionary<Guid, string>   _employeeNames = [];
    private string    _nameFilter = "";
    private DateOnly? _dateFrom;
    private DateOnly? _dateTo;

    private List<WorkQueueItem> LeaveItems =>
        _items.Where(i => i.ItemType == WorkQueueItemTypes.LeaveApproval && MatchesFilter(i)).ToList();

    private List<WorkQueueItem> DocItems =>
        _items.Where(i => i.ItemType is WorkQueueItemTypes.DocExpired or WorkQueueItemTypes.DocExpiring30
                       or WorkQueueItemTypes.DocExpiring90 && MatchesFilter(i)).ToList();

    private List<WorkQueueItem> OnboardingItems =>
        _items.Where(i => i.ItemType == WorkQueueItemTypes.OnboardingTask && MatchesFilter(i)).ToList();

    private bool MatchesFilter(WorkQueueItem item)
    {
        if (!string.IsNullOrWhiteSpace(_nameFilter))
        {
            var name = EmployeeName(item.EmploymentId);
            if (!name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase)) return false;
        }
        if (_dateFrom.HasValue && item.DueDate.HasValue && item.DueDate < _dateFrom) return false;
        if (_dateTo.HasValue   && item.DueDate.HasValue && item.DueDate > _dateTo)   return false;
        return true;
    }

    private void ClearFilters()
    {
        _nameFilter = "";
        _dateFrom   = null;
        _dateTo     = null;
    }

    private string EmployeeName(Guid? employmentId)
    {
        if (employmentId is null) return "—";
        return _employeeNames.TryGetValue(employmentId.Value, out var name) ? name : "—";
    }

    // Action state
    private Guid?   _approvingId;
    private Guid?   _denyingId;
    private string  _denyReason  = "";
    private bool    _actioning   = false;
    private string? _actionError;

    protected override async Task OnInitializedAsync()
    {
        SessionState.OnChanged += HandleEntityChanged;
        await LoadAsync();
    }

    private void HandleEntityChanged()
        => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });

    public void Dispose() => SessionState.OnChanged -= HandleEntityChanged;

    private async Task LoadAsync()
    {
        _loading = true;
        _items   = [];
        try
        {
            var state = await AuthStateTask;
            var roles = state.User.Claims
                .Where(c => c.Type == "roles")
                .Select(c => c.Value)
                .ToHashSet();

            var entityId = SessionState.SelectedLegalEntityId;

            var tasks = new List<Task<IEnumerable<WorkQueueItem>>>();
            if (roles.Contains("HrisAdmin")) tasks.Add(WorkQueueService.GetOpenByRoleAsync("HrisAdmin", entityId));
            if (roles.Contains("Manager"))   tasks.Add(WorkQueueService.GetOpenByRoleAsync("Manager",   entityId));

            var results = await Task.WhenAll(tasks);
            _items = results.SelectMany(r => r)
                            .DistinctBy(i => i.WorkQueueItemId)
                            .OrderByDescending(i => PriorityRank(i.Priority))
                            .ThenBy(i => i.CreatedAt)
                            .ToList();

            var employmentIds = _items
                .Where(i => i.EmploymentId.HasValue)
                .Select(i => i.EmploymentId!.Value)
                .Distinct();
            _employeeNames = await PersonService.GetNamesByEmploymentIdsAsync(employmentIds);
        }
        finally { _loading = false; }
    }

    private void StartApprove(Guid itemId)
    {
        _approvingId = itemId;
        _denyingId   = null;
        _actionError = null;
    }

    private void StartDeny(Guid itemId)
    {
        _denyingId   = itemId;
        _approvingId = null;
        _denyReason  = "";
        _actionError = null;
    }

    private void CancelAction()
    {
        _approvingId = null;
        _denyingId   = null;
        _actionError = null;
    }

    private async Task ConfirmApproveAsync(WorkQueueItem item)
    {
        _actioning   = true;
        _actionError = null;
        try
        {
            await LeaveService.ApproveLeaveRequestAsync(new ApproveLeaveRequestCommand
            {
                LeaveRequestId = item.ReferenceId,
                ApprovedBy     = await GetCurrentUserIdAsync()
            });
            await WorkQueueService.ResolveByReferenceAsync(item.ReferenceId, await GetCurrentUserIdAsync());
            _approvingId = null;
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = ex.Message; }
        finally { _actioning = false; }
    }

    private async Task ConfirmDenyAsync(WorkQueueItem item)
    {
        if (string.IsNullOrWhiteSpace(_denyReason))
        {
            _actionError = "Denial reason is required.";
            return;
        }
        _actioning   = true;
        _actionError = null;
        try
        {
            await LeaveService.DenyLeaveRequestAsync(new DenyLeaveRequestCommand
            {
                LeaveRequestId = item.ReferenceId,
                DeniedBy       = await GetCurrentUserIdAsync(),
                DenialReason   = _denyReason
            });
            await WorkQueueService.ResolveByReferenceAsync(item.ReferenceId, await GetCurrentUserIdAsync());
            _denyingId = null;
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = ex.Message; }
        finally { _actioning = false; }
    }

    private async Task<Guid> GetCurrentUserIdAsync()
    {
        var state = await AuthStateTask;
        var sub   = state.User.FindFirst("sub")?.Value;
        return Guid.TryParse(sub, out var id) ? id : Guid.Empty;
    }

    private string OnboardingTaskLabel(string title)
    {
        const string prefix = "Onboarding task: ";
        if (!title.StartsWith(prefix)) return title;
        var code = title[prefix.Length..];
        try { return "Onboarding: " + LookupCache.Get(LookupTables.OnboardingTaskType, code).Label; }
        catch { return title; }
    }

    private static int PriorityRank(string priority) => priority switch
    {
        WorkQueuePriority.Hold   => 3,
        WorkQueuePriority.High   => 2,
        WorkQueuePriority.Normal => 1,
        _                        => 0
    };

    private string DueClass(DateOnly? due)
    {
        if (due is null) return "";
        var today = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
        if (due <= today)            return "cell-overdue";
        if (due <= today.AddDays(7)) return "cell-expiring";
        return "";
    }
}

<style>
    .page-container { padding: var(--space-6); }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-6);
    }

    .page-title {
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-semibold);
        color: var(--aw-navy);
        margin: 0;
    }

    .section-heading {
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-semibold);
        color: var(--aw-navy);
        margin: 0 0 var(--space-3) 0;
    }

    /* ── Stat cards ── */
    .stat-cards { display: flex; gap: var(--space-4); margin-bottom: var(--space-6); }

    .stat-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: var(--space-4) var(--space-6);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        min-width: 140px;
    }

    .stat-card--open   { border-top: 4px solid var(--aw-teal); }
    .stat-card--urgent { border-top: 4px solid var(--color-danger); }

    .stat-label { font-size: var(--font-size-sm); color: #6B7280; font-weight: var(--font-weight-medium); }
    .stat-value { font-size: 1.5rem; font-weight: var(--font-weight-semibold); color: var(--aw-navy); }

    /* ── Table ── */
    .grid-container {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: var(--space-4);
    }

    .data-table { width: 100%; border-collapse: collapse; font-size: var(--font-size-sm); }

    .data-table th {
        background: #F9FAFB;
        padding: var(--space-3) var(--space-4);
        text-align: left;
        font-weight: var(--font-weight-medium);
        color: #6B7280;
        border-bottom: 1px solid #E5E7EB;
        white-space: nowrap;
    }

    .data-table td {
        padding: var(--space-3) var(--space-4);
        border-bottom: 1px solid #F3F4F6;
        color: var(--aw-navy);
        vertical-align: middle;
    }

    .data-table tr:last-child td { border-bottom: none; }
    .data-table tbody tr:hover td { background: #F9FAFB; }

    /* ── Priority badges ── */
    .priority-badge {
        display: inline-block;
        padding: 2px var(--space-2);
        border-radius: var(--radius-sm);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
    }

    .priority-normal { background: #F3F4F6; color: #6B7280; }
    .priority-high   { background: #FEF3C7; color: #92400E; }
    .priority-hold   { background: #FEE2E2; color: #991B1B; }

    /* ── Cell states ── */
    .cell-overdue  { color: #DC2626; font-weight: var(--font-weight-medium); }
    .cell-expiring { color: #92400E; font-weight: var(--font-weight-medium); }

    /* ── Actions ── */
    .action-cell { white-space: nowrap; }

    .inline-confirm {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        flex-wrap: wrap;
    }

    .confirm-text { font-size: var(--font-size-sm); color: var(--aw-navy); }

    .form-input-sm {
        padding: var(--space-1) var(--space-2);
        border: 1px solid #D1D5DB;
        border-radius: var(--radius-md);
        font-size: var(--font-size-sm);
        width: 180px;
    }

    .form-error { color: #DC2626; font-size: var(--font-size-sm); margin: 0; padding: var(--space-2) var(--space-4); }

    /* ── Misc ── */
    .loading-text { padding: var(--space-6); color: #6B7280; text-align: center; }

    .empty-state {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: var(--space-10);
        text-align: center;
        color: #6B7280;
    }

    .filter-row { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
    .filter-input { padding: var(--space-2) var(--space-3); border: 1px solid #D1D5DB; border-radius: var(--radius-md); font-size: var(--font-size-sm); width: 220px; }
    .filter-date  { padding: var(--space-2) var(--space-3); border: 1px solid #D1D5DB; border-radius: var(--radius-md); font-size: var(--font-size-sm); }
    .filter-label { font-size: var(--font-size-sm); color: #6B7280; white-space: nowrap; }

    .link { color: var(--aw-teal); text-decoration: none; font-weight: var(--font-weight-medium); }
    .link:hover { text-decoration: underline; }

    /* ── Buttons ── */
    .btn-primary {
        background: var(--aw-teal); color: white; border: none;
        border-radius: var(--radius-md); padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); cursor: pointer;
    }
    .btn-primary:hover:not(:disabled) { opacity: 0.9; }
    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-secondary {
        background: white; color: var(--aw-navy); border: 1px solid #D1D5DB;
        border-radius: var(--radius-md); padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); cursor: pointer;
    }
    .btn-secondary:hover { background: #F9FAFB; }

    .btn-danger {
        background: white; color: #DC2626; border: 1px solid #FCA5A5;
        border-radius: var(--radius-md); padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); cursor: pointer;
    }
    .btn-danger:hover { background: #FEF2F2; }

    .btn-sm  { padding: var(--space-1) var(--space-2) !important; }
    .btn-xs  { padding: 2px var(--space-2) !important; font-size: var(--font-size-sm) !important; }
</style>
