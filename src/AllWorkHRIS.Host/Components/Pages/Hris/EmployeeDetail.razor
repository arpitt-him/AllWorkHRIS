    // ---- HrisOperator: change request (approval required) ----

    private void BeginChangeRequest()
    {
        if (_person is null) return;
        _crFirstName  = _person.LegalFirstName;
        _crMiddleName = _person.LegalMiddleName ?? "";
        _crLastName   = _person.LegalLastName;
        _crSuffix     = _person.NameSuffix ?? "";
        _crDob        = _person.DateOfBirth.ToDateTime(TimeOnly.MinValue);
        _crNI         = "";   // never pre-fill NI from the live record
        _crNIType     = _person.NationalIdentifierType ?? "";
        _crError      = null;
        _crSuccess    = null;
        _crEditing    = true;
    }

    private void CancelChangeRequest() { _crEditing = false; _crError = null; }

    private async Task SubmitChangeRequestsAsync()
    {
        if (_person is null) return;
        _crSaving = true;
        _crError  = null;
        try
        {
            var requestor  = await GetCurrentUserIdAsync();
            int submitted  = 0;

            // Legal name — submit if any name field changed
            var nameChanged = _crFirstName.Trim()  != _person.LegalFirstName
                           || (_crMiddleName.Trim() != (_person.LegalMiddleName ?? ""))
                           || _crLastName.Trim()   != _person.LegalLastName
                           || (_crSuffix.Trim()    != (_person.NameSuffix ?? ""));
            if (nameChanged)
            {
                if (string.IsNullOrWhiteSpace(_crFirstName) || string.IsNullOrWhiteSpace(_crLastName))
                { _crError = "First and last name are required when requesting a legal name change."; return; }

                var currentJson   = System.Text.Json.JsonSerializer.Serialize(new { legalFirstName = _person.LegalFirstName, legalMiddleName = _person.LegalMiddleName, legalLastName = _person.LegalLastName, nameSuffix = _person.NameSuffix });
                var requestedJson = System.Text.Json.JsonSerializer.Serialize(new { legalFirstName = _crFirstName.Trim(), legalMiddleName = string.IsNullOrWhiteSpace(_crMiddleName) ? (string?)null : _crMiddleName.Trim(), legalLastName = _crLastName.Trim(), nameSuffix = string.IsNullOrWhiteSpace(_crSuffix) ? (string?)null : _crSuffix.Trim() });
                await PersonService.SubmitChangeRequestAsync(new SubmitPersonChangeRequestCommand { PersonId = _person.PersonId, ChangeType = PersonChangeType.LegalName, CurrentValueJson = currentJson, RequestedValueJson = requestedJson, RequestedBy = requestor });
                submitted++;
            }

            // Date of birth — submit if changed
            var dobChanged = DateOnly.FromDateTime(_crDob) != _person.DateOfBirth;
            if (dobChanged)
            {
                var currentJson   = System.Text.Json.JsonSerializer.Serialize(new { dateOfBirth = _person.DateOfBirth.ToString("yyyy-MM-dd") });
                var requestedJson = System.Text.Json.JsonSerializer.Serialize(new { dateOfBirth = DateOnly.FromDateTime(_crDob).ToString("yyyy-MM-dd") });
                await PersonService.SubmitChangeRequestAsync(new SubmitPersonChangeRequestCommand { PersonId = _person.PersonId, ChangeType = PersonChangeType.DateOfBirth, CurrentValueJson = currentJson, RequestedValueJson = requestedJson, RequestedBy = requestor });
                submitted++;
            }

            // National identifier — submit if a new value was entered
            if (!string.IsNullOrWhiteSpace(_crNI))
            {
                var currentJson   = System.Text.Json.JsonSerializer.Serialize(new { nationalIdentifier = (string?)null, nationalIdentifierType = _person.NationalIdentifierType });
                var requestedJson = System.Text.Json.JsonSerializer.Serialize(new { nationalIdentifier = _crNI.Trim(), nationalIdentifierType = string.IsNullOrWhiteSpace(_crNIType) ? _person.NationalIdentifierType : _crNIType.Trim() });
                await PersonService.SubmitChangeRequestAsync(new SubmitPersonChangeRequestCommand { PersonId = _person.PersonId, ChangeType = PersonChangeType.NationalIdentifier, CurrentValueJson = currentJson, RequestedValueJson = requestedJson, RequestedBy = requestor });
                submitted++;
            }

            if (submitted == 0)
            { _crError = "No changes detected. Adjust at least one field before submitting."; return; }

            _pendingRequests = await PersonService.GetPendingChangeRequestsAsync(_person.PersonId);
            _crEditing       = false;
            _crSuccess       = $"{submitted} change request{(submitted > 1 ? "s" : "")} submitted for approval.";
        }
        catch (Exception ex) { _crError = ex.Message; }
        finally { _crSaving = false; }
    }

    // ---- HrisAdmin: approve / reject ----

    private async Task ApproveRequestAsync(Guid requestId)
    {
        _reviewSaving = true;
        _reviewError  = null;
        try
        {
            await PersonService.ApproveChangeRequestAsync(new ReviewPersonChangeRequestCommand { PersonChangeRequestId = requestId, ReviewedBy = await GetCurrentUserIdAsync() });
            // Reload person to reflect approved changes
            _person          = await PersonService.GetByEmploymentIdAsync(EmploymentId);
            _pendingRequests = await PersonService.GetPendingChangeRequestsAsync(_person!.PersonId);
            if (_person is not null)
            {
                _pageTitle = $"{_person.LegalFirstName} {_person.LegalLastName}";
                _initials  = $"{_person.LegalFirstName.FirstOrDefault()}{_person.LegalLastName.FirstOrDefault()}".ToUpper();
            }
        }
        catch (Exception ex) { _reviewError = ex.Message; }
        finally { _reviewSaving = false; }
    }

    private void BeginReject(Guid requestId)  { _rejectingId = requestId; _rejectNote = ""; _reviewError = null; }
