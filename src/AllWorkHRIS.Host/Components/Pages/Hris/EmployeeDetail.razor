                PostalCode     = cmd.PostalCode,
                CountryCode    = cmd.CountryCode,
                PhonePrimary   = cmd.PhonePrimary,
                PhoneSecondary = cmd.PhoneSecondary,
                EmailPersonal  = cmd.EmailPersonal,
            };
            _addressEditing = false;
            _addressSuccess = "Address updated.";
        }
        catch (Exception ex)
        {
            _addressError = ex.Message;
        }
        finally { _addressSaving = false; }
    }

    // ---- Action panel helpers ----

    private void CancelAction()
    {
        _actionMode    = ActionMode.None;
        _compError     = null;
        _txfrError     = null;
        _mgrError      = null;
    }

    // ---- Change Compensation ----

    private void BeginChangeCompensation()
    {
        _compNewRateTypeId = _compensation?.RateTypeId  ?? 0;
        _compNewBaseRate   = _compensation?.BaseRate    ?? 0m;
        _compNewFreqId     = _compensation?.PayFrequencyId ?? 0;
        _compEffectiveDt   = DateTime.Today;
        _compReasonCode    = "";
        _compError         = null;
        _actionMode        = ActionMode.ChangeCompensation;
    }

    private async Task SaveChangeCompensationAsync()
    {
        if (_compNewRateTypeId == 0 || _compNewFreqId == 0 || _compNewBaseRate <= 0 ||
            string.IsNullOrWhiteSpace(_compReasonCode))
        {
            _compError = "Rate type, base rate, pay frequency, and reason code are all required.";
            return;
        }
        _compSaving = true;
        _compError  = null;
        try
        {
            var cmd = new ChangeCompensationCommand
            {
                EmploymentId     = EmploymentId,
                RateTypeId       = _compNewRateTypeId,
                NewBaseRate      = _compNewBaseRate,
                PayFrequencyId   = _compNewFreqId,
                EffectiveDate    = DateOnly.FromDateTime(_compEffectiveDt),
                ChangeReasonCode = _compReasonCode.Trim(),
                InitiatedBy      = await GetCurrentUserIdAsync()
            };
            await CompensationService.ChangeCompensationAsync(cmd);
            _compensation = await CompensationService.GetCurrentRateAsync(
                EmploymentId, DateOnly.FromDateTime(TemporalContext.GetOperativeDate()));
            _actionMode = ActionMode.None;
        }
        catch (Exception ex) { _compError = ex.Message; }
        finally { _compSaving = false; }
    }

    // ---- Transfer ----

    private async Task BeginTransfer()
    {
        _txfrNewDeptId     = _employment?.PrimaryDepartmentId   ?? Guid.Empty;
        _txfrNewLocationId = _employment?.PrimaryWorkLocationId ?? Guid.Empty;
        _txfrNewJobId      = "";
        _txfrEffectiveDt   = DateTime.Today;
        _txfrReasonCode    = "";
        _txfrNotes         = null;
        _txfrError         = null;
        _actionMode        = ActionMode.Transfer;
        _txfrLoading       = true;
        try
        {
            var legalEntityId = _employment!.LegalEntityId;
            var deptTask      = OrgStructureService.GetDepartmentsAsync(legalEntityId);
            var locTask       = OrgStructureService.GetLocationsAsync(legalEntityId);
            var jobTask       = JobRepository.GetByLegalEntityAsync(legalEntityId);
            await Task.WhenAll(deptTask, locTask, jobTask);
            _txfrDepts     = await deptTask;
            _txfrLocations = await locTask;
            _txfrJobs      = await jobTask;
        }
        finally { _txfrLoading = false; }
    }

    private async Task SaveTransferAsync()
    {
        if (_txfrNewDeptId == Guid.Empty || _txfrNewLocationId == Guid.Empty ||
            string.IsNullOrWhiteSpace(_txfrReasonCode))
        {
            _txfrError = "New department, location, and reason code are all required.";
            return;
        }
        _txfrSaving = true;
        _txfrError  = null;
        try
        {
            var cmd = new TransferEmployeeCommand
            {
                EmploymentId    = EmploymentId,
                NewDepartmentId = _txfrNewDeptId,
                NewLocationId   = _txfrNewLocationId,
                NewJobId        = Guid.TryParse(_txfrNewJobId, out var jid) ? jid : (Guid?)null,
                EffectiveDate   = DateOnly.FromDateTime(_txfrEffectiveDt),
                ReasonCode      = _txfrReasonCode.Trim(),
                Notes           = string.IsNullOrWhiteSpace(_txfrNotes) ? null : _txfrNotes.Trim(),
                InitiatedBy     = await GetCurrentUserIdAsync()
            };
            await EmploymentService.TransferAsync(cmd);
            // Reload assignment data
            _assignmentLoaded = false;
            await LoadAssignmentAsync();
            _actionMode = ActionMode.None;
        }
        catch (Exception ex) { _txfrError = ex.Message; }
        finally { _txfrSaving = false; }
    }

    // ---- Change Manager ----

    private async Task BeginChangeManager()
    {
        _mgrNewManagerId = "";
        _mgrEffectiveDt  = DateTime.Today;
        _mgrNotes        = null;
        _mgrError        = null;
        _actionMode      = ActionMode.ChangeManager;
        _mgrLoading      = true;
        try
        {
            _mgrCandidates = (await EmploymentService.GetAllActiveListAsync(_employment!.LegalEntityId))
                .Where(e => e.EmploymentId != EmploymentId)
                .OrderBy(e => e.LegalLastName).ThenBy(e => e.LegalFirstName)
                .ToList();
        }
        finally { _mgrLoading = false; }
    }

    private async Task SaveChangeManagerAsync()
    {
        if (!Guid.TryParse(_mgrNewManagerId, out var newMgrId) || newMgrId == Guid.Empty)
        {
            _mgrError = "A new manager must be selected.";
            return;
        }
        _mgrSaving = true;
        _mgrError  = null;
        try
        {
            var cmd = new ChangeManagerCommand
            {
                EmploymentId           = EmploymentId,
                NewManagerEmploymentId = newMgrId,
                EffectiveDate          = DateOnly.FromDateTime(_mgrEffectiveDt),
                Notes                  = string.IsNullOrWhiteSpace(_mgrNotes) ? null : _mgrNotes.Trim(),
                InitiatedBy            = await GetCurrentUserIdAsync()
            };
            await EmploymentService.ChangeManagerAsync(cmd);
            // Reload employment to reflect new manager
            _employment = await EmploymentService.GetByIdAsync(EmploymentId);
            if (_assignmentLoaded)
            {
                _assignmentLoaded = false;
                await LoadAssignmentAsync();
            }
            _actionMode = ActionMode.None;
        }
        catch (Exception ex) { _mgrError = ex.Message; }
        finally { _mgrSaving = false; }
    }

    // ---- Place on Leave ----

    private async Task BeginPlaceOnLeave()
    {
        _showLeaveForm = true;
        if (!_leaveLoaded)
            await SwitchTabAsync("Leave");
        else
            _activeTab = "Leave";
    }

    // ---- Assignment lazy load ----

    private async Task LoadAssignmentAsync()
    {
        _assignmentLoading = true;
        try
        {
            _assignment = await AssignmentRepository.GetActiveByEmploymentIdAsync(EmploymentId);
            if (_assignment is not null)
            {
                var jobTask   = JobRepository.GetByIdAsync(_assignment.JobId);
                var deptTask  = OrgStructureService.GetOrgUnitByIdAsync(_assignment.DepartmentId);
                var locTask   = OrgStructureService.GetOrgUnitByIdAsync(_assignment.LocationId);
                await Task.WhenAll(jobTask, deptTask, locTask);
                _assignmentJob        = await jobTask;
                _assignmentDepartment = await deptTask;
                _assignmentLocation   = await locTask;

                if (_employment?.ManagerEmploymentId.HasValue == true)
                    _managerPerson = await PersonService.GetByEmploymentIdAsync(_employment.ManagerEmploymentId!.Value);
            }
            _assignmentLoaded = true;
        }
        finally { _assignmentLoading = false; }
    }

    private async Task LoadLeaveAsync()
    {
        _leaveLoading = true;
        try
        {
            _leaveBalances = await LeaveService.GetBalancesAsync(EmploymentId);
            _leaveHistory  = await LeaveService.GetHistoryAsync(EmploymentId);
            _leaveLoaded   = true;
        }
        finally { _leaveLoading = false; }
    }

    private async Task LoadDocumentsAsync()
    {
        if (_person is null) return;
        _documentsLoading = true;
        try
        {
            _documents       = await DocumentService.GetDocumentsAsync(_person.PersonId, EmploymentId);
            _documentsLoaded = true;
        }
        finally { _documentsLoading = false; }
    }

    private async Task LoadCommunityAsync()
    {
        if (_person is null) return;
        _communityLoading = true;
        try
        {
            var profile        = await SocialProfileRepo.GetAsync(_person.PersonId);
            _communityBio      = profile?.BioText ?? "";
            _communityHasPhoto = profile?.PhotoData is not null;
            _communityLoaded   = true;
        }
        finally { _communityLoading = false; }
    }

    private async Task SaveCommunityPhotoAsync()
    {
        if (_person is null) return;
        _communityError   = null;
        _communitySuccess = null;

        var fileSize = await JSRuntime.InvokeAsync<long>("allworkFiles.getFileSize", "community-photo-input");
        if (fileSize == 0)          { _communityError = "No file selected."; return; }
        if (fileSize > 2_097_152)   { _communityError = "Photo must be under 2 MB."; return; }

        var mimeType = await JSRuntime.InvokeAsync<string>("allworkFiles.getFileMime", "community-photo-input");
        if (!mimeType.StartsWith("image/")) { _communityError = "Please select an image file (JPEG, PNG, or WebP)."; return; }

        var base64 = await JSRuntime.InvokeAsync<string?>("allworkFiles.readBase64", "community-photo-input");
        if (string.IsNullOrEmpty(base64)) { _communityError = "Could not read the selected file."; return; }

        var bytes = Convert.FromBase64String(base64);
        if (bytes.Length > 2_097_152) { _communityError = "Photo must be under 2 MB."; return; }

        _communitySaving = true;
        try
        {
            await SocialProfileRepo.SavePhotoAsync(_person.PersonId, bytes, mimeType);
            _communityHasPhoto   = true;
            _communityShowUpload = false;
            _communityPhotoStamp = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            _communitySuccess    = "Photo updated.";
        }
        catch (Exception ex) { _communityError = ex.Message; }
        finally { _communitySaving = false; }
    }

    private async Task SaveCommunityBioAsync()
    {
        if (_person is null) return;
        _communityError   = null;
        _communitySuccess = null;
        if (_communityBio.Length > 1000) { _communityError = "Bio must be 1,000 characters or fewer."; return; }
        _communitySaving = true;
        try
        {
            await SocialProfileRepo.SaveBioAsync(_person.PersonId, _communityBio.Trim());
            _communitySuccess = "Profile saved.";
        }
        catch (Exception ex) { _communityError = ex.Message; }
        finally { _communitySaving = false; }
    }

    private async Task LoadOnboardingAsync()
    {
        _onboardingLoading = true;
        try
        {
            _onboardingPlan = await OnboardingService.GetPlanByEmploymentIdAsync(EmploymentId);
            if (_onboardingPlan is not null)
                _onboardingTasks = await OnboardingService.GetTasksByPlanIdAsync(_onboardingPlan.OnboardingPlanId);
            _onboardingLoaded = true;
        }
        finally { _onboardingLoading = false; }
    }

    // Leave form

    private void ToggleLeaveForm()
    {
        _showLeaveForm = !_showLeaveForm;
        if (_showLeaveForm)
        {
            var today = TemporalContext.GetOperativeDate();
            _newLeaveStartDt = today;
            _newLeaveEndDt   = today;
            _leaveError      = null;
        }
    }

    private async Task SubmitLeaveAsync()
    {
        _leaveError = null;
        if (string.IsNullOrWhiteSpace(_newLeaveType))   { _leaveError = "Leave type is required.";   return; }
        if (string.IsNullOrWhiteSpace(_newLeaveReason)) { _leaveError = "Reason code is required.";  return; }

        _leaveSubmitting = true;
        try
        {
            var command = new SubmitLeaveRequestCommand
            {
                EmploymentId    = EmploymentId,
                LeaveType       = _newLeaveType,
                LeaveStartDate  = DateOnly.FromDateTime(_newLeaveStartDt),
                LeaveEndDate    = DateOnly.FromDateTime(_newLeaveEndDt),
                LeaveReasonCode = _newLeaveReason,
                SubmittedBy     = await GetCurrentUserIdAsync(),
                Notes           = string.IsNullOrWhiteSpace(_newLeaveNotes) ? null : _newLeaveNotes
            };
            await LeaveService.SubmitLeaveRequestAsync(command);
            _showLeaveForm = false;
            _newLeaveType = _newLeaveReason = "";
            _newLeaveNotes = null;
            _leaveLoaded = false;
            await LoadLeaveAsync();
        }
        catch (Exception ex) { _leaveError = ex.Message; }
        finally { _leaveSubmitting = false; }
    }

    // Document upload

    private void ToggleUploadForm()
    {
        _showUploadForm = !_showUploadForm;
        if (_showUploadForm)
        {
            _uploadEffectiveDt = TemporalContext.GetOperativeDate();
            _uploadError       = null;
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e) => _uploadFile = e.File;

    private async Task UploadDocumentAsync()
    {
        _uploadError = null;
        if (string.IsNullOrWhiteSpace(_uploadDocType)) { _uploadError = "Document type is required."; return; }
        if (string.IsNullOrWhiteSpace(_uploadDocName)) { _uploadError = "Document name is required."; return; }
        if (_uploadFile is null)                        { _uploadError = "A file is required.";        return; }
        if (_person is null)                            return;

        var ext = Path.GetExtension(_uploadFile.Name).TrimStart('.');
        if (string.IsNullOrEmpty(ext)) { _uploadError = "Cannot determine file format from extension."; return; }

        const long maxBytes = 25L * 1024 * 1024;
        if (_uploadFile.Size > maxBytes) { _uploadError = "File exceeds 25 MB limit."; return; }

        _uploading = true;
        try
        {
            // Read the file entirely in the browser via JS interop, bypassing
            // IBrowserFile.OpenReadStream() which times out in Blazor Web App
            // because the server-side pipe never receives data from the client.
            var base64 = await JSRuntime.InvokeAsync<string?>(
                "allworkFiles.readBase64", "doc-file-input");
            if (string.IsNullOrEmpty(base64))
            {
                _uploadError = "Could not read the selected file.";
                return;
            }
            using var ms = new MemoryStream(Convert.FromBase64String(base64));

            var command = new UploadDocumentCommand
            {
                PersonId       = _person.PersonId,
                EmploymentId   = EmploymentId,
                DocumentType   = _uploadDocType,
                DocumentName   = _uploadDocName,
                FileContent    = ms,
                FileFormat     = ext.ToUpper(),
                EffectiveDate  = DateOnly.FromDateTime(_uploadEffectiveDt),
                ExpirationDate = _uploadExpirationDt.HasValue
                                     ? DateOnly.FromDateTime(_uploadExpirationDt.Value)
                                     : null,
                UploadedBy     = await GetCurrentUserIdAsync()
            };
            await DocumentService.UploadDocumentAsync(command);
            _showUploadForm = false;
            _uploadDocType = _uploadDocName = "";
            _uploadFile    = null;
            _uploadExpirationDt = null;
            _documentsLoaded = false;
            await LoadDocumentsAsync();
        }
        catch (Exception ex) { _uploadError = ex.Message; }
        finally { _uploading = false; }
    }

    // Onboarding actions

    private void StartComplete(Guid taskId)
    {
        _completingTaskId = taskId;
        _waivingTaskId    = null;
        _completionDt     = TemporalContext.GetOperativeDate();
        _onboardingError  = null;
    }

    private void StartWaive(Guid taskId)
    {
        _waivingTaskId    = taskId;
        _completingTaskId = null;
        _waiveReason      = "";
        _onboardingError  = null;
    }

    private void CancelInlineForm()
    {
        _completingTaskId = null;
        _waivingTaskId    = null;
    }

    private async Task ConfirmCompleteAsync(Guid taskId)
    {
        _onboardingError = null;
        try
        {
            await OnboardingService.CompleteTaskAsync(
                taskId, DateOnly.FromDateTime(_completionDt), await GetCurrentUserIdAsync());
            _completingTaskId = null;
            _onboardingLoaded = false;
            await LoadOnboardingAsync();
        }
        catch (Exception ex) { _onboardingError = ex.Message; }
    }

    private async Task ConfirmWaiveAsync(Guid taskId)
    {
        _onboardingError = null;
        if (string.IsNullOrWhiteSpace(_waiveReason))
        {
            _onboardingError = "Waiver reason is required.";
            return;
        }
        try
        {
            await OnboardingService.WaiveTaskAsync(taskId, _waiveReason, await GetCurrentUserIdAsync());
            _waivingTaskId    = null;
            _onboardingLoaded = false;
            await LoadOnboardingAsync();
        }
        catch (Exception ex) { _onboardingError = ex.Message; }
    }

    // Helpers

    private async Task<Guid> GetCurrentUserIdAsync()
    {
        var state = await AuthStateTask;
        var sub   = state.User.FindFirst("sub")?.Value;
        return Guid.TryParse(sub, out var id) ? id : Guid.Empty;
    }

    private string LookupLabel(string tableName, int id)
        => LookupCache.GetAll(tableName).FirstOrDefault(e => e.Id == id)?.Label ?? id.ToString();

    private string LookupCode(string tableName, int id)
        => LookupCache.GetCode(tableName, id).ToLower();

    private string ExpirationClass(DateOnly? expiration)
    {
        if (expiration is null) return "";
        var today = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
        if (expiration <= today)               return "cell-overdue";
        if (expiration <= today.AddDays(90))   return "cell-expiring";
        return "";
    }

    private string DocStatusLabel(HrDocument doc)
    {
        var code = LookupCache.GetCode(LookupTables.DocumentStatus, doc.DocumentStatusId).ToUpper();
        if (code is "ACTIVE" or "EXPIRED" && doc.ExpirationDate.HasValue)
        {
            var today = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
            return doc.ExpirationDate.Value <= today ? "Expired" : "Active";
        }
        return LookupLabel(LookupTables.DocumentStatus, doc.DocumentStatusId);
    }

    private string DocStatusClass(HrDocument doc)
    {
        var code = LookupCache.GetCode(LookupTables.DocumentStatus, doc.DocumentStatusId).ToUpper();
        if (code is "ACTIVE" or "EXPIRED" && doc.ExpirationDate.HasValue)
        {
            var today = DateOnly.FromDateTime(TemporalContext.GetOperativeDate());
            return doc.ExpirationDate.Value <= today ? "status-badge status-expired" : "status-badge status-active";
        }
        return $"status-badge status-{LookupCode(LookupTables.DocumentStatus, doc.DocumentStatusId)}";
    }
}

