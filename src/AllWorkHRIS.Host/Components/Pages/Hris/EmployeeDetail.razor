    private static string ChangeTypeLabel(string changeType) => changeType switch
    {
        PersonChangeType.LegalName          => "Legal name",
        PersonChangeType.DateOfBirth        => "Date of birth",
        PersonChangeType.NationalIdentifier => "National identifier",
        _                                   => changeType
    };

    private static string MaskNationalIdentifier(string? ni)
    {
        if (string.IsNullOrEmpty(ni)) return "—";
        var digits = new string(ni.Where(char.IsDigit).ToArray());
        return digits.Length >= 4
            ? new string('•', digits.Length - 4) + digits[^4..]
            : "••••";
    }

    private string FormatChangeDisplay(PersonChangeRequest req, bool current)
    {
        var json = current ? req.CurrentValueJson : req.RequestedValueJson;
        if (json is null) return "—";
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json).RootElement;
            return req.ChangeType switch
            {
                PersonChangeType.LegalName =>
                    string.Join(" ", new[]
                    {
                        doc.GetProperty("legalFirstName").GetString(),
                        doc.TryGetProperty("legalMiddleName", out var mn) ? mn.GetString() : null,
                        doc.GetProperty("legalLastName").GetString(),
                        doc.TryGetProperty("nameSuffix", out var sfx) ? sfx.GetString() : null
                    }.Where(s => !string.IsNullOrWhiteSpace(s))!),
                PersonChangeType.DateOfBirth =>
                    doc.GetProperty("dateOfBirth").GetString() ?? "—",
                PersonChangeType.NationalIdentifier =>
                    MaskNationalIdentifier(doc.GetProperty("nationalIdentifier").GetString()),
                _ => json
            };
        }
        catch { return json; }
    }

