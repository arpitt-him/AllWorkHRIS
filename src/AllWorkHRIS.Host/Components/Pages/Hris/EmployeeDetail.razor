                NationalIdentifier     = cmd.NationalIdentifier     ?? _person!.NationalIdentifier,
                NationalIdentifierType = cmd.NationalIdentifierType ?? _person!.NationalIdentifierType,
            };
            _pageTitle      = $"{_person.LegalFirstName} {_person.LegalLastName}";
            _initials       = $"{_person.LegalFirstName.FirstOrDefault()}{_person.LegalLastName.FirstOrDefault()}".ToUpper();
            _profileEditing = false;
            _profileSuccess = "Personal information updated.";
        }
        catch (Exception ex)
