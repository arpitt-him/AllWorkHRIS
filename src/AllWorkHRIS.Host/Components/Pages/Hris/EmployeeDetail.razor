            await PersonService.RejectChangeRequestAsync(new ReviewPersonChangeRequestCommand { PersonChangeRequestId = requestId, ReviewedBy = await GetCurrentUserIdAsync(), RejectionNotes = string.IsNullOrWhiteSpace(_rejectNote) ? null : _rejectNote.Trim() });
            _pendingRequests = await PersonService.GetPendingChangeRequestsAsync(_person!.PersonId);
            _rejectingId     = null;
            _rejectNote      = "";
        }
        catch (Exception ex) { _reviewError = ex.Message; }
        finally { _reviewSaving = false; }
    }

