@page "/hris/employees/{EmploymentId:guid}"
@layout HrisShell
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@attribute [Authorize(Roles = "HrisViewer,HrisAdmin,HrisOperator")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using AllWorkHRIS.Core.Lookups
@using AllWorkHRIS.Core.Temporal
@using AllWorkHRIS.Core.Composition
@using AllWorkHRIS.Host.Hris.Commands
@using AllWorkHRIS.Host.Hris.Services
@using AllWorkHRIS.Host.Hris.Repositories
@using AllWorkHRIS.Host.Hris.Queries
@using AllWorkHRIS.Host.Hris.Domain
@inject IEmploymentService    EmploymentService
@inject IPersonService        PersonService
@inject ICompensationService  CompensationService
@inject IAssignmentRepository AssignmentRepository
@inject IOrgStructureService  OrgStructureService
@inject IJobRepository        JobRepository
@inject ILeaveService         LeaveService
@inject IDocumentService      DocumentService
@inject IOnboardingService    OnboardingService
@inject IPersonSocialProfileRepository SocialProfileRepo
@inject IEnumerable<IEmployeeTabContributor> TabContributors
@inject IHrisSessionState     SessionState
@inject ILookupCache          LookupCache
@inject ITemporalContext      TemporalContext
@inject NavigationManager     Navigation
@inject IJSRuntime            JSRuntime

<PageTitle>@_pageTitle — AllWork HRIS</PageTitle>

@if (_loading)
{
    <div class="page-container">
        <p class="loading-text">Loading employee...</p>
    </div>
}
else if (_employment is null)
{
    <div class="page-container">
        <p class="error-text">Employee not found.</p>
        <a href="/hris/employees" class="btn-link">Back to Employees</a>
    </div>
}
else
{
    <div class="page-container">

        @* Page header *@
        <div class="page-header">
            <div class="employee-header-info">
                <span class="avatar-lg">@_initials</span>
                <div>
                    <h2 class="page-title">@_person?.LegalFirstName @_person?.LegalLastName</h2>
                    <span class="employee-number">@_employment.EmployeeNumber</span>
                    <span class="status-badge status-@LookupCode(LookupTables.EmploymentStatus, _employment.EmploymentStatusId)">
                        @LookupLabel(LookupTables.EmploymentStatus, _employment.EmploymentStatusId)
                    </span>
                </div>
            </div>
            <AuthorizeView Roles="HrisAdmin">
                <Authorized>
                    <div class="action-buttons">
                        @if (_employment.EmploymentStatusId == _activeStatusId)
                        {
                            <button class="btn-secondary" @onclick="BeginChangeCompensation">Change Compensation</button>
                            <button class="btn-secondary" @onclick="BeginTransfer">Transfer</button>
                            <button class="btn-secondary" @onclick="BeginChangeManager">Change Manager</button>
                            <button class="btn-secondary" @onclick="BeginPlaceOnLeave">Place on Leave</button>
                            <button class="btn-danger">Terminate</button>
                        }
                        else if (_employment.EmploymentStatusId == _onLeaveStatusId)
                        {
                            <button class="btn-secondary">Return from Leave</button>
                            <button class="btn-danger">Terminate</button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        @* Action panels — shown between header and tabs when an action button is active *@
        @if (_actionMode != ActionMode.None)
        {
            <div class="action-panel">
                <div class="action-panel-header">
                    <h3 class="action-panel-title">
                        @(_actionMode switch {
                            ActionMode.ChangeCompensation => "Change Compensation",
                            ActionMode.Transfer           => "Transfer Employee",
                            ActionMode.ChangeManager      => "Change Manager",
                            _                             => ""
                        })
                    </h3>
                    <button class="btn-link" @onclick="CancelAction" style="font-size:.85rem;">✕ Cancel</button>
                </div>

                @if (_actionMode == ActionMode.ChangeCompensation)
                {
                    <div class="form-panel">
                        <div class="form-grid">
                            <div class="form-field">
                                <label class="form-label">Rate Type <span class="req">*</span></label>
                                <select class="form-select" @bind="_compNewRateTypeId">
                                    <option value="0">Select…</option>
                                    @foreach (var rt in LookupCache.GetAll(LookupTables.CompensationRateType))
                                    {
                                        <option value="@rt.Id">@rt.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label">New Base Rate <span class="req">*</span></label>
                                <input type="number" step="0.01" min="0" class="form-input" @bind="_compNewBaseRate" />
                            </div>
                            <div class="form-field">
                                <label class="form-label">Pay Frequency <span class="req">*</span></label>
                                <select class="form-select" @bind="_compNewFreqId">
                                    <option value="0">Select…</option>
                                    @foreach (var pf in LookupCache.GetAll(LookupTables.PayFrequency))
                                    {
                                        <option value="@pf.Id">@pf.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label">Effective Date <span class="req">*</span></label>
                                <input type="date" class="form-input" @bind="_compEffectiveDt" />
                            </div>
                            <div class="form-field form-field-full">
                                <label class="form-label">Change Reason <span class="req">*</span></label>
                                <input type="text" class="form-input" @bind="_compReasonCode"
                                       placeholder="e.g. MERIT, PROMOTION, CORRECTION" />
                            </div>
                        </div>
                        @if (_compError is not null) { <p class="form-error">@_compError</p> }
                        <div class="form-actions">
                            <button class="btn-primary" @onclick="SaveChangeCompensationAsync" disabled="@_compSaving">
                                @(_compSaving ? "Saving…" : "Save Change")
                            </button>
                            <button class="btn-secondary" @onclick="CancelAction" disabled="@_compSaving">Cancel</button>
                        </div>
                    </div>
                }
                else if (_actionMode == ActionMode.Transfer)
                {
                    @if (_txfrLoading)
                    {
                        <p class="loading-text">Loading options…</p>
                    }
                    else
                    {
                        <div class="form-panel">
                            <div class="form-grid">
                                <div class="form-field">
                                    <label class="form-label">New Department <span class="req">*</span></label>
                                    <select class="form-select" @bind="_txfrNewDeptId">
                                        <option value="@Guid.Empty">Select…</option>
                                        @foreach (var d in _txfrDepts ?? [])
                                        {
                                            <option value="@d.OrgUnitId">@d.OrgUnitName</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-field">
                                    <label class="form-label">New Location <span class="req">*</span></label>
                                    <select class="form-select" @bind="_txfrNewLocationId">
                                        <option value="@Guid.Empty">Select…</option>
                                        @foreach (var l in _txfrLocations ?? [])
                                        {
                                            <option value="@l.OrgUnitId">@l.OrgUnitName</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-field">
                                    <label class="form-label">New Job (optional — leave blank to keep current)</label>
                                    <select class="form-select" @bind="_txfrNewJobId">
                                        <option value="">Keep current</option>
                                        @foreach (var j in _txfrJobs ?? [])
                                        {
                                            <option value="@j.JobId">@j.JobTitle (@j.JobCode)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-field">
                                    <label class="form-label">Effective Date <span class="req">*</span></label>
                                    <input type="date" class="form-input" @bind="_txfrEffectiveDt" />
                                </div>
                                <div class="form-field">
                                    <label class="form-label">Reason Code <span class="req">*</span></label>
                                    <input type="text" class="form-input" @bind="_txfrReasonCode"
                                           placeholder="e.g. RESTRUCTURE, VOLUNTARY, LATERAL" />
                                </div>
                                <div class="form-field form-field-full">
                                    <label class="form-label">Notes (optional)</label>
                                    <textarea class="form-input" rows="2" @bind="_txfrNotes"></textarea>
                                </div>
                            </div>
                            @if (_txfrError is not null) { <p class="form-error">@_txfrError</p> }
                            <div class="form-actions">
                                <button class="btn-primary" @onclick="SaveTransferAsync" disabled="@_txfrSaving">
                                    @(_txfrSaving ? "Saving…" : "Save Transfer")
                                </button>
                                <button class="btn-secondary" @onclick="CancelAction" disabled="@_txfrSaving">Cancel</button>
                            </div>
                        </div>
                    }
                }
                else if (_actionMode == ActionMode.ChangeManager)
                {
                    @if (_mgrLoading)
                    {
                        <p class="loading-text">Loading employee list…</p>
                    }
                    else
                    {
                        <div class="form-panel">
                            <div class="form-grid">
                                <div class="form-field">
                                    <label class="form-label">New Manager <span class="req">*</span></label>
                                    <select class="form-select" @bind="_mgrNewManagerId">
                                        <option value="">Select…</option>
                                        @foreach (var e in _mgrCandidates)
                                        {
                                            <option value="@e.EmploymentId">@e.LegalLastName, @e.LegalFirstName (@e.EmployeeNumber)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-field">
                                    <label class="form-label">Effective Date <span class="req">*</span></label>
                                    <input type="date" class="form-input" @bind="_mgrEffectiveDt" />
                                </div>
                                <div class="form-field form-field-full">
                                    <label class="form-label">Notes (optional)</label>
                                    <textarea class="form-input" rows="2" @bind="_mgrNotes"></textarea>
                                </div>
                            </div>
                            @if (_mgrError is not null) { <p class="form-error">@_mgrError</p> }
                            <div class="form-actions">
                                <button class="btn-primary" @onclick="SaveChangeManagerAsync" disabled="@_mgrSaving">
                                    @(_mgrSaving ? "Saving…" : "Save Change")
                                </button>
                                <button class="btn-secondary" @onclick="CancelAction" disabled="@_mgrSaving">Cancel</button>
                            </div>
                        </div>
                    }
                }
            </div>
        }

        @* Tabs *@
        <div class="tab-bar">
            @foreach (var tab in _allTabs)
            {
                <button class="tab-btn @(_activeTab == tab.Label ? "active" : "")"
                        @onclick="() => SwitchTabAsync(tab.Label)">
                    @tab.Label
                </button>
            }
        </div>

        @* Tab content *@
        <div class="tab-content">
            @{
                var _activeEntry = _allTabs.FirstOrDefault(t => t.Label == _activeTab);
            }
            @if (_activeEntry?.ComponentType is not null)
            {
                <DynamicComponent Type="_activeEntry.ComponentType"
                                  Parameters="_tabParams" />
            }
            else
            @switch (_activeTab)
            {
                case "Profile":
                    <div class="detail-section">
                        <div class="section-header-row">
                            <h3 class="section-title">Personal Information</h3>
                            @if (!_profileEditing && !_basicEditing && !_crEditing)
                            {
                                <AuthorizeView Roles="HrisAdmin">
                                    <Authorized>
                                        <button class="btn-link" @onclick="BeginEditProfile">Edit</button>
                                    </Authorized>
                                </AuthorizeView>
                                <AuthorizeView Roles="HrisOperator">
                                    <Authorized>
                                        <div style="display:flex;gap:var(--space-3)">
                                            <button class="btn-link" @onclick="BeginBasicEdit">Edit</button>
                                            <button class="btn-link" @onclick="BeginChangeRequest">Request change</button>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                            }
                        </div>

                        @if (!_profileEditing && !_basicEditing && !_crEditing)
                        {
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <span class="detail-label">
                                        Legal Name
                                        @if (HasPendingFor(PersonChangeType.LegalName))
                                        { <span class="pending-badge">pending</span> }
                                    </span>
                                    <span class="detail-value">@_person?.LegalFirstName @_person?.LegalMiddleName @_person?.LegalLastName @_person?.NameSuffix</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Preferred Name</span>
                                    <span class="detail-value">@(_person?.PreferredName ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">
                                        Date of Birth
                                        @if (HasPendingFor(PersonChangeType.DateOfBirth))
                                        { <span class="pending-badge">pending</span> }
                                    </span>
                                    <span class="detail-value">@_person?.DateOfBirth.ToString("yyyy-MM-dd")</span>
                                </div>
                                <AuthorizeView Roles="HrisAdmin,HrisOperator">
                                    <Authorized>
                                        <div class="detail-item">
                                            <span class="detail-label">
                                                @(_person?.NationalIdentifierType ?? "National ID")
                                                @if (HasPendingFor(PersonChangeType.NationalIdentifier))
                                                { <span class="pending-badge">pending</span> }
                                            </span>
                                            <span class="detail-value">@MaskNationalIdentifier(_person?.NationalIdentifier)</span>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                                <div class="detail-item">
                                    <span class="detail-label">Gender</span>
                                    <span class="detail-value">@(_person?.Gender ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Pronouns</span>
                                    <span class="detail-value">@(_person?.Pronouns ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Marital Status</span>
                                    <span class="detail-value">@(_person?.MaritalStatus ?? "—")</span>
                                </div>
                            </div>
                        }

                        @* HrisAdmin — direct edit, all fields *@
                        @if (_profileEditing)
                        {
                            <div class="stacked-form">
                                <p class="form-section-label">Identity (restricted)</p>
                                <div class="form-row form-row--3col">
                                    <div>
                                        <label class="form-label">Legal first name <span class="req">*</span></label>
                                        <input class="form-input" @bind="_profFirstName" />
                                    </div>
                                    <div>
                                        <label class="form-label">Middle name</label>
                                        <input class="form-input" @bind="_profMiddleName" />
                                    </div>
                                    <div>
                                        <label class="form-label">Legal last name <span class="req">*</span></label>
                                        <input class="form-input" @bind="_profLastName" />
                                    </div>
                                </div>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">Suffix</label>
                                        <input class="form-input form-input--sm" @bind="_profSuffix" placeholder="Jr., Sr., III…" />
                                    </div>
                                    <div>
                                        <label class="form-label">Date of birth <span class="req">*</span></label>
                                        <input class="form-input form-input--dob" type="date" @bind="_profDob" />
                                    </div>
                                </div>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">National identifier</label>
                                        <input class="form-input" @bind="_profNI" placeholder="e.g. 123-45-6789" />
                                    </div>
                                    <div>
                                        <label class="form-label">ID type</label>
                                        <input class="form-input form-input--sm" @bind="_profNIType" placeholder="SSN, SIN…" />
                                    </div>
                                </div>
                                <p class="form-section-label" style="margin-top:var(--space-3)">Personal details</p>
                                <div class="form-row">
                                    <label class="form-label">Preferred name</label>
                                    <input class="form-input" @bind="_profPreferredName" />
                                </div>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">Gender</label>
                                        <input class="form-input" @bind="_profGender" placeholder="e.g. Male, Female, Non-binary" />
                                    </div>
                                    <div>
                                        <label class="form-label">Pronouns</label>
                                        <input class="form-input" @bind="_profPronouns" placeholder="e.g. she/her" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Marital status</label>
                                    <input class="form-input" @bind="_profMaritalStatus" placeholder="e.g. Single, Married" />
                                </div>
                                @if (_profileError is not null) { <p class="form-error">@_profileError</p> }
                                <div class="form-actions">
                                    <button class="btn-primary" @onclick="SaveProfileAsync" disabled="@_profileSaving">@(_profileSaving ? "Saving…" : "Save")</button>
                                    <button class="btn-secondary" @onclick="CancelEditProfile" disabled="@_profileSaving">Cancel</button>
                                </div>
                            </div>
                        }

                        @* HrisOperator — basic field direct edit *@
                        @if (_basicEditing)
                        {
                            <div class="stacked-form">
                                <div class="form-row">
                                    <label class="form-label">Preferred name</label>
                                    <input class="form-input" @bind="_basicPreferredName" />
                                </div>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">Gender</label>
                                        <input class="form-input" @bind="_basicGender" placeholder="e.g. Male, Female, Non-binary" />
                                    </div>
                                    <div>
                                        <label class="form-label">Pronouns</label>
                                        <input class="form-input" @bind="_basicPronouns" placeholder="e.g. she/her" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Marital status</label>
                                    <input class="form-input" @bind="_basicMaritalStatus" placeholder="e.g. Single, Married" />
                                </div>
                                @if (_basicError is not null) { <p class="form-error">@_basicError</p> }
                                <div class="form-actions">
                                    <button class="btn-primary" @onclick="SaveBasicAsync" disabled="@_basicSaving">@(_basicSaving ? "Saving…" : "Save")</button>
                                    <button class="btn-secondary" @onclick="CancelBasicEdit" disabled="@_basicSaving">Cancel</button>
                                </div>
                            </div>
                        }

                        @* HrisOperator — restricted field change request *@
                        @if (_crEditing)
                        {
                            <div class="stacked-form">
                                <p class="form-hint">Changes to these fields require HrisAdmin approval before taking effect.</p>
                                <p class="form-section-label">Legal name</p>
                                <div class="form-row form-row--3col">
                                    <div>
                                        <label class="form-label">First name <span class="req">*</span></label>
                                        <input class="form-input" @bind="_crFirstName" />
                                    </div>
                                    <div>
                                        <label class="form-label">Middle name</label>
                                        <input class="form-input" @bind="_crMiddleName" />
                                    </div>
                                    <div>
                                        <label class="form-label">Last name <span class="req">*</span></label>
                                        <input class="form-input" @bind="_crLastName" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Suffix</label>
                                    <input class="form-input form-input--sm" @bind="_crSuffix" placeholder="Jr., Sr., III…" />
                                </div>
                                <p class="form-section-label" style="margin-top:var(--space-3)">Date of birth</p>
                                <div class="form-row">
                                    <label class="form-label">Date of birth</label>
                                    <input class="form-input form-input--dob" type="date" @bind="_crDob" />
                                </div>
                                <p class="form-section-label" style="margin-top:var(--space-3)">National identifier</p>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">Identifier</label>
                                        <input class="form-input" @bind="_crNI" placeholder="e.g. 123-45-6789" />
                                    </div>
                                    <div>
                                        <label class="form-label">Type</label>
                                        <input class="form-input form-input--sm" @bind="_crNIType" placeholder="SSN, SIN…" />
                                    </div>
                                </div>
                                @if (_crError is not null) { <p class="form-error">@_crError</p> }
                                <div class="form-actions">
                                    <button class="btn-primary" @onclick="SubmitChangeRequestsAsync" disabled="@_crSaving">@(_crSaving ? "Submitting…" : "Submit for approval")</button>
                                    <button class="btn-secondary" @onclick="CancelChangeRequest" disabled="@_crSaving">Cancel</button>
                                </div>
                            </div>
                        }

                        @if (_profileSuccess  is not null) { <p class="form-success">@_profileSuccess</p>  }
                        @if (_basicSuccess    is not null) { <p class="form-success">@_basicSuccess</p>    }
                        @if (_crSuccess       is not null) { <p class="form-success">@_crSuccess</p>       }
                    </div>

                    @* Pending change requests — HrisAdmin only *@
                    @if (_pendingRequests.Count > 0)
                    {
                        <AuthorizeView Roles="HrisAdmin">
                            <Authorized>
                                <div class="detail-section pending-changes-section">
                                    <h3 class="section-title">Pending Change Requests</h3>
                                    @if (_reviewError is not null) { <p class="form-error">@_reviewError</p> }
                                    <div class="pending-list">
                                        @foreach (var req in _pendingRequests)
                                        {
                                            <div class="pending-item">
                                                <div class="pending-item-header">
                                                    <span class="pending-type-label">@ChangeTypeLabel(req.ChangeType)</span>
                                                    <span class="pending-meta">Requested @req.RequestedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                                </div>
                                                <div class="pending-values">
                                                    <div>
                                                        <span class="pending-value-label">Current</span>
                                                        <span class="pending-value">@FormatChangeDisplay(req, current: true)</span>
                                                    </div>
                                                    <span class="pending-arrow">→</span>
                                                    <div>
                                                        <span class="pending-value-label">Requested</span>
                                                        <span class="pending-value">@FormatChangeDisplay(req, current: false)</span>
                                                    </div>
                                                </div>
                                                @if (_rejectingId == req.PersonChangeRequestId)
                                                {
                                                    <div class="pending-reject-form">
                                                        <textarea class="form-input" rows="2" placeholder="Rejection note (optional)"
                                                                  @bind="_rejectNote"></textarea>
                                                        <div class="form-actions">
                                                            <button class="btn-danger" @onclick="() => ConfirmRejectAsync(req.PersonChangeRequestId)" disabled="@_reviewSaving">
                                                                @(_reviewSaving ? "Rejecting…" : "Confirm reject")
                                                            </button>
                                                            <button class="btn-secondary" @onclick="CancelReject">Cancel</button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="pending-actions">
                                                        <button class="btn-primary btn-sm" @onclick="() => ApproveRequestAsync(req.PersonChangeRequestId)" disabled="@_reviewSaving">Approve</button>
                                                        <button class="btn-secondary btn-sm" @onclick="() => BeginReject(req.PersonChangeRequestId)">Reject</button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </Authorized>
                        </AuthorizeView>
                    }

                    <div class="detail-section">
                        <div class="section-header-row">
                            <h3 class="section-title">Address &amp; Contact</h3>
                            <AuthorizeView Roles="HrisAdmin">
                                <Authorized>
                                    @if (!_addressEditing && _address is not null)
                                    {
                                        <button class="btn-link" @onclick="BeginEditAddress">Edit</button>
                                    }
                                </Authorized>
                            </AuthorizeView>
                        </div>

                        @if (_address is null)
                        {
                            <p class="placeholder-text">No address on file.</p>
                        }
                        else if (!_addressEditing)
                        {
                            <div class="detail-grid">
                                <div class="detail-item detail-item--wide">
                                    <span class="detail-label">Address</span>
                                    <span class="detail-value">
                                        @_address.AddressLine1
                                        @if (!string.IsNullOrWhiteSpace(_address.AddressLine2))
                                        { <br />@_address.AddressLine2 }
                                        <br />@_address.City, @_address.StateCode @_address.PostalCode
                                        <br />@_address.CountryCode
                                    </span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Phone (primary)</span>
                                    <span class="detail-value">@(_address.PhonePrimary ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Phone (secondary)</span>
                                    <span class="detail-value">@(_address.PhoneSecondary ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Personal email</span>
                                    <span class="detail-value">@(_address.EmailPersonal ?? "—")</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="stacked-form">
                                <div class="form-row">
                                    <label class="form-label">Address line 1 <span class="req">*</span></label>
                                    <input class="form-input" @bind="_addrLine1" />
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Address line 2</label>
                                    <input class="form-input" @bind="_addrLine2" />
                                </div>
                                <div class="form-row form-row--3col">
                                    <div>
                                        <label class="form-label">City <span class="req">*</span></label>
                                        <input class="form-input" @bind="_addrCity" />
                                    </div>
                                    <div>
                                        <label class="form-label">State / Province <span class="req">*</span></label>
                                        <input class="form-input" @bind="_addrState" maxlength="10" />
                                    </div>
                                    <div>
                                        <label class="form-label">Postal code <span class="req">*</span></label>
                                        <input class="form-input" @bind="_addrPostal" maxlength="20" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Country code <span class="req">*</span></label>
                                    <input class="form-input form-input--sm" @bind="_addrCountry" maxlength="3" />
                                </div>
                                <div class="form-row form-row--2col">
                                    <div>
                                        <label class="form-label">Phone (primary)</label>
                                        <input class="form-input" @bind="_addrPhone1" />
                                    </div>
                                    <div>
                                        <label class="form-label">Phone (secondary)</label>
                                        <input class="form-input" @bind="_addrPhone2" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label class="form-label">Personal email</label>
                                    <input class="form-input" type="email" @bind="_addrEmail" />
                                </div>

                                @if (_addressError is not null)
                                {
                                    <p class="form-error">@_addressError</p>
                                }
                                <div class="form-actions">
                                    <button class="btn-primary" @onclick="SaveAddressAsync" disabled="@_addressSaving">
                                        @(_addressSaving ? "Saving…" : "Save")
                                    </button>
                                    <button class="btn-secondary" @onclick="CancelEditAddress" disabled="@_addressSaving">Cancel</button>
                                </div>
                            </div>
                        }

                        @if (_addressSuccess is not null)
                        {
                            <p class="form-success">@_addressSuccess</p>
                        }
                    </div>
                    break;

                case "Employment":
                    <div class="detail-section">
                        <h3 class="section-title">Employment Details</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <span class="detail-label">Employee Number</span>
                                <span class="detail-value">@_employment.EmployeeNumber</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Employment Type</span>
                                <span class="detail-value">@LookupLabel(LookupTables.EmploymentType, _employment.EmploymentTypeId)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Status</span>
                                <span class="detail-value">@LookupLabel(LookupTables.EmploymentStatus, _employment.EmploymentStatusId)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">FLSA Status</span>
                                <span class="detail-value">@LookupLabel(LookupTables.FlsaStatus, _employment.FlsaStatusId)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Full / Part Time</span>
                                <span class="detail-value">@LookupLabel(LookupTables.FullPartTimeStatus, _employment.FullPartTimeStatusId)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Start Date</span>
                                <span class="detail-value">@_employment.EmploymentStartDate.ToString("yyyy-MM-dd")</span>
                            </div>
                            @if (_employment.TerminationDate.HasValue)
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Termination Date</span>
                                    <span class="detail-value">@_employment.TerminationDate.Value.ToString("yyyy-MM-dd")</span>
                                </div>
                            }
                        </div>
                    </div>
                    break;

                case "Assignment":
                    @if (_assignmentLoading)
                    {
                        <p class="loading-text">Loading assignment...</p>
                    }
                    else if (_assignment is null)
                    {
                        <p class="placeholder-text">No active assignment on record.</p>
                    }
                    else
                    {
                        <div class="detail-section">
                            <h3 class="section-title">Current Assignment</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <span class="detail-label">Job</span>
                                    <span class="detail-value">
                                        @if (_assignmentJob is not null)
                                        {
                                            @($"{_assignmentJob.JobTitle} ({_assignmentJob.JobCode})")
                                        }
                                        else { @("—") }
                                    </span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Department</span>
                                    <span class="detail-value">@(_assignmentDepartment?.OrgUnitName ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Location</span>
                                    <span class="detail-value">@(_assignmentLocation?.OrgUnitName ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Manager</span>
                                    <span class="detail-value">
                                        @if (_managerPerson is not null)
                                        {
                                            @($"{_managerPerson.LegalFirstName} {_managerPerson.LegalLastName}")
                                        }
                                        else { @("—") }
                                    </span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Assignment Type</span>
                                    <span class="detail-value">@LookupLabel(LookupTables.AssignmentType, _assignment.AssignmentTypeId)</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Start Date</span>
                                    <span class="detail-value">@_assignment.AssignmentStartDate.ToString("yyyy-MM-dd")</span>
                                </div>
                            </div>
                        </div>
                    }
                    break;

                case "Compensation":
                    <AuthorizeView Roles="HrisAdmin">
                        <Authorized>
                            <div class="detail-section">
                                <h3 class="section-title">Current Compensation</h3>
                                @if (_compensation is not null)
                                {
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <span class="detail-label">Rate Type</span>
                                            <span class="detail-value">@LookupLabel(LookupTables.CompensationRateType, _compensation.RateTypeId)</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Base Rate</span>
                                            <span class="detail-value">@_compensation.BaseRate.ToString("C") @_compensation.RateCurrency</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Pay Frequency</span>
                                            <span class="detail-value">@LookupLabel(LookupTables.PayFrequency, _compensation.PayFrequencyId)</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Effective Date</span>
                                            <span class="detail-value">@_compensation.EffectiveStartDate.ToString("yyyy-MM-dd")</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <p class="placeholder-text">No active compensation record.</p>
                                }
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <p class="placeholder-text">You do not have permission to view compensation details.</p>
                        </NotAuthorized>
                    </AuthorizeView>
                    break;

                case "Leave":
                    @if (_leaveLoading)
                    {
                        <p class="loading-text">Loading leave data...</p>
                    }
                    else
                    {
                        <div class="section-header-row">
                            <h3 class="section-title">Leave Balances</h3>
                        </div>
                        @if (_leaveBalances is not null && _leaveBalances.Any())
                        {
                            <div class="balance-cards">
                                @foreach (var bal in _leaveBalances)
                                {
                                    <div class="balance-card">
                                        <div class="balance-card-type">@LookupLabel(LookupTables.LeaveType, bal.LeaveTypeId)</div>
                                        <div class="balance-card-available">@bal.AvailableBalance.ToString("0.##")</div>
                                        <div class="balance-card-label">days available</div>
                                        <div class="balance-card-details">
                                            <span>Used: @bal.UsedBalance.ToString("0.##")</span>
                                            <span>Pending: @bal.PendingBalance.ToString("0.##")</span>
                                            <span>Entitled: @bal.EntitlementTotal.ToString("0.##")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="placeholder-text">No leave balances on record.</p>
                        }

                        <div class="section-header-row" style="margin-top: var(--space-6);">
                            <h3 class="section-title">Leave Requests</h3>
                            <AuthorizeView Roles="HrisAdmin">
                                <Authorized>
                                    <button class="btn-secondary btn-sm"
                                            @onclick="ToggleLeaveForm">
                                        @(_showLeaveForm ? "Cancel" : "+ Request Leave")
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </div>

                        <AuthorizeView Roles="HrisAdmin">
                            <Authorized>
                                @if (_showLeaveForm)
                                {
                                    <div class="form-panel">
                                        <div class="form-grid">
                                            <div class="form-field">
                                                <label class="form-label">Leave Type</label>
                                                <select class="form-select" @bind="_newLeaveType">
                                                    <option value="">Select type…</option>
                                                    @foreach (var lt in LookupCache.GetAll(LookupTables.LeaveType))
                                                    {
                                                        <option value="@lt.Code">@lt.Label</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">Reason Code</label>
                                                <input type="text" class="form-input" @bind="_newLeaveReason"
                                                       placeholder="e.g. PERSONAL" />
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">Start Date</label>
                                                <input type="date" class="form-input" @bind="_newLeaveStartDt" />
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">End Date</label>
                                                <input type="date" class="form-input" @bind="_newLeaveEndDt" />
                                            </div>
                                            <div class="form-field form-field-full">
                                                <label class="form-label">Notes (optional)</label>
                                                <textarea class="form-input" rows="2" @bind="_newLeaveNotes"></textarea>
                                            </div>
                                        </div>
                                        @if (_leaveError is not null)
                                        {
                                            <p class="form-error">@_leaveError</p>
                                        }
                                        <div class="form-actions">
                                            <button class="btn-primary" @onclick="SubmitLeaveAsync"
                                                    disabled="@_leaveSubmitting">
                                                @(_leaveSubmitting ? "Submitting…" : "Submit Request")
                                            </button>
                                            <button class="btn-secondary"
                                                    @onclick="() => _showLeaveForm = false">Cancel</button>
                                        </div>
                                    </div>
                                }
                            </Authorized>
                        </AuthorizeView>

                        @if (_leaveHistory is not null && _leaveHistory.Any())
                        {
                            <div class="table-wrapper">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Type</th>
                                            <th>Start</th>
                                            <th>End</th>
                                            <th>Requested</th>
                                            <th>Status</th>
                                            <th>Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var req in _leaveHistory.OrderByDescending(r => r.RequestDate))
                                        {
                                            <tr>
                                                <td>@LookupLabel(LookupTables.LeaveType, req.LeaveTypeId)</td>
                                                <td>@req.LeaveStartDate.ToString("yyyy-MM-dd")</td>
                                                <td>@req.LeaveEndDate.ToString("yyyy-MM-dd")</td>
                                                <td>@req.RequestDate.ToString("yyyy-MM-dd")</td>
                                                <td>
                                                    <span class="status-badge status-@LookupCode(LookupTables.LeaveStatus, req.LeaveStatusId)">
                                                        @LookupLabel(LookupTables.LeaveStatus, req.LeaveStatusId)
                                                    </span>
                                                </td>
                                                <td>@(req.Notes ?? "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="placeholder-text" style="margin-top: var(--space-4);">No leave requests on record.</p>
                        }
                    }
                    break;

                case "Documents":
                    <AuthorizeView Roles="HrisAdmin">
                        <Authorized>
                            @if (_documentsLoading)
                            {
                                <p class="loading-text">Loading documents...</p>
                            }
                            else
                            {
                                <div class="section-header-row">
                                    <h3 class="section-title">Documents</h3>
                                    <button class="btn-secondary btn-sm"
                                            @onclick="ToggleUploadForm">
                                        @(_showUploadForm ? "Cancel" : "+ Upload Document")
                                    </button>
                                </div>

                                @if (_showUploadForm)
                                {
                                    <div class="form-panel">
                                        <div class="form-grid">
                                            <div class="form-field">
                                                <label class="form-label">Document Type</label>
                                                <select class="form-select" @bind="_uploadDocType">
                                                    <option value="">Select type…</option>
                                                    @foreach (var dt in LookupCache.GetAll(LookupTables.DocumentType))
                                                    {
                                                        <option value="@dt.Code">@dt.Label</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">Document Name</label>
                                                <input type="text" class="form-input" @bind="_uploadDocName"
                                                       placeholder="e.g. I-9 Form" />
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">Effective Date</label>
                                                <input type="date" class="form-input" @bind="_uploadEffectiveDt" />
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">Expiration Date (optional)</label>
                                                <input type="date" class="form-input" @bind="_uploadExpirationDt" />
                                            </div>
                                            <div class="form-field form-field-full">
                                                <label class="form-label">File</label>
                                                <InputFile id="doc-file-input" OnChange="OnFileSelected" />
                                                @if (_uploadFile is not null)
                                                {
                                                    <span class="file-info">
                                                        @_uploadFile.Name (@(_uploadFile.Size / 1024) KB)
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                        @if (_uploadError is not null)
                                        {
                                            <p class="form-error">@_uploadError</p>
                                        }
                                        <div class="form-actions">
                                            <button class="btn-primary" @onclick="UploadDocumentAsync"
                                                    disabled="@_uploading">
                                                @(_uploading ? "Uploading…" : "Upload")
                                            </button>
                                            <button class="btn-secondary"
                                                    @onclick="() => _showUploadForm = false">Cancel</button>
                                        </div>
                                    </div>
                                }

                                @if (_documents is not null && _documents.Any())
                                {
                                    <div class="table-wrapper">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Type</th>
                                                    <th>Name</th>
                                                    <th>Ver.</th>
                                                    <th>Status</th>
                                                    <th>Effective</th>
                                                    <th>Expires</th>
                                                    <th>Verified</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var doc in _documents.OrderByDescending(d => d.UploadDate))
                                                {
                                                    <tr>
                                                        <td>@LookupLabel(LookupTables.DocumentType, doc.DocumentTypeId)</td>
                                                        <td>@doc.DocumentName</td>
                                                        <td>v@(doc.DocumentVersion)</td>
                                                        <td>
                                                            <span class="status-badge @DocStatusClass(doc)">
                                                                @DocStatusLabel(doc)
                                                            </span>
                                                        </td>
                                                        <td>@doc.EffectiveDate.ToString("yyyy-MM-dd")</td>
                                                        <td class="@ExpirationClass(doc.ExpirationDate)">
                                                            @(doc.ExpirationDate?.ToString("yyyy-MM-dd") ?? "—")
                                                        </td>
                                                        <td>@(doc.VerifiedBy.HasValue ? "✓" : "—")</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(doc.StorageReference))
                                                            {
                                                                <a href="/api/documents/@doc.DocumentId/content"
                                                                   class="btn-link" target="_blank">Download</a>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <p class="placeholder-text" style="margin-top: var(--space-4);">No documents on record.</p>
                                }
                            }
                        </Authorized>
                        <NotAuthorized>
                            <p class="placeholder-text">You do not have permission to view documents.</p>
                        </NotAuthorized>
                    </AuthorizeView>
                    break;

                case "Onboarding":
                    @if (_onboardingLoading)
                    {
                        <p class="loading-text">Loading onboarding data...</p>
                    }
                    else if (_onboardingPlan is null)
                    {
                        <p class="placeholder-text">No onboarding plan found for this employee.</p>
                    }
                    else
                    {
                        <div class="detail-section">
                            <div class="section-header-row">
                                <h3 class="section-title">Onboarding Plan</h3>
                                <span class="status-badge status-@LookupCode(LookupTables.OnboardingPlanStatus, _onboardingPlan.PlanStatusId)">
                                    @LookupLabel(LookupTables.OnboardingPlanStatus, _onboardingPlan.PlanStatusId)
                                </span>
                            </div>
                            <div class="detail-grid" style="margin-top: var(--space-3);">
                                <div class="detail-item">
                                    <span class="detail-label">Target Start Date</span>
                                    <span class="detail-value">@_onboardingPlan.TargetStartDate.ToString("yyyy-MM-dd")</span>
                                </div>
                                @if (_onboardingPlan.CompletionDate.HasValue)
                                {
                                    <div class="detail-item">
                                        <span class="detail-label">Completion Date</span>
                                        <span class="detail-value">@_onboardingPlan.CompletionDate.Value.ToString("yyyy-MM-dd")</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (_onboardingError is not null)
                        {
                            <p class="form-error" style="margin-top: var(--space-3);">@_onboardingError</p>
                        }

                        <div class="detail-section" style="margin-top: var(--space-6);">
                            <h3 class="section-title">Tasks</h3>
                            @if (_onboardingTasks is not null && _onboardingTasks.Any())
                            {
                                <div class="table-wrapper">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Task</th>
                                                <th>Type</th>
                                                <th>Owner</th>
                                                <th>Due</th>
                                                <th>Blocking</th>
                                                <th>Status</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var task in _onboardingTasks.OrderBy(t => t.DueDate))
                                            {
                                                var isPending = task.TaskStatusId == _taskPendingStatusId;
                                                var isOverdue = task.DueDate < DateOnly.FromDateTime(TemporalContext.GetOperativeDate()) && isPending;
                                                <tr>
                                                    <td>@task.TaskName</td>
                                                    <td>@LookupLabel(LookupTables.OnboardingTaskType, task.TaskTypeId)</td>
                                                    <td>@task.TaskOwnerRole</td>
                                                    <td class="@(isOverdue ? "cell-overdue" : "")">
                                                        @task.DueDate.ToString("yyyy-MM-dd")
                                                    </td>
                                                    <td>
                                                        @if (task.BlockingFlag)
                                                        {
                                                            <span class="badge-blocking">Blocking</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span class="status-badge status-@LookupCode(LookupTables.OnboardingTaskStatus, task.TaskStatusId)">
                                                            @LookupLabel(LookupTables.OnboardingTaskStatus, task.TaskStatusId)
                                                        </span>
                                                        @if (task.WaiverReason is not null)
                                                        {
                                                            <div class="waiver-reason">@task.WaiverReason</div>
                                                        }
                                                    </td>
                                                    <td>
                                                        <AuthorizeView Roles="HrisAdmin">
                                                            <Authorized>
                                                                @if (isPending)
                                                                {
                                                                    <button class="btn-link btn-xs"
                                                                            @onclick="() => StartComplete(task.TaskId)">Complete</button>
                                                                    <span class="text-muted"> · </span>
                                                                    <button class="btn-link btn-xs text-muted"
                                                                            @onclick="() => StartWaive(task.TaskId)">Waive</button>
                                                                }
                                                            </Authorized>
                                                        </AuthorizeView>
                                                    </td>
                                                </tr>

                                                @if (_completingTaskId == task.TaskId)
                                                {
                                                    <tr class="inline-form-row">
                                                        <td colspan="7">
                                                            <div class="inline-form">
                                                                <label class="form-label">Completion Date</label>
                                                                <input type="date" class="form-input form-input-sm"
                                                                       @bind="_completionDt" />
                                                                <button class="btn-primary btn-sm"
                                                                        @onclick="() => ConfirmCompleteAsync(task.TaskId)">Confirm</button>
                                                                <button class="btn-secondary btn-sm"
                                                                        @onclick="CancelInlineForm">Cancel</button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }

                                                @if (_waivingTaskId == task.TaskId)
                                                {
                                                    <tr class="inline-form-row">
                                                        <td colspan="7">
                                                            <div class="inline-form">
                                                                <label class="form-label">Waiver Reason</label>
                                                                <input type="text" class="form-input form-input-sm"
                                                                       @bind="_waiveReason" placeholder="Enter reason…" />
                                                                <button class="btn-primary btn-sm"
                                                                        @onclick="() => ConfirmWaiveAsync(task.TaskId)">Confirm</button>
                                                                <button class="btn-secondary btn-sm"
                                                                        @onclick="CancelInlineForm">Cancel</button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="placeholder-text">No onboarding tasks found.</p>
                            }
                        </div>
                    }
                    break;

                case "Community":
                    <div class="detail-section">
                        <h3 class="section-title">Community Profile</h3>
                        <p class="section-subtitle">Optional — visible to colleagues. Share a photo and a bit about yourself.</p>

                        @if (_communityLoading)
                        {
                            <p class="loading-text">Loading…</p>
                        }
                        else
                        {
                            @* Photo *@
                            <div class="community-photo-row">
                                @if (_communityHasPhoto && _person is not null)
                                {
                                    <img src="/api/profile-photo/@_person.PersonId?t=@_communityPhotoStamp"
                                         class="community-photo" alt="Profile photo" />
                                }
                                else
                                {
                                    <div class="community-photo-placeholder">
                                        <span>No photo</span>
                                    </div>
                                }
                                <div class="community-photo-actions">
                                    @if (!_communityShowUpload)
                                    {
                                        <button class="btn-secondary" @onclick="() => { _communityShowUpload = true; _communityError = null; _communitySuccess = null; }">
                                            @(_communityHasPhoto ? "Change Photo" : "Upload Photo")
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="upload-inline">
                                            <input id="community-photo-input" type="file" accept="image/*" class="file-input" />
                                            <p class="upload-hint">JPEG, PNG or WebP · max 2 MB</p>
                                            <div style="display:flex;gap:.5rem;margin-top:.5rem;">
                                                <button class="btn-primary" @onclick="SaveCommunityPhotoAsync" disabled="@_communitySaving">
                                                    @(_communitySaving ? "Uploading…" : "Save Photo")
                                                </button>
                                                <button class="btn-secondary" @onclick="() => { _communityShowUpload = false; _communityError = null; }">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* Bio *@
                            <div class="community-bio-section">
                                <label class="detail-label">About Me</label>
                                <textarea class="community-bio-input" rows="5" maxlength="1000"
                                          placeholder="Hobbies, interests, what you do outside of work…"
                                          @bind="_communityBio" @bind:event="oninput" />
                                <div class="community-bio-footer">
                                    <span class="char-count">@_communityBio.Length / 1,000</span>
                                    <button class="btn-primary" @onclick="SaveCommunityBioAsync" disabled="@_communitySaving">
                                        @(_communitySaving ? "Saving…" : "Save")
                                    </button>
                                </div>
                            </div>

                            @if (_communityError is not null)
                            {
                                <p class="form-error" style="margin-top:.75rem;">@_communityError</p>
                            }
                            @if (_communitySuccess is not null)
                            {
                                <p class="form-success" style="margin-top:.75rem;">@_communitySuccess</p>
                            }
                        }
                    </div>
                    break;

                case "History":
                    <div class="detail-section">
                        <h3 class="section-title">Lifecycle Event History</h3>
                        <p class="placeholder-text">Event history — populated as lifecycle events are recorded.</p>
                    </div>
                    break;
            }
        </div>

    </div>
}

