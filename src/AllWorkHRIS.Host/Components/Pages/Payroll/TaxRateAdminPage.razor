    .data-table--nested th { background:#f3f4f6; }
    .row-open td    { background:#f0fdf4; }
    .row-current td { background:#eff6ff; }

    .rate-set { margin-bottom:1rem; }
    .rate-set-hdr { display:flex; align-items:center; gap:.6rem; margin-bottom:.3rem; }
    .set-label { font-size:.8rem; font-weight:600; color:#374151; font-family:monospace; }
    .open-badge    { display:inline-block; padding:1px 6px; border-radius:9999px; font-size:.7rem; font-weight:600; background:#d1fae5; color:#065f46; }
    .closed-badge  { display:inline-block; padding:1px 6px; border-radius:9999px; font-size:.7rem; font-weight:600; background:#f3f4f6; color:#6b7280; }
    .current-badge { display:inline-block; padding:1px 6px; border-radius:9999px; font-size:.7rem; font-weight:600; background:#dbeafe; color:#1e40af; }

    .close-panel { display:flex; align-items:center; flex-wrap:wrap; gap:.5rem; background:#fff7ed; border:1px solid #fed7aa; border-radius:var(--radius-md); padding:var(--space-3); margin-bottom:.75rem; font-size:.85rem; }
    .inline-err { color:#dc2626; font-size:.8rem; }

    .empty-msg { color:#6b7280; font-size:.85rem; font-style:italic; margin:0 0 .75rem; }
    .hint-msg  { color:#92400e; font-size:.8rem; background:#fef3c7; border:1px solid #fcd34d; border-radius:4px; padding:4px 10px; display:inline-block; margin:0 0 .5rem; }
    .form-error { color:#dc2626; font-size:.85rem; margin:.25rem 0 0; }
    .req { color:#dc2626; }

    .btn-add { display:inline-block; padding:4px 12px; border-radius:4px; font-size:.8rem; cursor:pointer; border:1px dashed #d1d5db; background:white; color:#374151; }
    .btn-add:hover { background:#f9fafb; border-color:#9ca3af; }

    .btn-close { padding:2px 7px; border-radius:4px; font-size:.75rem; cursor:pointer; border:1px solid #fca5a5; background:#fee2e2; color:#991b1b; }
    .btn-close:hover { background:#fecaca; }

    .btn-action { padding:3px 10px; border-radius:4px; font-size:.8rem; cursor:pointer; border:1px solid #d1d5db; background:white; color:var(--aw-navy); }
    .btn-action:hover { background:#f9fafb; }
    .btn-action--danger { background:#fee2e2; border-color:#fca5a5; color:#991b1b; }

    .btn-primary { background:var(--aw-teal); color:white; border:none; border-radius:var(--radius-md); padding:var(--space-2) var(--space-4); font-size:var(--font-size-sm); font-weight:500; cursor:pointer; }
    .btn-primary:hover:not(:disabled) { opacity:.9; }
    .btn-primary:disabled { opacity:.5; cursor:not-allowed; }

    .btn-secondary { background:white; color:#374151; border:1px solid #d1d5db; border-radius:var(--radius-md); padding:var(--space-2) var(--space-4); font-size:var(--font-size-sm); font-weight:500; cursor:pointer; }
    .btn-secondary:hover { background:#f9fafb; }

    .insert-panel { background:#f9fafb; border:1px solid #e5e7eb; border-radius:var(--radius-md); padding:var(--space-4); margin-top:.5rem; }
    .insert-heading { font-size:.85rem; font-weight:600; color:var(--aw-navy); margin:0 0 .75rem; }

    .ins-grid { display:grid; grid-template-columns:max-content 1fr; gap:.4rem var(--space-3,1rem); align-items:center; margin-bottom:.5rem; }
    .ins-grid label { font-size:.8rem; font-weight:500; color:#374151; white-space:nowrap; }
    .form-label { font-size:var(--font-size-sm); font-weight:500; color:#374151; }
    .form-control { padding:var(--space-2); border:1px solid #d1d5db; border-radius:var(--radius-md); font-size:var(--font-size-sm); background:white; width:100%; box-sizing:border-box; }
</style>
