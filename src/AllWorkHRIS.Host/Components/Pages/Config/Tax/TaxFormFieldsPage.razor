@page "/config/tax/form-fields"
@layout TaxConfigShell
@rendermode InteractiveServer
@attribute [Authorize(Roles = "TaxAdmin,ComplianceReviewer,PayrollAdmin,SystemAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using AllWorkHRIS.Host.Config.Tax
@inject ITaxConfigRepository        TaxConfig
@inject AuthenticationStateProvider AuthState

<PageTitle>Form Fields — Tax Configuration</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Form Field Definitions</h2>
        <p class="page-subtitle">Configure required/optional fields per tax form type and manage field status.</p>
    </div>
</div>

<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">
    <label class="form-label" style="margin:0;white-space:nowrap;">Form Type</label>
    <select class="form-control" style="max-width:300px;" @bind="_selectedFormType" @bind:after="LoadFieldsAsync">
        <option value="">— select —</option>
        @foreach (var ft in _formTypes)
        {
            <option value="@ft.Code">@ft.Label</option>
        }
    </select>
</div>

@if (_loading)
{
    <p class="loading-text">Loading…</p>
}
else if (!string.IsNullOrEmpty(_selectedFormType) && _fields.Count == 0)
{
    <p class="loading-text">No field definitions found for this form type.</p>
}
else if (_fields.Count > 0)
{
    <div class="grid-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Order</th>
                    <th>Section</th>
                    <th>Label</th>
                    <th>Key</th>
                    <th>Type</th>
                    <th>Required</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var field in _fields)
                {
                    var f = field;
                    <tr>
                        <td class="mono">@f.DisplayOrder</td>
                        <td style="color:#6b7280;font-size:.8rem;">@(f.SectionLabel ?? "—")</td>
                        <td>@f.DisplayLabel</td>
                        <td class="mono">@f.FieldKey</td>
                        <td><span class="type-badge">@f.FieldType</span></td>
                        <td>
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                <input type="checkbox" checked="@f.IsRequired"
                                       @onchange="e => ToggleRequiredAsync(f, (bool)(e.Value ?? false))" />
                                <span style="font-size:.8rem;">@(f.IsRequired ? "Required" : "Optional")</span>
                            </label>
                        </td>
                        <td><span class="status-badge status-@f.StatusCode.ToLower().Replace('_','-')">@f.StatusCode</span></td>
                        <td>
                            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                                @if (f.StatusCode == "DRAFT")
                                {
                                    <button class="btn-action" @onclick="() => SubmitForReviewAsync(f)">Submit</button>
                                }
                                @if (f.StatusCode == "APPROVED")
                                {
                                    <button class="btn-action btn-action--success" @onclick="() => ActivateAsync(f)">Activate</button>
                                }
                                @if (f.StatusCode is "DRAFT" or "ACTIVE")
                                {
                                    <button class="btn-action btn-action--danger" @onclick="() => ArchiveAsync(f)">Archive</button>
                                }
                            </div>
                            @if (_actionErrors.TryGetValue(f.FieldDefinitionId, out var err) && err is not null)
                            {
                                <p style="color:#dc2626;font-size:.75rem;margin:.25rem 0 0;">@err</p>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool   _loading         = false;
    private string _selectedFormType = string.Empty;
    private List<FormFieldConfigRow>    _fields       = [];
    private Dictionary<int, string?>   _actionErrors = [];

    private static readonly (string Code, string Label)[] _formTypes =
    [
        ("W4_2020",   "US Federal W-4 (2020+)"),
        ("W4_LEGACY", "US Federal W-4 (Pre-2020)"),
        ("G_4",       "Georgia G-4"),
        ("IT_2104",   "New York IT-2104"),
        ("DE_4",      "California DE-4"),
        ("TD1",       "Canada TD1 (Federal)"),
        ("BB_TD4",    "Barbados TD4"),
    ];

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    private async Task LoadFieldsAsync()
    {
        if (string.IsNullOrEmpty(_selectedFormType)) { _fields = []; return; }
        _loading = true;
        _actionErrors.Clear();
        StateHasChanged();
        _fields  = (await TaxConfig.GetFormFieldsAsync(_selectedFormType)).ToList();
        _loading = false;
    }

    private async Task ToggleRequiredAsync(FormFieldConfigRow field, bool isRequired)
    {
        _actionErrors[field.FieldDefinitionId] = null;
        try
        {
            var auth  = await AuthState.GetAuthenticationStateAsync();
            var actor = auth.User.Identity?.Name ?? "system";
            await TaxConfig.UpdateFormFieldRequiredAsync(field.FieldDefinitionId, isRequired, actor);
            await LoadFieldsAsync();
        }
        catch (Exception ex) { _actionErrors[field.FieldDefinitionId] = ex.Message; }
    }

    private async Task SubmitForReviewAsync(FormFieldConfigRow field) => await TransitionAsync(field, "PENDING_REVIEW");
    private async Task ActivateAsync(FormFieldConfigRow field)        => await TransitionAsync(field, "ACTIVE");
    private async Task ArchiveAsync(FormFieldConfigRow field)         => await TransitionAsync(field, "ARCHIVED");

    private async Task TransitionAsync(FormFieldConfigRow field, string newStatus)
    {
        _actionErrors[field.FieldDefinitionId] = null;
        try
        {
            var auth  = await AuthState.GetAuthenticationStateAsync();
            var actor = auth.User.Identity?.Name ?? "system";
            await TaxConfig.UpdateFormFieldStatusAsync(
                field.FieldDefinitionId, field.FieldKey, field.StatusCode, newStatus, actor);
            await LoadFieldsAsync();
        }
        catch (Exception ex) { _actionErrors[field.FieldDefinitionId] = ex.Message; }
    }
}

<style>
    .page-header   { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; }
    .page-title    { font-size:var(--font-size-lg); font-weight:600; color:var(--aw-navy); margin:0 0 .25rem; }
    .page-subtitle { font-size:var(--font-size-sm); color:#6b7280; margin:0; }
    .loading-text  { color:#6b7280; font-style:italic; }

    .grid-container { background:white; border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); overflow:hidden; }
    .data-table { width:100%; border-collapse:collapse; font-size:var(--font-size-sm); }
    .data-table th { background:#f9fafb; padding:var(--space-3) var(--space-4); text-align:left; font-weight:500; color:#6b7280; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .data-table td { padding:var(--space-3) var(--space-4); border-bottom:1px solid #f3f4f6; color:var(--aw-navy); vertical-align:middle; }
    .data-table tr:last-child td { border-bottom:none; }
    .mono { font-family:monospace; font-size:.8rem; }

    .type-badge { display:inline-block; padding:1px 6px; border-radius:4px; font-size:.75rem; font-weight:500; background:#f0fdf4; color:#166534; }

    .status-badge { display:inline-block; padding:2px 8px; border-radius:9999px; font-size:.75rem; font-weight:600; }
    .status-draft           { background:#fef9c3; color:#854d0e; }
    .status-pending-review  { background:#dbeafe; color:#1d4ed8; }
    .status-approved        { background:#dcfce7; color:#166534; }
    .status-active          { background:#d1fae5; color:#065f46; }
    .status-archived        { background:#f3f4f6; color:#6b7280; }

    .btn-action { padding:3px 10px; border-radius:4px; font-size:.8rem; cursor:pointer; border:1px solid #d1d5db; background:white; color:var(--aw-navy); }
    .btn-action:hover { background:#f9fafb; }
    .btn-action--success { background:#dcfce7; border-color:#86efac; color:#166534; }
    .btn-action--danger  { background:#fee2e2; border-color:#fca5a5; color:#991b1b; }

    .form-label  { font-size:var(--font-size-sm); font-weight:500; color:#374151; }
    .form-control { padding:var(--space-2); border:1px solid #d1d5db; border-radius:var(--radius-md); font-size:var(--font-size-sm); background:white; }
</style>
