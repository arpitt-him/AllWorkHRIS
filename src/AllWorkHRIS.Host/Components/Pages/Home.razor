@page "/"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>AllWork HRIS</PageTitle>

<div class="home-container">
    <div class="home-brand">
        <img src="/images/allworkhr-icon.png"
             alt="AllWork HRIS"
             class="home-icon" />
        <h1 class="home-wordmark">AllWork HRIS</h1>
        <p class="home-tagline">People&nbsp;•&nbsp;Process&nbsp;•&nbsp;Compliance</p>
        @if (_displayName is not null)
        {
            <p class="home-welcome">Welcome, @_displayName</p>
        }
    </div>
</div>

@code {
    private string? _displayName;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _displayName = authState.User.FindFirst("name")?.Value
                    ?? authState.User.Identity?.Name;
    }
}

<style>
    .home-container {
        display: flex;
        align-items: center;
        justify-content: center;
        height: calc(100vh - var(--topbar-height));
    }

    .home-brand {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-4);
    }

    .home-icon {
        width: 120px;
        height: 120px;
        object-fit: contain;
    }

    .home-wordmark {
        font-family: var(--font-family-base);
        font-size: 2rem;
        font-weight: var(--font-weight-semibold);
        color: var(--aw-navy);
        margin: 0;
        letter-spacing: -0.5px;
    }

    .home-tagline {
        font-family: var(--font-family-base);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: var(--aw-blue);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0;
    }

    .home-welcome {
        font-family: var(--font-family-base);
        font-size: var(--font-size-base);
        color: #6B7280;
        margin: var(--space-2) 0 0 0;
    }
</style>
